# Copy this file to .env and replace placeholders
DB_PASSWORD=<DB_PASSWORD>
JWT_SECRET_KEY=<MIN_32_CHAR_RANDOM_SECRET>

ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=kasah_qms;Username=kasahqms;Password=${DB_PASSWORD}
JwtSettings__SecretKey=${JWT_SECRET_KEY}
JwtSettings__Issuer=KasahQMS
JwtSettings__Audience=KasahQMS

Smtp__Host=smtp.sendgrid.net
Smtp__Port=587
Smtp__Username=apikey
Smtp__Password=<SMTP_API_KEY>
Smtp__From=noreply@example.com
Smtp__FromName=KASAH QMS
Smtp__EnableSsl=true

EmailSettings__SmtpServer=smtp.sendgrid.net
EmailSettings__SmtpPort=587
EmailSettings__Username=apikey
EmailSettings__Password=<SMTP_API_KEY>
EmailSettings__FromAddress=noreply@example.com
EmailSettings__FromName=KASAH QMS

Application__BaseUrl=https://your-domain.example
AllowedOrigins__0=https://your-domain.example
