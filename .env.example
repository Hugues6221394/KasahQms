# ===========================================
# KASAH QMS Environment Configuration
# ===========================================
# Copy this file to .env and fill in real values
# NEVER commit the .env file to version control
# ===========================================

# Database
DB_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# JWT Authentication (minimum 32 characters, random string)
JWT_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_STRING_AT_LEAST_32_CHARS

# Email (SMTP) - for notifications, password resets, etc.
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_ADDRESS=noreply@kasah.rw
SMTP_FROM_NAME=KASAH QMS
