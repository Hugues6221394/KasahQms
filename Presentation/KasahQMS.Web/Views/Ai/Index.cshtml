@model KasahQMS.Web.Controllers.AiAssistantViewModel
@{
    ViewData["Title"] = "AI Assistant";
}

<div class="py-8 animate-on-scroll">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 space-y-6">
        <section class="relative overflow-hidden rounded-2xl border border-slate-200 bg-slate-900 text-white" style="background-image:linear-gradient(120deg,rgba(15,23,42,.9),rgba(16,185,129,.45));">
            <div class="p-6 md:p-8">
                <p class="text-xs uppercase tracking-[0.2em] text-emerald-100">AI Workspace</p>
                <h1 class="mt-2 text-3xl font-bold">AI Assistant</h1>
                <p class="mt-2 text-sm text-slate-200">Chat naturally with AI, attach text documents, and continue conversations from history.</p>
            </div>
        </section>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-4">
            <aside class="card p-4 lg:col-span-4">
                <div class="flex items-center justify-between mb-3">
                    <h2 class="text-sm font-semibold text-slate-900">Chat histories</h2>
                    <a href="/Ai" class="rounded-lg border border-slate-300 px-3 py-1.5 text-xs font-medium text-slate-700 hover:bg-slate-50">New chat</a>
                </div>
                <div id="conversationList" class="space-y-2 max-h-[58vh] overflow-y-auto">
                    @if (Model.Conversations.Count == 0)
                    {
                        <div class="rounded-lg border border-dashed border-slate-300 p-3 text-xs text-slate-500">No chat history yet.</div>
                    }
                    else
                    {
                        @foreach (var conversation in Model.Conversations)
                        {
                            var isActive = string.Equals(Model.ActiveConversationId, conversation.ConversationId, StringComparison.OrdinalIgnoreCase);
                            <div class="rounded-xl border @(isActive ? "border-brand-300 bg-brand-50 shadow-sm" : "border-slate-200 bg-white") p-2.5 transition-all duration-300 hover:border-brand-200 hover:shadow-sm conversation-item" data-conversation-id="@conversation.ConversationId">
                                <a href="/Ai?conversationId=@conversation.ConversationId" class="block conversation-open-link">
                                    <div class="text-xs font-semibold text-slate-800 truncate">@conversation.Title</div>
                                    <div class="text-[11px] text-slate-500 mt-0.5">@conversation.UpdatedAt.ToLocalTime().ToString("g")</div>
                                    @if (!string.IsNullOrWhiteSpace(conversation.LastMessagePreview))
                                    {
                                        <div class="text-[11px] text-slate-500 mt-1 truncate">@conversation.LastMessagePreview</div>
                                    }
                                </a>
                                <form asp-controller="Ai" asp-action="DeleteConversation" method="post" class="mt-2 conversation-delete-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="conversationId" value="@conversation.ConversationId" />
                                    <button type="submit" class="rounded-md border border-rose-200 px-2 py-1 text-[11px] text-rose-700 hover:bg-rose-50">Delete</button>
                                </form>
                            </div>
                        }
                    }
                </div>
            </aside>

            <div class="card p-0 overflow-hidden lg:col-span-8">
                <div id="chatThread" class="max-h-[60vh] overflow-y-auto bg-gradient-to-b from-slate-50 to-white p-5 space-y-4">
                    @if (Model.Messages.Count == 0)
                    {
                        <div class="rounded-xl border border-dashed border-slate-300 bg-white p-6 text-center text-sm text-slate-500">
                            Start the conversation by typing a message below.
                        </div>
                    }
                    else
                    {
                        @foreach (var message in Model.Messages)
                        {
                            var isUser = string.Equals(message.Role, "user", StringComparison.OrdinalIgnoreCase);
                            <div class="flex @(isUser ? "justify-end" : "justify-start")">
                                <div class="max-w-[85%]">
                                    <p class="mb-1 text-[11px] font-medium @(isUser ? "text-right text-brand-700" : "text-left text-slate-500")">@(isUser ? "You" : "AI Assistant")</p>
                                    <div class="rounded-2xl px-4 py-3 text-sm whitespace-pre-wrap shadow-sm @(isUser ? "bg-brand-600 text-white" : "bg-white text-slate-700 border border-slate-200")">
                                        @message.Content
                                    </div>
                                </div>
                            </div>
                        }
                    }
                </div>

                <div id="aiTypingIndicator" class="hidden border-t border-slate-100 bg-slate-50 px-5 py-2 text-xs text-slate-500">
                    AI is thinking<span class="inline-flex gap-1 align-middle"><span class="h-1.5 w-1.5 animate-pulse rounded-full bg-slate-400"></span><span class="h-1.5 w-1.5 animate-pulse rounded-full bg-slate-400 [animation-delay:150ms]"></span><span class="h-1.5 w-1.5 animate-pulse rounded-full bg-slate-400 [animation-delay:300ms]"></span></span>
                </div>

                <form id="aiChatForm" asp-controller="Ai" asp-action="Generate" method="post" enctype="multipart/form-data" class="space-y-4 border-t border-slate-200 bg-white p-4">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="conversationId" name="conversationId" value="@Model.ConversationId" />
                    <input type="hidden" id="historyJson" name="historyJson" value="@Model.HistoryJson" />

                    <div class="grid grid-cols-1 md:grid-cols-5 gap-3">
                        <div class="md:col-span-4">
                            <label for="prompt" class="block text-sm font-medium text-slate-700 mb-2">Message</label>
                            <textarea id="prompt" name="prompt" rows="3" class="w-full rounded-2xl border border-slate-300 px-4 py-3 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200" placeholder="Type your message...">@Model.Prompt</textarea>
                        </div>
                        <div>
                            <label for="attachment" class="block text-sm font-medium text-slate-700 mb-2">Attach document</label>
                            <input id="attachment" name="attachment" type="file" accept=".txt,.md,.markdown,.csv,.json,.xml,.html,.htm,.log,.docx,.pdf" class="block w-full rounded-xl border border-slate-300 px-3 py-2 text-xs text-slate-700 file:mr-3 file:rounded-md file:border-0 file:bg-slate-100 file:px-3 file:py-1.5 file:text-xs file:font-medium file:text-slate-700 hover:file:bg-slate-200" />
                            <div id="attachmentStatus" class="mt-2 hidden rounded-md border border-emerald-200 bg-emerald-50 px-2 py-1 text-[11px] text-emerald-700"></div>
                            @if (!string.IsNullOrWhiteSpace(Model.AttachmentName))
                            {
                                <p class="mt-2 text-xs text-slate-500">Last attachment: @Model.AttachmentName</p>
                            }
                            <button type="button" id="clearAttachmentBtn" class="mt-2 rounded-md border border-slate-300 px-2 py-1 text-[11px] text-slate-700 hover:bg-slate-50">Cancel attachment</button>
                        </div>
                    </div>

                    <div class="flex items-center justify-between gap-3">
                        <p class="text-xs text-slate-500">Press Enter to send, Shift+Enter for new line.</p>
                        <button id="sendBtn" type="submit" class="inline-flex items-center rounded-xl bg-brand-600 px-5 py-2.5 text-sm font-semibold text-white hover:bg-brand-700 transition-colors disabled:cursor-not-allowed disabled:opacity-70">Send</button>
                    </div>
                </form>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div id="aiError" class="rounded-xl border border-rose-200 bg-rose-50 p-4 text-sm text-rose-700">@Model.ErrorMessage</div>
        }
        else
        {
            <div id="aiError" class="hidden rounded-xl border border-rose-200 bg-rose-50 p-4 text-sm text-rose-700"></div>
        }
    </div>
</div>

<script>
    (function () {
        const form = document.getElementById('aiChatForm');
        const prompt = document.getElementById('prompt');
        const sendBtn = document.getElementById('sendBtn');
        const chatThread = document.getElementById('chatThread');
        const historyJsonInput = document.getElementById('historyJson');
        const conversationIdInput = document.getElementById('conversationId');
        const conversationList = document.getElementById('conversationList');
        const aiError = document.getElementById('aiError');
        const attachmentInput = document.getElementById('attachment');
        const attachmentStatus = document.getElementById('attachmentStatus');
        const clearAttachmentBtn = document.getElementById('clearAttachmentBtn');
        const typingIndicator = document.getElementById('aiTypingIndicator');

        function escapeHtml(value) {
            return (value || '')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }

        function renderMessages(messages) {
            if (!chatThread) return;
            chatThread.innerHTML = '';
            if (!messages || messages.length === 0) {
                chatThread.innerHTML = '<div class="rounded-xl border border-dashed border-slate-300 bg-white p-6 text-center text-sm text-slate-500">Start the conversation by typing a message below.</div>';
                return;
            }

            messages.forEach(function (message) {
                const isUser = String(message.role || '').toLowerCase() === 'user';
                const row = document.createElement('div');
                row.className = 'flex ' + (isUser ? 'justify-end' : 'justify-start');
                const wrapper = document.createElement('div');
                wrapper.className = 'max-w-[85%]';
                const role = document.createElement('p');
                role.className = 'mb-1 text-[11px] font-medium ' + (isUser ? 'text-right text-brand-700' : 'text-left text-slate-500');
                role.textContent = isUser ? 'You' : 'AI Assistant';
                const bubble = document.createElement('div');
                bubble.className = 'rounded-2xl px-4 py-3 text-sm whitespace-pre-wrap shadow-sm ' + (isUser ? 'bg-brand-600 text-white' : 'bg-white text-slate-700 border border-slate-200');
                bubble.textContent = message.content || '';
                wrapper.appendChild(role);
                wrapper.appendChild(bubble);
                row.appendChild(wrapper);
                chatThread.appendChild(row);
            });
            chatThread.scrollTop = chatThread.scrollHeight;
        }

        function renderConversations(conversations, activeConversationId, antiForgery) {
            if (!conversationList) return;
            conversationList.innerHTML = '';
            if (!conversations || conversations.length === 0) {
                conversationList.innerHTML = '<div class="rounded-lg border border-dashed border-slate-300 p-3 text-xs text-slate-500">No chat history yet.</div>';
                return;
            }

            conversations.forEach(function (c) {
                const isActive = String(c.conversationId || '') === String(activeConversationId || '');
                const item = document.createElement('div');
                item.className = 'rounded-lg border p-2 conversation-item ' + (isActive ? 'border-brand-300 bg-brand-50' : 'border-slate-200 bg-white');
                item.setAttribute('data-conversation-id', c.conversationId || '');
                item.innerHTML =
                    '<a href="/Ai?conversationId=' + encodeURIComponent(c.conversationId || '') + '" class="block conversation-open-link">' +
                    '<div class="text-xs font-semibold text-slate-800 truncate">' + escapeHtml(c.title || 'Conversation') + '</div>' +
                    '<div class="text-[11px] text-slate-500 mt-0.5">' + new Date(c.updatedAt).toLocaleString() + '</div>' +
                    ((c.lastMessagePreview && c.lastMessagePreview.length > 0)
                        ? ('<div class="text-[11px] text-slate-500 mt-1 truncate">' + escapeHtml(c.lastMessagePreview) + '</div>')
                        : '') +
                    '</a>' +
                    '<form action="/Ai/DeleteConversation" method="post" class="mt-2 conversation-delete-form">' +
                    '<input type="hidden" name="__RequestVerificationToken" value="' + escapeHtml(antiForgery || '') + '" />' +
                    '<input type="hidden" name="conversationId" value="' + escapeHtml(c.conversationId || '') + '" />' +
                    '<button type="submit" class="rounded-md border border-rose-200 px-2 py-1 text-[11px] text-rose-700 hover:bg-rose-50">Delete</button>' +
                    '</form>';
                conversationList.appendChild(item);
            });
        }

        function toggleError(message) {
            if (!aiError) return;
            if (message && message.length > 0) {
                aiError.textContent = message;
                aiError.classList.remove('hidden');
            } else {
                aiError.textContent = '';
                aiError.classList.add('hidden');
            }
        }

        if (chatThread) {
            chatThread.scrollTop = chatThread.scrollHeight;
        }

        if (attachmentInput && attachmentStatus) {
            attachmentInput.addEventListener('change', function () {
                const file = this.files && this.files.length > 0 ? this.files[0] : null;
                if (!file) {
                    attachmentStatus.classList.add('hidden');
                    attachmentStatus.textContent = '';
                    return;
                }
                const kb = Math.max(1, Math.round(file.size / 1024));
                attachmentStatus.textContent = 'Attached: ' + file.name + ' (' + kb + ' KB)';
                attachmentStatus.classList.remove('hidden');
            });
        }

        if (clearAttachmentBtn && attachmentInput) {
            clearAttachmentBtn.addEventListener('click', function () {
                attachmentInput.value = '';
                if (attachmentStatus) {
                    attachmentStatus.classList.add('hidden');
                    attachmentStatus.textContent = '';
                }
            });
        }

        if (prompt) {
            prompt.addEventListener('keydown', function (e) {
                if (e.key === 'Enter' && !e.shiftKey) {
                    e.preventDefault();
                    if (form) {
                        form.requestSubmit();
                    }
                }
            });
        }

        if (form) {
            form.addEventListener('submit', async function (e) {
                e.preventDefault();
                toggleError('');

                const formData = new FormData(form);
                if (sendBtn) sendBtn.disabled = true;
                if (prompt) prompt.disabled = true;
                if (typingIndicator) typingIndicator.classList.remove('hidden');

                try {
                    const antiForgeryToken = formData.get('__RequestVerificationToken');
                    const response = await fetch(form.action, {
                        method: 'POST',
                        headers: { 'X-Requested-With': 'XMLHttpRequest' },
                        body: formData
                    });

                    if (!response.ok) {
                        throw new Error('Request failed');
                    }

                    const result = await response.json();
                    if (conversationIdInput && result.conversationId) conversationIdInput.value = result.conversationId;
                    if (historyJsonInput && typeof result.historyJson === 'string') historyJsonInput.value = result.historyJson;

                    renderMessages(result.messages || []);
                    renderConversations(result.conversations || [], result.conversationId, antiForgeryToken);
                    toggleError(result.errorMessage || '');

                    if (prompt) prompt.value = '';
                    if (attachmentInput) attachmentInput.value = '';
                    if (attachmentStatus) {
                        attachmentStatus.classList.add('hidden');
                        attachmentStatus.textContent = '';
                    }
                } catch {
                    toggleError('AI request failed. Please try again.');
                } finally {
                    if (typingIndicator) typingIndicator.classList.add('hidden');
                    if (sendBtn) sendBtn.disabled = false;
                    if (prompt) {
                        prompt.disabled = false;
                        prompt.focus();
                    }
                }
            });
        }
    })();
</script>
