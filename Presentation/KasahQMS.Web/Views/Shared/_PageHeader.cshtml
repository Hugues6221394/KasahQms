@* 
    KASAH QMS - Reusable Page Header Component
    
    Usage in a view:
    @await Html.PartialAsync("_PageHeader", new ViewDataDictionary(ViewData) {
        { "Title", "Documents" },
        { "Subtitle", "Manage all quality documents" },
        { "BreadcrumbItems", new[] { ("Dashboard", "/Dashboard"), ("Documents", "") } }
    })
    
    Or minimal usage:
    @await Html.PartialAsync("_PageHeader")
    (Will use ViewData["Title"] automatically)
    
    For action buttons, define a section in the calling view or pass HTML via ViewData["ActionButtons"].
*@
@{
    var headerTitle = ViewData["Title"]?.ToString() ?? "Page";
    var headerSubtitle = ViewData["Subtitle"]?.ToString();
    var breadcrumbItems = ViewData["BreadcrumbItems"] as (string Label, string Href)[];
    var actionButtonsHtml = ViewData["ActionButtons"]?.ToString();
}

<div class="page-header mb-6">
    <div>
        @if (breadcrumbItems != null && breadcrumbItems.Length > 0)
        {
            <nav class="breadcrumb mb-2" aria-label="Breadcrumb">
                <span class="breadcrumb-item">
                    <a href="/Dashboard">
                        <svg class="w-4 h-4 inline-block -mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
                        </svg>
                    </a>
                </span>
                @for (int i = 0; i < breadcrumbItems.Length; i++)
                {
                    <span class="breadcrumb-separator">/</span>
                    @if (!string.IsNullOrEmpty(breadcrumbItems[i].Href))
                    {
                        <span class="breadcrumb-item">
                            <a href="@breadcrumbItems[i].Href">@breadcrumbItems[i].Label</a>
                        </span>
                    }
                    else
                    {
                        <span class="breadcrumb-item">@breadcrumbItems[i].Label</span>
                    }
                }
            </nav>
        }
        <h1 class="page-title">@headerTitle</h1>
        @if (!string.IsNullOrEmpty(headerSubtitle))
        {
            <p class="page-subtitle">@headerSubtitle</p>
        }
    </div>
    @if (!string.IsNullOrEmpty(actionButtonsHtml))
    {
        <div class="flex items-center gap-3 flex-shrink-0">
            @Html.Raw(actionButtonsHtml)
        </div>
    }
</div>
