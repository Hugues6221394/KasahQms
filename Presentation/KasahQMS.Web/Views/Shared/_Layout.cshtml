                        </svg>
                        <span>Activity Log</span>
                    </a>
                }
            </div>

            <!-- Operations Section -->
            <div class="space-y-1.5">
                <div class="px-3 pb-2 text-[11px] font-semibold uppercase tracking-wider text-slate-400">Operations</div>
