                {
                <div class="hidden md:flex items-center gap-2 px-3 py-2 text-sm font-medium text-amber-700 bg-amber-50 rounded-lg">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                    </svg>
                    Read-only Mode
                </div>
                }

                <!-- Notifications -->
                <div id="notif-wrapper" class="relative">
                    <button id="notif-btn" type="button" class="relative p-2.5 text-slate-400 hover:text-slate-600 hover:bg-slate-100 rounded-lg transition-colors">
                        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
                        </svg>
                        <span id="notification-dot" class="hidden absolute top-2 right-2 h-2 w-2 rounded-full bg-brand-500 ring-2 ring-white"></span>
                        <span id="badge-notifications" class="hidden absolute -top-1 -right-1 min-w-[18px] h-[18px] px-1 text-[10px] font-bold text-white bg-brand-500 rounded-full flex items-center justify-center">0</span>
                    </button>
                    <div id="notif-panel" class="hidden absolute right-0 mt-2 w-[30rem] rounded-2xl border border-slate-200/80 notif-panel-glass shadow-xl py-2 origin-top-right z-50">
                        <div class="px-4 py-3 border-b border-slate-100 flex justify-between items-center">
                            <div>
                                <div class="flex items-center gap-2">
                                    <span class="font-semibold text-slate-800">Live Notifications</span>
                                    <span class="inline-flex items-center gap-1 rounded-full bg-emerald-50 px-2 py-0.5 text-[10px] font-semibold text-emerald-700">
                                        <span class="h-1.5 w-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
                                        Live
                                    </span>
                                </div>
                                <p class="text-[11px] text-slate-500 mt-0.5">Instant updates across tasks, approvals, and documents</p>
                            </div>
                            <a href="/Notifications" class="text-sm text-brand-600 hover:underline">View all</a>
                        </div>
                        <div id="notif-connection-state" class="hidden px-4 py-2 text-xs font-medium text-amber-700 bg-amber-50 border-b border-amber-100">
                            Reconnecting live updates...
                        </div>
                        <div class="max-h-[26rem] overflow-y-auto px-2">
                            <div id="notif-loading" class="hidden p-3">
                                <div class="space-y-2">
                                    <div class="h-16 rounded-xl notif-shimmer"></div>
                                    <div class="h-16 rounded-xl notif-shimmer"></div>
                                </div>
                            </div>
                            <div id="notif-empty" class="p-6 text-center text-slate-500 text-sm">
                                <div class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-slate-100 text-slate-400 mb-2">
                                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
                                </div>
                                <div>You're all caught up.</div>
                            </div>
                            <div id="notif-list" class="hidden space-y-2 py-2"></div>
                        </div>
                        <div class="px-4 py-2 border-t border-slate-100 flex items-center justify-between">
                            <button id="notif-mark-all-btn" type="button" class="text-xs font-medium text-slate-600 hover:text-slate-900">Mark all as read</button>
                            <button id="notif-load-more-btn" type="button" class="hidden text-xs font-semibold text-brand-600 hover:text-brand-700">Load more</button>
                        </div>
                    </div>
                </div>

                <!-- Divider -->
                <div class="hidden md:block h-8 w-px bg-slate-200 mx-1"></div>

                <!-- User Menu -->
                <div id="user-menu-wrapper" class="relative">
                    <button id="user-menu-btn" type="button" class="flex items-center gap-3 pl-2 pr-3 py-1.5 hover:bg-slate-50 rounded-xl transition-colors">
                        <div class="h-9 w-9 rounded-xl bg-gradient-to-br from-brand-500 to-brand-700 flex items-center justify-center text-white text-sm font-bold shadow-md shadow-brand-500/30">
                            @initials
                        </div>
                        <div class="text-left hidden md:block">
                            <div class="text-sm font-semibold text-slate-800">@displayName</div>
                            <div class="text-xs text-slate-500">@roleLabel</div>
                        </div>
                        <svg id="user-menu-chevron" class="hidden md:block h-4 w-4 text-slate-400 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                        </svg>
                    </button>
                    <div id="user-menu-panel" class="hidden absolute right-0 mt-2 w-56 rounded-xl border border-slate-200 bg-white shadow-xl shadow-slate-200/50 py-1 origin-top-right z-50">
                        <div class="px-4 py-3 border-b border-slate-100">
                            <p class="text-sm font-semibold text-slate-900">@displayName</p>
                            <p class="text-xs text-slate-500 truncate">@roleLabel</p>
                        </div>
                        <div class="py-1">
                            <a class="flex items-center gap-3 px-4 py-2.5 text-sm text-slate-600 hover:bg-slate-50 hover:text-slate-900 transition-colors" href="/Profile">
                                <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                                </svg>
                                My Profile
                            </a>
                            <a class="flex items-center gap-3 px-4 py-2.5 text-sm text-slate-600 hover:bg-slate-50 hover:text-slate-900 transition-colors" href="/Account/ChangePassword">
                                <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/>
                                </svg>
                                Change Password
                            </a>
                            <a class="flex items-center gap-3 px-4 py-2.5 text-sm text-slate-600 hover:bg-slate-50 hover:text-slate-900 transition-colors" href="/Settings">
                                <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                </svg>
                                Settings
                            </a>
                        </div>
                        <div class="border-t border-slate-100 py-1">
                            <a class="flex items-center gap-3 px-4 py-2.5 text-sm text-red-600 hover:bg-red-50 transition-colors" href="/Account/Logout">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                                </svg>
                                Sign out
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </header>

        <!-- Main Content Area -->
        <main class="app-main flex-1 p-6 lg:p-8">
            <div class="page-transition-wrapper">
                @RenderBody()
            </div>
        </main>

        <!-- Toast Notification Container -->
        <div id="toast-container" class="toast-container"></div>

        <!-- Footer -->
        <footer class="px-6 py-4 border-t border-slate-200/80 bg-white/50">
            <div class="flex flex-col sm:flex-row items-center justify-between gap-2 text-xs text-slate-500">
                <p>© @DateTime.Now.Year KASAH Technologies. All rights reserved.</p>
                <p class="flex items-center gap-1">
                    <span class="inline-block w-2 h-2 bg-brand-500 rounded-full animate-pulse"></span>
                    System operational
                </p>
            </div>
        </footer>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
<script>
// =====================================================
// Header Dropdowns - Pure Vanilla JS (no Alpine dependency)
// =====================================================
(function() {
  var panels = [];

  function closeAll(except) {
    panels.forEach(function(p) { if (p !== except) p.classList.add('hidden'); });
    var chevron = document.getElementById('user-menu-chevron');
    if (chevron && except !== document.getElementById('user-menu-panel')) chevron.classList.remove('rotate-180');
  }

  function togglePanel(panelId, chevronId) {
    var panel = document.getElementById(panelId);
    if (!panel) return;
    var isHidden = panel.classList.contains('hidden');
    closeAll(panel);
    if (isHidden) {
      panel.classList.remove('hidden');
      if (chevronId) { var c = document.getElementById(chevronId); if (c) c.classList.add('rotate-180'); }
    } else {
      panel.classList.add('hidden');
      if (chevronId) { var c2 = document.getElementById(chevronId); if (c2) c2.classList.remove('rotate-180'); }
    }
  }

  document.addEventListener('DOMContentLoaded', function() {
    var qaPanel = document.getElementById('quick-add-panel');
    var notifPanel = document.getElementById('notif-panel');
    var userPanel = document.getElementById('user-menu-panel');

    if (qaPanel) panels.push(qaPanel);
    if (notifPanel) panels.push(notifPanel);
    if (userPanel) panels.push(userPanel);

    // Quick Add
    var qaBtn = document.getElementById('quick-add-btn');
    if (qaBtn) qaBtn.addEventListener('click', function(e) { e.stopPropagation(); togglePanel('quick-add-panel', null); });

    // Notifications
    var notifBtn = document.getElementById('notif-btn');
    if (notifBtn) {
      notifBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        var wasHidden = notifPanel && notifPanel.classList.contains('hidden');
        togglePanel('notif-panel', null);
        if (wasHidden) { fetchNotifications(); }
      });
    }

    // User Menu
    var userBtn = document.getElementById('user-menu-btn');
    if (userBtn) userBtn.addEventListener('click', function(e) { e.stopPropagation(); togglePanel('user-menu-panel', 'user-menu-chevron'); });

    // Mobile sidebar (robust fallback independent of Alpine)
    var sidebar = document.getElementById('mobile-sidebar');
    var sidebarOverlay = document.getElementById('mobile-sidebar-overlay');
    var sidebarOpenBtn = document.getElementById('mobile-sidebar-open');
    var sidebarCloseBtn = document.getElementById('mobile-sidebar-close');
    var sidebarNav = document.getElementById('mobile-sidebar-nav');

    function setMobileSidebar(open) {
      if (!sidebar || window.innerWidth >= 1024) return;
      if (open) {
        sidebar.classList.remove('-translate-x-full');
        sidebar.classList.add('translate-x-0');
        if (sidebarOverlay) sidebarOverlay.classList.remove('hidden');
        document.body.classList.add('overflow-hidden');
      } else {
        sidebar.classList.add('-translate-x-full');
        sidebar.classList.remove('translate-x-0');
        if (sidebarOverlay) sidebarOverlay.classList.add('hidden');
        document.body.classList.remove('overflow-hidden');
      }
    }

    if (sidebarOpenBtn) sidebarOpenBtn.addEventListener('click', function() { setMobileSidebar(true); });
    if (sidebarCloseBtn) sidebarCloseBtn.addEventListener('click', function() { setMobileSidebar(false); });
    if (sidebarOverlay) sidebarOverlay.addEventListener('click', function() { setMobileSidebar(false); });
    if (sidebarNav) sidebarNav.addEventListener('click', function(e) { if (e.target && e.target.closest('a')) setMobileSidebar(false); });
    window.addEventListener('keydown', function(e) { if (e.key === 'Escape') setMobileSidebar(false); });
    window.addEventListener('resize', function() {
      if (window.innerWidth >= 1024) {
        if (sidebarOverlay) sidebarOverlay.classList.add('hidden');
        document.body.classList.remove('overflow-hidden');
      } else if (sidebar && !sidebar.classList.contains('translate-x-0')) {
        sidebar.classList.add('-translate-x-full');
      }
    });

    // Close on outside click
    document.addEventListener('click', function() { closeAll(null); });
    // Prevent panel clicks from closing
    panels.forEach(function(p) { if (p) p.addEventListener('click', function(e) { e.stopPropagation(); }); });
  });

  // ---- Notifications fetch & render ----
  var notifUnreadCount = 0;
  var notifItems = [];
  var notifHasMore = false;
  var notifNextBefore = null;
  var notifLoadingMore = false;
  var maxFeedItems = 100;
  var lastIncomingNotificationId = null;

  function renderRelativeTime(iso) {
    if (!iso) return '';
    var then = new Date(iso).getTime();
    var now = Date.now();
    var delta = Math.max(0, Math.floor((now - then) / 1000));
    if (delta < 60) return delta + 's ago';
    if (delta < 3600) return Math.floor(delta / 60) + 'm ago';
    if (delta < 86400) return Math.floor(delta / 3600) + 'h ago';
    return Math.floor(delta / 86400) + 'd ago';
  }

  function notifAccent(relType) {
    if (relType === 'task' || relType === 'taskassignment') return 'bg-amber-100 text-amber-700';
    if (relType.indexOf('document') === 0 || relType === 'document') return 'bg-emerald-100 text-emerald-700';
    if (relType === 'training') return 'bg-violet-100 text-violet-700';
    if (relType === 'chat' || relType === 'message') return 'bg-blue-100 text-blue-700';
    return 'bg-brand-100 text-brand-700';
  }

  function renderNotifications() {
    var loading = document.getElementById('notif-loading');
    var empty = document.getElementById('notif-empty');
    var list = document.getElementById('notif-list');
    var dot = document.getElementById('notification-dot');
    if (!list) return;
    if (loading) loading.classList.add('hidden');
    if (notifItems.length === 0) {
      if (empty) empty.classList.remove('hidden');
      if (list) list.classList.add('hidden');
    } else {
      if (empty) empty.classList.add('hidden');
      list.classList.remove('hidden');
      list.innerHTML = notifItems.map(function(n) {
        var relType = String(n.relatedEntityType || '').toLowerCase();
        var href = '/Notifications';
        if (n.relatedEntityId) {
          if (relType === 'taskassignment' || relType === 'task') href = '/Tasks/Details/' + n.relatedEntityId;
          else if (relType.startsWith('document') || relType === 'document') href = '/Documents/Details/' + n.relatedEntityId;
          else if (relType === 'training') href = '/Training/Details/' + n.relatedEntityId;
        }
        var time = n.createdAt ? new Date(n.createdAt).toLocaleString() : '';
        var relative = renderRelativeTime(n.createdAt);
        var accent = notifAccent(relType);
        var isNewClass = String(n.id || '') === String(lastIncomingNotificationId || '') ? ' notif-item-new' : '';
        return '<a href="' + href + '" onclick="qmsNotifGo(event,\'' + (n.id||'') + '\',\'' + href + '\')" class="notif-item block px-3 py-3 rounded-xl bg-white/90 hover:bg-white cursor-pointer border border-slate-100 shadow-sm' + isNewClass + '">'
          + '<div class="flex items-start justify-between gap-2">'
          + '<div class="inline-flex items-center rounded-full px-2 py-0.5 text-[10px] font-semibold mb-1 ' + accent + '">New</div>'
          + '<div class="text-[11px] text-slate-400 whitespace-nowrap">' + relative + '</div>'
          + '</div>'
          + '<div class="font-semibold text-slate-900 text-sm leading-5">' + (n.title||'') + '</div>'
          + '<div class="text-slate-500 text-xs mt-0.5 line-clamp-2">' + (n.message||'') + '</div>'
          + '<div class="text-slate-400 text-[11px] mt-2 flex items-center justify-end"><span>' + time + '</span></div>'
          + '</a>';
      }).join('');
      if (lastIncomingNotificationId) {
        setTimeout(function(){ lastIncomingNotificationId = null; }, 900);
      }
    }
    var loadMoreBtn = document.getElementById('notif-load-more-btn');
    if (loadMoreBtn) {
      if (notifHasMore) loadMoreBtn.classList.remove('hidden');
      else loadMoreBtn.classList.add('hidden');
      loadMoreBtn.disabled = notifLoadingMore;
      loadMoreBtn.textContent = notifLoadingMore ? 'Loading...' : 'Load more';
    }
    var markAllBtn = document.getElementById('notif-mark-all-btn');
    if (markAllBtn) {
      markAllBtn.disabled = notifUnreadCount === 0;
      markAllBtn.classList.toggle('opacity-50', notifUnreadCount === 0);
    }
    if (dot) { notifUnreadCount > 0 ? dot.classList.remove('hidden') : dot.classList.add('hidden'); }
  }

  function mergeIncomingNotification(n) {
    if (!n || !n.id) return;
    notifItems = notifItems.filter(function(x){ return String(x.id) !== String(n.id); });
    notifItems.unshift(n);
    lastIncomingNotificationId = n.id;
    if (notifItems.length > maxFeedItems) {
      notifItems = notifItems.slice(0, maxFeedItems);
    }
  }

  window.qmsNotifGo = function(e, id, href) {
    e.preventDefault();
    if (id) {
      fetch('/api/NotificationsApi/' + id + '/read', { method: 'POST' }).finally(function() {
        notifItems = notifItems.filter(function(n){ return String(n.id) !== String(id); });
        notifUnreadCount = Math.max(0, notifUnreadCount - 1);
        renderNotifications();
        if (window.qmsRefreshBadges) window.qmsRefreshBadges();
        window.location.href = href;
      });
    }
    else { window.location.href = href; }
  };

  function fetchNotifications(before, append) {
    var loading = document.getElementById('notif-loading');
    var empty = document.getElementById('notif-empty');
    var list = document.getElementById('notif-list');
    if (!append && loading) loading.classList.remove('hidden');
    if (empty) empty.classList.add('hidden');
    if (!append && list) list.classList.add('hidden');
    var url = '/api/NotificationsApi?limit=15&unreadOnly=true';
    if (before) url += '&before=' + encodeURIComponent(before);
    fetch(url).then(function(r) { return r.json(); }).then(function(d) {
      var newItems = (d.items || []).filter(function(n){ return n && n.isRead === false; });
      if (append) notifItems = notifItems.concat(newItems);
      else notifItems = newItems;
      notifHasMore = !!d.hasMore;
      notifNextBefore = d.nextBefore || null;
      notifUnreadCount = d.unreadCount != null ? Number(d.unreadCount) : notifUnreadCount;
      if (append) notifLoadingMore = false;
      renderNotifications();
    }).catch(function() {
      if (!append) notifItems = [];
      if (append) notifLoadingMore = false;
      renderNotifications();
    });
  }

  function markAllNotifsRead() {
    if (!notifUnreadCount) return;
    fetch('/api/NotificationsApi/read-all', { method: 'POST' }).then(function() {
      notifUnreadCount = 0;
      notifItems = notifItems.map(function(n) { return Object.assign({}, n, { isRead: true }); });
      renderNotifications();
      try { window.dispatchEvent(new CustomEvent('qms:notificationsRead')); window.dispatchEvent(new CustomEvent('qms:unreadCount', { detail: { count: 0 } })); } catch(e) {}
    });
  }

  function setNotifConnectionState(state) {
    var el = document.getElementById('notif-connection-state');
    if (!el) return;
    if (state === 'reconnecting' || state === 'failed' || state === 'disconnected') el.classList.remove('hidden');
    else el.classList.add('hidden');
  }

  // Listen for real-time notification events
  window.addEventListener('qms:notification', function(e) {
    var payload = (e && e.detail) ? e.detail : null;
    if (payload && payload.id) {
      mergeIncomingNotification({
        id: payload.id,
        title: payload.title || payload.Title || 'Notification',
        message: payload.message || payload.Message || '',
        relatedEntityId: payload.relatedEntityId || payload.RelatedEntityId || null,
        relatedEntityType: payload.relatedEntityType || payload.RelatedEntityType || '',
        isRead: false,
        createdAt: new Date().toISOString()
      });
      notifUnreadCount = Math.max(0, notifUnreadCount + 1);
      renderNotifications();
    } else {
      fetchNotifications();
    }
    if (window.qmsRefreshBadges) window.qmsRefreshBadges();
  });
  window.addEventListener('qms:unreadCount', function(e) {
    notifUnreadCount = e && e.detail ? Number(e.detail.count || 0) : 0;
    var dot = document.getElementById('notification-dot');
    if (dot) { notifUnreadCount > 0 ? dot.classList.remove('hidden') : dot.classList.add('hidden'); }
  });
  window.addEventListener('qms:notificationsRead', function() {
    notifUnreadCount = 0;
    var dot = document.getElementById('notification-dot');
    if (dot) dot.classList.add('hidden');
  });
  window.addEventListener('qms:connectionState', function(e) {
    var state = e && e.detail ? e.detail.state : 'disconnected';
    setNotifConnectionState(state);
  });

  document.addEventListener('DOMContentLoaded', function() {
    var loadMoreBtn = document.getElementById('notif-load-more-btn');
    if (loadMoreBtn) {
      loadMoreBtn.addEventListener('click', function() {
        if (!notifHasMore || notifLoadingMore) return;
        notifLoadingMore = true;
        renderNotifications();
        fetchNotifications(notifNextBefore, true);
      });
    }
    var markAllBtn = document.getElementById('notif-mark-all-btn');
    if (markAllBtn) markAllBtn.addEventListener('click', markAllNotifsRead);
  });
})();
</script>
<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<script src="~/js/site.js"></script>
<script src="~/js/animations.js"></script>
<script src="~/js/signalr-notifications.js"></script>
<script src="~/js/notifications-badges.js"></script>
@if (User?.Identity?.IsAuthenticated == true)
{
    <script src="~/js/onboarding-tour.js"></script>
}
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
