@page "{id:guid}"
@model KasahQMS.Web.Pages.Templates.EditModel
@{
    ViewData["Title"] = "Edit Template";
}

<div class="max-w-4xl mx-auto space-y-6">
    <div class="flex items-center justify-between">
        <div>
            <a href="/Templates" class="inline-flex items-center gap-2 text-sm text-slate-600 hover:text-brand-600 mb-4">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
                </svg>
                Back to Templates
            </a>
            <h1 class="text-2xl font-semibold text-slate-900">Edit Template</h1>
            <p class="text-sm text-slate-500">Update the document template details</p>
        </div>
    </div>

    <form method="post" class="bg-white rounded-2xl shadow-lg border border-slate-200/50 p-8 space-y-6">
        <input type="hidden" asp-for="Id" />
        @Html.AntiForgeryToken()

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="md:col-span-2">
                <label asp-for="Title" class="block text-sm font-medium text-slate-700 mb-2">Template Title *</label>
                <input asp-for="Title" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-brand-500 focus:border-brand-500" placeholder="Enter template title" required />
                <span asp-validation-for="Title" class="text-red-500 text-sm"></span>
            </div>

            <div>
                <label asp-for="DocumentTypeId" class="block text-sm font-medium text-slate-700 mb-2">Document Type</label>
                <select asp-for="DocumentTypeId" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-brand-500 focus:border-brand-500">
                    <option value="">-- Select Type --</option>
                    @foreach (var dt in Model.DocumentTypes)
                    {
                        <option value="@dt.Id">@dt.Name</option>
                    }
                </select>
            </div>

            <div>
                <label asp-for="CategoryId" class="block text-sm font-medium text-slate-700 mb-2">Category</label>
                <select asp-for="CategoryId" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-brand-500 focus:border-brand-500">
                    <option value="">-- Select Category --</option>
                    @foreach (var cat in Model.Categories)
                    {
                        <option value="@cat.Id">@cat.Name</option>
                    }
                </select>
            </div>

            <div class="md:col-span-2">
                <label asp-for="Description" class="block text-sm font-medium text-slate-700 mb-2">Description</label>
                <textarea asp-for="Description" rows="3" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-brand-500 focus:border-brand-500" placeholder="Brief description of the template"></textarea>
            </div>

            <div class="md:col-span-2">
                <label class="block text-sm font-medium text-slate-700 mb-2">Authorized Departments</label>
                <p class="text-xs text-slate-500 mb-3">Select departments that can use this template. Leave empty for all departments.</p>
                <div class="grid grid-cols-2 md:grid-cols-3 gap-2 max-h-48 overflow-y-auto p-4 border border-slate-200 rounded-xl bg-slate-50">
                    @foreach (var dept in Model.Departments)
                    {
                        <label class="flex items-center gap-2 cursor-pointer p-2 hover:bg-white rounded-lg">
                            <input type="checkbox" name="AuthorizedDepartmentIds" value="@dept.Id" 
                                   @(Model.AuthorizedDepartmentIds.Contains(dept.Id) ? "checked" : "")
                                   class="w-4 h-4 text-brand-600 border-slate-300 rounded focus:ring-brand-500" />
                            <span class="text-sm text-slate-700">@dept.Name</span>
                        </label>
                    }
                </div>
            </div>

            <div class="md:col-span-2">
                <label asp-for="TemplateContent" class="block text-sm font-medium text-slate-700 mb-2">Template Content</label>
                <textarea asp-for="TemplateContent" rows="12" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-brand-500 focus:border-brand-500 font-mono text-sm" placeholder="Enter the template content here..."></textarea>
            </div>
        </div>

        <div class="flex items-center justify-between pt-6 border-t border-slate-200">
            <button type="submit" asp-page-handler="Delete" class="px-4 py-2 border border-red-200 text-red-600 rounded-xl hover:bg-red-50 transition-colors font-medium" onclick="return confirm('Are you sure you want to delete this template?');">
                Delete Template
            </button>
            <div class="flex gap-4">
                <a href="/Templates" class="px-6 py-3 border border-slate-200 text-slate-700 rounded-xl hover:bg-slate-50 transition-colors font-medium">
                    Cancel
                </a>
                <button type="submit" class="px-6 py-3 bg-gradient-to-r from-brand-600 to-brand-700 text-white rounded-xl hover:shadow-lg transition-all font-medium">
                    Save Changes
                </button>
            </div>
        </div>
    </form>
</div>
