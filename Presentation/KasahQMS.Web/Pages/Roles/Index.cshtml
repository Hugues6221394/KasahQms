@page
@using System.Linq
@model KasahQMS.Web.Pages.Roles.IndexModel
@{
    ViewData["Title"] = "Roles";
    var totalRoles = Model.Roles.Count();
    var totalPolicies = Model.Roles.Sum(r => r.Policies.Count());
    var totalPermissions = Model.Roles.Sum(r => r.Permissions.Count());
}

<div class="space-y-6">
    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
            <div>
                <p class="text-xs uppercase tracking-[0.2em] text-brand-600">Access Control</p>
                <h1 class="mt-2 text-3xl font-semibold text-slate-900">Roles &amp; permissions</h1>
                <p class="mt-2 text-sm text-slate-500">Define least-privilege access and policy constraints for every actor.</p>
            </div>
            <a href="/Roles/Create" class="rounded-lg bg-brand-600 px-4 py-2 text-sm font-semibold text-white hover:bg-brand-700">Create role</a>
        </div>
    </div>

    <div class="grid gap-4 sm:grid-cols-3">
        <div class="card p-5">
            <p class="text-xs uppercase tracking-wide text-slate-500">Total roles</p>
            <p class="mt-2 text-2xl font-semibold text-slate-900">@totalRoles</p>
        </div>
        <div class="card p-5">
            <p class="text-xs uppercase tracking-wide text-slate-500">Permissions mapped</p>
            <p class="mt-2 text-2xl font-semibold text-brand-600">@totalPermissions</p>
        </div>
        <div class="card p-5">
            <p class="text-xs uppercase tracking-wide text-slate-500">Policy rules</p>
            <p class="mt-2 text-2xl font-semibold text-indigo-600">@totalPolicies</p>
        </div>
    </div>

    <div class="grid gap-5 lg:grid-cols-2">
        @foreach (var role in Model.Roles)
        {
            <div class="card p-6">
                <div class="flex items-center justify-between gap-3">
                    <div>
                        <h2 class="text-lg font-semibold text-slate-900">@role.Name</h2>
                        <p class="text-xs text-slate-500">@role.Description</p>
                    </div>
                    <a href="/Roles/Edit?id=@role.Id" class="rounded-lg border border-slate-200 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 hover:border-brand-300">Edit</a>
                </div>

                <div class="mt-4">
                    <div class="mb-2 text-xs uppercase tracking-wide text-slate-400">Permissions</div>
                    <div class="flex flex-wrap gap-2">
                        @foreach (var perm in role.Permissions)
                        {
                            <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-600">@perm</span>
                        }
                    </div>
                </div>

                <div class="mt-5 border-t border-slate-100 pt-4">
                    <div class="mb-2 text-xs uppercase tracking-wide text-slate-400">Policy constraints (PBAC)</div>
                    @if (role.Policies.Any())
                    {
                        <div class="space-y-2">
                            @foreach (var policy in role.Policies)
                            {
                                <div class="rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-xs text-slate-600">
                                    <span class="font-semibold text-slate-700">@policy.Name</span> - @policy.Rule
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="rounded-lg border border-dashed border-slate-200 bg-slate-50 px-3 py-2 text-xs text-slate-500">
                            No policy constraints assigned.
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>
