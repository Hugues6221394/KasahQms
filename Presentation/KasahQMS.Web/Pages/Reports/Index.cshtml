@page
@model KasahQMS.Web.Pages.Reports.IndexModel
@{
    ViewData["Title"] = "Reports";
}

<div class="space-y-8" x-data="{ category: '@(Model.Category ?? "")', reportType: '@(Model.ReportType ?? "")' }">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
        <div>
            <h1 class="text-2xl font-semibold text-slate-900">Report Center</h1>
            <p class="text-sm text-slate-500">Generate, preview and export reports across all QMS modules.</p>
        </div>
    </div>

    <!-- Filters -->
    <form method="get" class="card p-6">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-end">
            <div class="flex-1">
                <label class="text-sm font-medium text-slate-600">Category</label>
                <select name="category" x-model="category"
                        class="mt-2 w-full rounded-lg border border-slate-200 px-3 py-2 text-sm"
                        @@change="reportType = ''">
                    <option value="">Select category…</option>
                    @foreach (var cat in Model.Categories)
                    {
                        <option value="@cat.Id" selected="@(Model.Category == cat.Id)">@cat.Label</option>
                    }
                </select>
            </div>
            <div class="flex-1">
                <label class="text-sm font-medium text-slate-600">Report Type</label>
                <select name="reportType" x-model="reportType" class="mt-2 w-full rounded-lg border border-slate-200 px-3 py-2 text-sm">
                    <option value="">Select report…</option>
                    @foreach (var cat in Model.Categories)
                    {
                        foreach (var rt in cat.Types)
                        {
                            <option value="@rt.Id" x-show="category === '@cat.Id'" selected="@(Model.ReportType == rt.Id)">@rt.Label</option>
                        }
                    }
                </select>
            </div>
            <div>
                <label class="text-sm font-medium text-slate-600">Period</label>
                <select name="days" class="mt-2 w-40 rounded-lg border border-slate-200 px-3 py-2 text-sm">
                    <option value="30" selected="@(Model.Days == 30)">Last 30 days</option>
                    <option value="60" selected="@(Model.Days == 60)">Last 60 days</option>
                    <option value="90" selected="@(Model.Days == 90)">Last 90 days</option>
                    <option value="365" selected="@(Model.Days == 365)">Last year</option>
                </select>
            </div>
            <button type="submit" class="rounded-lg bg-brand-600 px-5 py-2 text-sm font-semibold text-white hover:bg-brand-700">
                Preview
            </button>
        </div>
    </form>

    <!-- Export Buttons -->
    @if (Model.PreviewRows.Count > 0)
    {
        <div class="flex items-center justify-between">
            <p class="text-sm text-slate-500">@Model.PreviewRows.Count row(s) found</p>
            <div class="flex gap-2">
                <form method="post" asp-page-handler="Export" class="inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="category" value="@Model.Category" />
                    <input type="hidden" name="reportType" value="@Model.ReportType" />
                    <input type="hidden" name="days" value="@Model.Days" />
                    <input type="hidden" name="format" value="pdf" />
                    <button type="submit" class="inline-flex items-center gap-1 rounded-lg border border-slate-200 px-3 py-2 text-xs font-semibold text-slate-600 hover:bg-slate-50">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                        PDF
                    </button>
                </form>
                <form method="post" asp-page-handler="Export" class="inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="category" value="@Model.Category" />
                    <input type="hidden" name="reportType" value="@Model.ReportType" />
                    <input type="hidden" name="days" value="@Model.Days" />
                    <input type="hidden" name="format" value="excel" />
                    <button type="submit" class="inline-flex items-center gap-1 rounded-lg border border-slate-200 px-3 py-2 text-xs font-semibold text-slate-600 hover:bg-slate-50">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                        Excel
                    </button>
                </form>
                <form method="post" asp-page-handler="Export" class="inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="category" value="@Model.Category" />
                    <input type="hidden" name="reportType" value="@Model.ReportType" />
                    <input type="hidden" name="days" value="@Model.Days" />
                    <input type="hidden" name="format" value="csv" />
                    <button type="submit" class="inline-flex items-center gap-1 rounded-lg border border-slate-200 px-3 py-2 text-xs font-semibold text-slate-600 hover:bg-slate-50">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                        CSV
                    </button>
                </form>
            </div>
        </div>

        <!-- Preview Table -->
        <div class="card p-6">
            <div class="overflow-x-auto rounded-lg border border-slate-200">
                <table class="min-w-full divide-y divide-slate-200 text-sm">
                    <thead class="bg-slate-50 text-slate-500 uppercase text-xs">
                        <tr>
                            @foreach (var col in Model.PreviewColumns)
                            {
                                <th class="px-4 py-3 text-left font-semibold whitespace-nowrap">@col</th>
                            }
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100 bg-white">
                        @foreach (var row in Model.PreviewRows)
                        {
                            <tr>
                                @foreach (var col in Model.PreviewColumns)
                                {
                                    <td class="px-4 py-3 text-slate-600 whitespace-nowrap">@(row.ContainsKey(col) ? row[col]?.ToString() : "—")</td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else if (!string.IsNullOrEmpty(Model.Category) && !string.IsNullOrEmpty(Model.ReportType))
    {
        <div class="card p-12 text-center">
            <div class="w-16 h-16 mx-auto mb-4 rounded-2xl bg-slate-50 flex items-center justify-center">
                <svg class="w-8 h-8 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
            </div>
            <h3 class="text-lg font-medium text-slate-900">No data found</h3>
            <p class="text-slate-500 mt-1">Try adjusting the date range or report filters.</p>
        </div>
    }
    else
    {
        <!-- Category cards -->
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
            @foreach (var cat in Model.Categories)
            {
                <a href="?category=@cat.Id&reportType=@cat.Types.First().Id&days=@Model.Days"
                   class="card p-5 hover:border-brand-300 hover:shadow-md transition-all group">
                    <h3 class="text-base font-semibold text-slate-900 group-hover:text-brand-700">@cat.Label</h3>
                    <p class="text-xs text-slate-500 mt-1">@cat.Types.Length report(s)</p>
                    <ul class="mt-3 space-y-1">
                        @foreach (var rt in cat.Types)
                        {
                            <li class="text-xs text-slate-400">• @rt.Label</li>
                        }
                    </ul>
                </a>
            }
        </div>
    }
</div>
