@page
@model KasahQMS.Web.Pages.News.CreateModel
@{
    ViewData["Title"] = "Post News";
}

<div class="max-w-4xl mx-auto space-y-6">
    <div>
        <h1 class="text-2xl font-semibold text-slate-900">Post News Article</h1>
        <p class="text-sm text-slate-500">Broadcast an announcement, alert, or message to all employees.</p>
    </div>

    <form method="post" class="card p-6 space-y-6">
        @Html.AntiForgeryToken()
        
        <div asp-validation-summary="All" class="text-sm text-red-600"></div>

        <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5">Title <span class="text-red-600">*</span></label>
            <input type="text" asp-for="Title" required
                   class="w-full rounded-lg border border-slate-300 px-4 py-2.5 focus:border-brand-500 focus:ring-2 focus:ring-brand-100 outline-none"
                   placeholder="Enter news title" />
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1.5">Type</label>
                <select asp-for="Type" class="w-full rounded-lg border border-slate-300 px-4 py-2.5 focus:border-brand-500 focus:ring-2 focus:ring-brand-100">
                    <option value="Message">Message</option>
                    <option value="Notice">Notice</option>
                    <option value="Announcement">Announcement</option>
                    <option value="Alert">Alert</option>
                    <option value="Emergency">Emergency</option>
                </select>
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1.5">Priority</label>
                <select asp-for="Priority" class="w-full rounded-lg border border-slate-300 px-4 py-2.5 focus:border-brand-500 focus:ring-2 focus:ring-brand-100">
                    <option value="Low">Low</option>
                    <option value="Medium">Medium</option>
                    <option value="High">High</option>
                    <option value="Critical">Critical</option>
                </select>
            </div>
        </div>

        <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5">Content <span class="text-red-600">*</span></label>
            <textarea asp-for="ArticleContent" rows="10" required
                      class="w-full rounded-lg border border-slate-300 px-4 py-2.5 focus:border-brand-500 focus:ring-2 focus:ring-brand-100 outline-none font-mono text-sm"
                      placeholder="Write your news content here..."></textarea>
            <p class="text-xs text-slate-500 mt-1">Supports plain text. All active users will be notified via email.</p>
        </div>

        <div class="flex items-center justify-between pt-4 border-t border-slate-200">
            <a href="/News" class="text-sm text-slate-600 hover:text-slate-900">Cancel</a>
            <button type="submit" class="px-6 py-2.5 bg-brand-600 text-white rounded-lg font-semibold hover:bg-brand-700 transition-colors">
                Publish & Notify All Users
            </button>
        </div>
    </form>

    <div class="bg-amber-50 border border-amber-200 rounded-xl p-4">
        <div class="flex gap-3">
            <svg class="w-5 h-5 text-amber-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <div class="text-sm text-amber-900">
                <p class="font-semibold mb-1">Email Notification</p>
                <p>When you publish this article, <strong>all active users</strong> in your organization will receive an email notification immediately.</p>
            </div>
        </div>
    </div>
</div>
