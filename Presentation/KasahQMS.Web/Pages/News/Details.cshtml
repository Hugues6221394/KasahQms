@page
@model KasahQMS.Web.Pages.News.DetailsModel
@{
    ViewData["Title"] = Model.Article?.Title ?? "News Article";
    var a = Model.Article;
}

@if (a != null)
{
    <div class="max-w-4xl mx-auto space-y-6">
        <div class="flex items-center gap-4">
            <a href="/News" class="text-slate-600 hover:text-slate-900">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                </svg>
            </a>
            <h1 class="text-sm text-slate-500">Back to News</h1>
        </div>

        <div class="card p-8 space-y-6">
            <div>
                <div class="flex flex-wrap items-center gap-2 mb-4">
                    <span class="px-3 py-1 rounded-lg text-sm font-medium @a.TypeClass">
                        @a.Type
                    </span>
                    <span class="px-3 py-1 rounded-lg text-sm font-medium @a.PriorityClass">
                        @a.Priority Priority
                    </span>
                </div>
                
                <h1 class="text-3xl font-bold text-slate-900 mb-4">@a.Title</h1>
                
                <div class="flex items-center gap-4 text-sm text-slate-600 pb-6 border-b border-slate-200">
                    <div class="flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                        </svg>
                        <span>Published by <strong>@a.PublishedBy</strong></span>
                    </div>
                    <span>•</span>
                    <div class="flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                        <span>@a.PublishedAt</span>
                    </div>
                </div>
            </div>

            <div class="prose max-w-none">
                <div class="text-slate-700 leading-relaxed whitespace-pre-wrap">@a.Content</div>
            </div>
        </div>

        <div class="flex justify-center">
            <a href="/News" class="inline-flex items-center gap-2 px-6 py-2.5 border border-slate-300 bg-white text-slate-700 rounded-lg hover:bg-slate-50 transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                </svg>
                Back to All News
            </a>
        </div>
    </div>
}
