@page
@model KasahQMS.Web.Pages.Support.IndexModel
@{
    ViewData["Title"] = "Support";
}

<div class="space-y-6">
    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <h1 class="text-3xl font-semibold text-slate-900">Support center</h1>
        <p class="mt-2 text-sm text-slate-500">Get enterprise assistance for access, policy, and quality workflow issues.</p>
    </div>

    <div class="grid gap-4 md:grid-cols-3">
        <div class="card p-5"><p class="text-xs uppercase tracking-wide text-slate-500">SLA response</p><p class="mt-2 text-2xl font-semibold text-emerald-600">&lt; 4 hrs</p></div>
        <div class="card p-5"><p class="text-xs uppercase tracking-wide text-slate-500">Coverage</p><p class="mt-2 text-2xl font-semibold text-slate-900">24/7</p></div>
        <div class="card p-5"><p class="text-xs uppercase tracking-wide text-slate-500">Escalation</p><p class="mt-2 text-2xl font-semibold text-brand-600">Tier 1-3</p></div>
    </div>

    <div class="grid gap-6 md:grid-cols-2">
        <div class="card p-6">
            <h2 class="text-lg font-semibold text-slate-900">Help desk</h2>
            <p class="mt-3 text-sm text-slate-600">Email: <a href="mailto:support@kasah.com" class="font-medium text-brand-600 hover:text-brand-700">support@kasah.com</a></p>
            <p class="mt-1 text-sm text-slate-600">Phone: +250 788 000 000</p>
            <button class="mt-4 rounded-lg bg-brand-600 px-4 py-2 text-sm font-semibold text-white hover:bg-brand-700">Open ticket</button>
        </div>
        <div class="card p-6">
            <h2 class="text-lg font-semibold text-slate-900">Knowledge base</h2>
            <p class="mt-2 text-sm text-slate-600">Find SOPs, tutorials, and policy guidelines for every module.</p>
            <div class="mt-4 rounded-lg border border-dashed border-slate-200 bg-slate-50 p-4 text-sm text-slate-500">Browse standardized runbooks, onboarding packs, and troubleshooting articles.</div>
        </div>
    </div>
</div>
