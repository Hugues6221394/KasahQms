@page "{id:guid}"
@model KasahQMS.Web.Pages.Policies.EditModel
@{
    ViewData["Title"] = "Edit Policy";
}

<div class="space-y-6">
    <div>
        <a href="/Policies" class="inline-flex items-center gap-2 text-sm text-slate-600 hover:text-brand-600 mb-4">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
            </svg>
            Back to Policies
        </a>
        <h1 class="text-2xl font-semibold text-slate-900">Edit access policy</h1>
        <p class="text-sm text-slate-500">Update PBAC rules aligned with organizational hierarchy.</p>
    </div>

    <form method="post" class="card p-6 space-y-6">
        <input type="hidden" asp-for="Id" />
        @Html.AntiForgeryToken()

        <div class="grid gap-4 md:grid-cols-2">
            <div>
                <label class="form-label">Policy name</label>
                <input class="form-input" asp-for="Name" />
            </div>
            <div>
                <label class="form-label">Role</label>
                <select class="form-input form-select" asp-for="RoleId">
                    <option value="">All roles</option>
                    @foreach (var role in Model.Roles)
                    {
                        <option value="@role.Id">@role.Name</option>
                    }
                </select>
            </div>
            <div>
                <label class="form-label">Scope</label>
                <input class="form-input" asp-for="Scope" placeholder="e.g., Document, Workflow" />
            </div>
            <div>
                <label class="form-label">Attribute</label>
                <input class="form-input" asp-for="Attribute" placeholder="e.g., User.OrganizationUnitId" />
            </div>
            <div>
                <label class="form-label">Operator</label>
                <select class="form-input form-select" asp-for="Operator">
                    <option value="Equals">Equals</option>
                    <option value="In">In</option>
                    <option value="Contains">Contains</option>
                </select>
            </div>
            <div>
                <label class="form-label">Value</label>
                <input class="form-input" asp-for="Value" placeholder="e.g., AssignedUnit" />
            </div>
            <div class="md:col-span-2">
                <label class="form-label">Description</label>
                <input class="form-input" asp-for="Description" />
            </div>
        </div>

        <div class="flex items-center gap-3">
            <button type="submit" class="btn btn-primary">Save changes</button>
            <a href="/Policies" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>
