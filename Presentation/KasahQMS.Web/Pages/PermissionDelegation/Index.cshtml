@page
@model KasahQMS.Web.Pages.PermissionDelegation.IndexModel
@{
    ViewData["Title"] = "Permission Delegation";
}

<div class="space-y-8 animate-fade-in">
    <div class="rounded-2xl border border-slate-200 bg-white p-6">
        <h1 class="text-3xl font-semibold tracking-tight text-slate-900">Permission Delegation</h1>
        <p class="mt-1 text-sm text-slate-500">Delegate permissions to your subordinates or view received delegations.</p>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="card border-red-200 bg-red-50 p-4">
            <div class="flex items-center gap-3">
                <svg class="h-5 w-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <p class="text-sm font-medium text-red-800">@Model.ErrorMessage</p>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="card border-green-200 bg-green-50 p-4">
            <div class="flex items-center gap-3">
                <svg class="h-5 w-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <p class="text-sm font-medium text-green-800">@Model.SuccessMessage</p>
            </div>
        </div>
    }

    @if (Model.Subordinates.Any() && Model.AvailablePermissions.Any())
    {
        <div class="card p-6">
            <h2 class="mb-6 text-lg font-semibold text-slate-900">Delegate Permission</h2>
            <form method="post" asp-page-handler="Delegate">
                <div class="grid gap-6 md:grid-cols-3">
                    <div>
                        <label class="mb-2 block text-sm font-medium text-slate-700">Subordinate</label>
                        <select asp-for="SelectedSubordinateId" class="w-full rounded-xl border border-slate-300 px-4 py-2.5 focus:border-brand-500 focus:ring-2 focus:ring-brand-500">
                            <option value="">Select a subordinate...</option>
                            @foreach (var subordinate in Model.Subordinates)
                            {
                                <option value="@subordinate.Id">@subordinate.Name (@subordinate.Email)</option>
                            }
                        </select>
                        <span asp-validation-for="SelectedSubordinateId" class="text-xs text-red-600"></span>
                    </div>

                    <div>
                        <label class="mb-2 block text-sm font-medium text-slate-700">Permission</label>
                        <select asp-for="SelectedPermission" class="w-full rounded-xl border border-slate-300 px-4 py-2.5 focus:border-brand-500 focus:ring-2 focus:ring-brand-500">
                            <option value="">Select a permission...</option>
                            @foreach (var permission in Model.AvailablePermissions)
                            {
                                <option value="@permission.Value">@permission.Label</option>
                            }
                        </select>
                        <span asp-validation-for="SelectedPermission" class="text-xs text-red-600"></span>
                    </div>

                    <div>
                        <label class="mb-2 block text-sm font-medium text-slate-700">Expires After (Days)</label>
                        <input asp-for="ExpiresAfterDays" type="number" min="1" class="w-full rounded-xl border border-slate-300 px-4 py-2.5 focus:border-brand-500 focus:ring-2 focus:ring-brand-500" placeholder="Optional" />
                        <p class="mt-1 text-xs text-slate-500">Leave empty for no expiration</p>
                    </div>
                </div>

                <div class="mt-6">
                    <button type="submit" class="inline-flex items-center gap-2 rounded-xl bg-brand-600 px-6 py-3 font-semibold text-white transition-all hover:bg-brand-700">
                        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        Delegate Permission
                    </button>
                </div>
            </form>
        </div>
    }
    else if (!Model.Subordinates.Any())
    {
        <div class="card p-6">
            <div class="py-8 text-center">
                <div class="mx-auto mb-3 flex h-12 w-12 items-center justify-center rounded-xl bg-slate-100">
                    <svg class="h-6 w-6 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
                </div>
                <p class="text-sm font-medium text-slate-600">No subordinates found</p>
                <p class="mt-1 text-xs text-slate-400">You need to have subordinates to delegate permissions</p>
            </div>
        </div>
    }

    @if (Model.MyDelegations.Any())
    {
        <div class="card p-6">
            <h2 class="mb-6 text-lg font-semibold text-slate-900">My Delegations</h2>
            <div class="overflow-x-auto rounded-xl border border-slate-200">
                <table class="w-full text-sm">
                    <thead class="bg-slate-50 text-xs uppercase text-slate-500"><tr><th class="px-4 py-3 text-left font-semibold">Subordinate</th><th class="px-4 py-3 text-left font-semibold">Permission</th><th class="px-4 py-3 text-left font-semibold">Delegated At</th><th class="px-4 py-3 text-left font-semibold">Expires At</th><th class="px-4 py-3 text-left font-semibold">Status</th><th class="px-4 py-3 text-right font-semibold">Actions</th></tr></thead>
                    <tbody class="divide-y divide-slate-100 bg-white">
                        @foreach (var delegation in Model.MyDelegations)
                        {
                            <tr class="hover:bg-slate-50 transition-colors">
                                <td class="px-4 py-3 text-slate-800">@delegation.SubordinateName</td>
                                <td class="px-4 py-3 text-slate-600">@delegation.Permission</td>
                                <td class="px-4 py-3 text-slate-600">@delegation.DelegatedAt.ToString("MMM dd, yyyy")</td>
                                <td class="px-4 py-3 text-slate-600">@if (delegation.ExpiresAt.HasValue){@delegation.ExpiresAt.Value.ToString("MMM dd, yyyy")}else{<span class="text-slate-400">No expiration</span>}</td>
                                <td class="px-4 py-3">@if (delegation.IsExpired){<span class="inline-flex rounded-full bg-red-100 px-2.5 py-1 text-xs font-medium text-red-700">Expired</span>}else if (delegation.IsActive){<span class="inline-flex rounded-full bg-green-100 px-2.5 py-1 text-xs font-medium text-green-700">Active</span>}else{<span class="inline-flex rounded-full bg-slate-100 px-2.5 py-1 text-xs font-medium text-slate-700">Inactive</span>}</td>
                                <td class="px-4 py-3 text-right">@if (delegation.IsActive && !delegation.IsExpired){<form method="post" asp-page-handler="Revoke" asp-route-delegationId="@delegation.Id" class="inline"><button type="submit" class="text-sm font-medium text-red-600 transition-colors hover:text-red-700" onclick="return confirm('Are you sure you want to revoke this delegation?');">Revoke</button></form>}</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    @if (Model.ReceivedDelegations.Any())
    {
        <div class="card p-6">
            <h2 class="mb-6 text-lg font-semibold text-slate-900">Received Delegations</h2>
            <div class="overflow-x-auto rounded-xl border border-slate-200">
                <table class="w-full text-sm">
                    <thead class="bg-slate-50 text-xs uppercase text-slate-500"><tr><th class="px-4 py-3 text-left font-semibold">Delegated By</th><th class="px-4 py-3 text-left font-semibold">Permission</th><th class="px-4 py-3 text-left font-semibold">Delegated At</th><th class="px-4 py-3 text-left font-semibold">Expires At</th><th class="px-4 py-3 text-left font-semibold">Status</th></tr></thead>
                    <tbody class="divide-y divide-slate-100 bg-white">
                        @foreach (var delegation in Model.ReceivedDelegations)
                        {
                            <tr class="hover:bg-slate-50 transition-colors">
                                <td class="px-4 py-3 text-slate-800">@delegation.SubordinateName</td>
                                <td class="px-4 py-3 text-slate-600">@delegation.Permission</td>
                                <td class="px-4 py-3 text-slate-600">@delegation.DelegatedAt.ToString("MMM dd, yyyy")</td>
                                <td class="px-4 py-3 text-slate-600">@if (delegation.ExpiresAt.HasValue){@delegation.ExpiresAt.Value.ToString("MMM dd, yyyy")}else{<span class="text-slate-400">No expiration</span>}</td>
                                <td class="px-4 py-3">@if (delegation.IsExpired){<span class="inline-flex rounded-full bg-red-100 px-2.5 py-1 text-xs font-medium text-red-700">Expired</span>}else if (delegation.IsActive){<span class="inline-flex rounded-full bg-green-100 px-2.5 py-1 text-xs font-medium text-green-700">Active</span>}else{<span class="inline-flex rounded-full bg-slate-100 px-2.5 py-1 text-xs font-medium text-slate-700">Inactive</span>}</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else if (!Model.ReceivedDelegations.Any() && !Model.MyDelegations.Any())
    {
        <div class="card p-6">
            <div class="py-8 text-center">
                <div class="mx-auto mb-3 flex h-12 w-12 items-center justify-center rounded-xl bg-slate-100">
                    <svg class="h-6 w-6 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                </div>
                <p class="text-sm font-medium text-slate-600">No delegations</p>
                <p class="mt-1 text-xs text-slate-400">You haven't delegated or received any permissions yet</p>
            </div>
        </div>
    }
</div>
