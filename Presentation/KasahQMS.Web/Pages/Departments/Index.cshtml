@page
@using System.Linq
@model KasahQMS.Web.Pages.Departments.IndexModel
@{
    ViewData["Title"] = "Departments";
    var totalDepartments = Model.Departments.Count();
    var activeDepartments = Model.Departments.Count(d => string.Equals(d.Status, "Active", System.StringComparison.OrdinalIgnoreCase));
}

<div class="space-y-6">
    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
            <div>
                <p class="text-xs uppercase tracking-[0.2em] text-brand-600">Organization</p>
                <h1 class="mt-2 text-3xl font-semibold text-slate-900">Departments &amp; org units</h1>
                <p class="mt-2 text-sm text-slate-500">Maintain organizational structure, managers, and reporting lines.</p>
            </div>
            @if (Model.CanManageDepartments)
            {
                <a href="/Departments/Create" class="rounded-lg bg-brand-600 px-4 py-2 text-sm font-semibold text-white hover:bg-brand-700">Add department</a>
            }
        </div>
    </div>

    @if (TempData["Success"] is string successMessage)
    {
        <div class="rounded-lg border border-emerald-200 bg-emerald-50 p-4 text-sm text-emerald-800">@successMessage</div>
    }
    @if (TempData["Error"] is string errorMessage)
    {
        <div class="rounded-lg border border-rose-200 bg-rose-50 p-4 text-sm text-rose-700">@errorMessage</div>
    }

    <div class="grid gap-4 sm:grid-cols-2">
        <div class="card p-5"><p class="text-xs uppercase tracking-wide text-slate-500">Total departments</p><p class="mt-2 text-2xl font-semibold text-slate-900">@totalDepartments</p></div>
        <div class="card p-5"><p class="text-xs uppercase tracking-wide text-slate-500">Active departments</p><p class="mt-2 text-2xl font-semibold text-emerald-600">@activeDepartments</p></div>
    </div>

    <div class="card p-6">
        <div class="overflow-hidden rounded-xl border border-slate-200">
            <table class="min-w-full divide-y divide-slate-200 text-sm">
                <thead class="bg-slate-50 text-xs uppercase text-slate-500">
                    <tr>
                        <th class="px-4 py-3 text-left font-semibold">Department</th>
                        <th class="px-4 py-3 text-left font-semibold">Code</th>
                        <th class="px-4 py-3 text-left font-semibold">Manager</th>
                        <th class="px-4 py-3 text-left font-semibold">Status</th>
                        @if (Model.CanManageDepartments)
                        {
                            <th class="px-4 py-3 text-right font-semibold">Actions</th>
                        }
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 bg-white">
                    @foreach (var dept in Model.Departments)
                    {
                        <tr class="hover:bg-slate-50/70">
                            <td class="px-4 py-3 font-semibold text-slate-800">@dept.Name</td>
                            <td class="px-4 py-3 text-slate-600">@dept.Code</td>
                            <td class="px-4 py-3 text-slate-600">@dept.Manager</td>
                            <td class="px-4 py-3"><span class="rounded-full px-3 py-1 text-xs font-semibold @(string.Equals(dept.Status, "Active", System.StringComparison.OrdinalIgnoreCase) ? "bg-emerald-50 text-emerald-700" : "bg-slate-100 text-slate-700")">@dept.Status</span></td>
                            @if (Model.CanManageDepartments)
                            {
                                <td class="px-4 py-3 text-right">
                                    <div class="inline-flex items-center gap-3">
                                        <a asp-page="/Departments/Edit" asp-route-id="@dept.Id" class="text-sm font-medium text-indigo-600 hover:text-indigo-700">Edit</a>
                                        @if (dept.IsActive)
                                        {
                                            <form method="post" asp-page-handler="Deactivate" asp-route-id="@dept.Id" class="inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="text-sm font-medium text-amber-600 hover:text-amber-700">Deactivate</button>
                                            </form>
                                        }
                                        else
                                        {
                                            <form method="post" asp-page-handler="Activate" asp-route-id="@dept.Id" class="inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="text-sm font-medium text-emerald-600 hover:text-emerald-700">Activate</button>
                                            </form>
                                        }
                                        <form method="post" asp-page-handler="Delete" asp-route-id="@dept.Id" class="inline" onsubmit="return confirm('Delete this department?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="text-sm font-medium text-rose-600 hover:text-rose-700">Delete</button>
                                        </form>
                                    </div>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
