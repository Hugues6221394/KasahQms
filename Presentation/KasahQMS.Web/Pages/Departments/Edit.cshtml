@page "{id:guid}"
@model KasahQMS.Web.Pages.Departments.EditModel
@{
    ViewData["Title"] = "Edit Department";
}

<div class="max-w-3xl space-y-6">
    <div>
        <h1 class="text-2xl font-semibold text-slate-900">Edit Department</h1>
        <p class="text-sm text-slate-500">Update department details and status.</p>
    </div>

    <form method="post" class="card p-6 space-y-5">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <div>
            <label asp-for="Name" class="block text-sm font-medium text-slate-700 mb-1"></label>
            <input asp-for="Name" class="w-full rounded-lg border border-slate-300 px-3 py-2.5" />
            <span asp-validation-for="Name" class="text-xs text-rose-600"></span>
        </div>
        <div>
            <label asp-for="Code" class="block text-sm font-medium text-slate-700 mb-1"></label>
            <input asp-for="Code" class="w-full rounded-lg border border-slate-300 px-3 py-2.5" />
            <span asp-validation-for="Code" class="text-xs text-rose-600"></span>
        </div>
        <div>
            <label asp-for="Description" class="block text-sm font-medium text-slate-700 mb-1"></label>
            <textarea asp-for="Description" rows="4" class="w-full rounded-lg border border-slate-300 px-3 py-2.5"></textarea>
            <span asp-validation-for="Description" class="text-xs text-rose-600"></span>
        </div>
        <div>
            <label asp-for="ParentId" class="block text-sm font-medium text-slate-700 mb-1">Parent Department</label>
            <select asp-for="ParentId" class="w-full rounded-lg border border-slate-300 px-3 py-2.5">
                <option value="">None</option>
                @foreach (var p in Model.ParentUnits)
                {
                    <option value="@p.Id">@p.Name (@p.Code)</option>
                }
            </select>
        </div>
        <div class="flex items-center gap-2">
            <input asp-for="IsActive" type="checkbox" class="h-4 w-4 rounded border-slate-300 text-brand-600 focus:ring-brand-500" />
            <label asp-for="IsActive" class="text-sm font-medium text-slate-700">Active</label>
        </div>
        <div class="flex justify-end gap-3 pt-2">
            <a href="/Departments" class="rounded-lg border border-slate-300 px-4 py-2.5 text-sm font-medium text-slate-700 hover:bg-slate-50">Cancel</a>
            <button type="submit" class="rounded-lg bg-brand-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-brand-700">Save Changes</button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
