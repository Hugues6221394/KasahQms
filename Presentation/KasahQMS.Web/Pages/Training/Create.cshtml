@page
@model KasahQMS.Web.Pages.Training.CreateModel
@{
    ViewData["Title"] = "New Training Record";
}

<div class="mx-auto max-w-2xl space-y-6">
    <nav class="flex items-center gap-2 text-sm text-slate-500">
        <a href="/Training" class="hover:text-slate-900">Training</a>
        <span>/</span>
        <span class="text-slate-700">New Record</span>
    </nav>

    <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
        <h1 class="text-xl font-bold text-slate-900 mb-6">Create Training Record</h1>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="mb-4 p-4 bg-red-50 border border-red-200 rounded-lg text-red-700 text-sm">
                @Model.ErrorMessage
            </div>
        }

        <form method="post" class="space-y-4">
            @Html.AntiForgeryToken()

            <div>
                <label for="title" class="block text-sm font-medium text-slate-700 mb-1">Title <span class="text-red-500">*</span></label>
                <input type="text" id="title" asp-for="Title" required
                    class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-brand-500 focus:border-brand-500"
                    placeholder="Training title">
            </div>

            <div>
                <label for="description" class="block text-sm font-medium text-slate-700 mb-1">Description</label>
                <textarea id="description" asp-for="Description" rows="3"
                    class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-brand-500 focus:border-brand-500"
                    placeholder="Optional description"></textarea>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label for="trainingType" class="block text-sm font-medium text-slate-700 mb-1">Type</label>
                    <select id="trainingType" asp-for="TrainingType"
                        class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-brand-500 focus:border-brand-500">
                        <option value="Initial">Initial</option>
                        <option value="Refresher">Refresher</option>
                        <option value="Certification">Certification</option>
                        <option value="OnTheJob">On-the-Job</option>
                    </select>
                </div>
                <div>
                    <label for="userId" class="block text-sm font-medium text-slate-700 mb-1">Employee <span class="text-red-500">*</span></label>
                    <select id="userId" asp-for="UserId"
                        class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-brand-500 focus:border-brand-500">
                        <option value="">— Select employee —</option>
                        @foreach (var u in Model.Users)
                        {
                            <option value="@u.Id">@u.Name</option>
                        }
                    </select>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label for="scheduledDate" class="block text-sm font-medium text-slate-700 mb-1">Scheduled Date</label>
                    <input type="date" id="scheduledDate" asp-for="ScheduledDate"
                        class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-brand-500 focus:border-brand-500">
                </div>
                <div>
                    <label for="trainerId" class="block text-sm font-medium text-slate-700 mb-1">Trainer</label>
                    <select id="trainerId" asp-for="TrainerId"
                        class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-brand-500 focus:border-brand-500">
                        <option value="">— None —</option>
                        @foreach (var u in Model.Users)
                        {
                            <option value="@u.Id">@u.Name</option>
                        }
                    </select>
                </div>
            </div>

            <div class="w-full md:w-1/2">
                <label for="passingScore" class="block text-sm font-medium text-slate-700 mb-1">Passing Score (%)</label>
                <input type="number" id="passingScore" asp-for="PassingScore" min="0" max="100"
                    class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-brand-500 focus:border-brand-500"
                    placeholder="e.g. 80">
            </div>

            <div class="flex gap-3 pt-4">
                <button type="submit" class="px-4 py-2 bg-brand-600 text-white font-medium rounded-lg hover:bg-brand-700">
                    Create record
                </button>
                <a href="/Training" class="px-4 py-2 border border-slate-300 text-slate-700 font-medium rounded-lg hover:bg-slate-50">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>
