@page
@model KasahQMS.Web.Pages.Training.IndexModel
@{
    ViewData["Title"] = "Training";
}

<div class="space-y-6">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
        <div>
            <h1 class="text-2xl font-semibold text-slate-900">Training & Competency</h1>
            <p class="text-sm text-slate-500">Manage training records and track employee development.</p>
        </div>
        <div class="flex items-center gap-3">
            <button onclick="localStorage.removeItem('kasah_onboarding_done'); location.reload();"
                    class="inline-flex items-center rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50">
                <svg class="w-4 h-4 mr-2 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                </svg>
                Restart System Tour
            </button>
            @if (Model.CanCreateTraining)
            {
                <a href="/Training/Create" class="inline-flex items-center rounded-lg bg-brand-600 px-4 py-2 text-sm font-semibold text-white hover:bg-brand-700">
                    New Training Record
                </a>
            }
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
        <div class="card p-4 flex items-center justify-between">
            <div>
                <div class="text-xs text-slate-500 uppercase">Total</div>
                <div class="text-2xl font-semibold text-slate-900">@Model.TotalCount</div>
            </div>
            <div class="w-10 h-10 rounded-lg bg-slate-100 text-slate-600 flex items-center justify-center">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
            </div>
        </div>
        <div class="card p-4 flex items-center justify-between">
            <div>
                <div class="text-xs text-slate-500 uppercase">Completed</div>
                <div class="text-2xl font-semibold text-slate-900">@Model.CompletedCount</div>
            </div>
            <div class="w-10 h-10 rounded-lg bg-emerald-100 text-emerald-700 flex items-center justify-center">✓</div>
        </div>
        <div class="card p-4 flex items-center justify-between">
            <div>
                <div class="text-xs text-slate-500 uppercase">In Progress</div>
                <div class="text-2xl font-semibold text-slate-900">@Model.InProgressCount</div>
            </div>
            <div class="w-10 h-10 rounded-lg bg-brand-100 text-brand-700 flex items-center justify-center">▶</div>
        </div>
        <div class="card p-4 flex items-center justify-between">
            <div>
                <div class="text-xs text-slate-500 uppercase">Expired</div>
                <div class="text-2xl font-semibold text-slate-900">@Model.ExpiredCount</div>
            </div>
            <div class="w-10 h-10 rounded-lg bg-rose-100 text-rose-700 flex items-center justify-center">!</div>
        </div>
    </div>

    <!-- Filters -->
    <div class="card p-4">
        <form method="get" class="flex flex-wrap gap-4 items-end">
            <div class="w-40">
                <label class="block text-sm font-medium text-slate-700 mb-1">Status</label>
                <select name="StatusFilter" asp-for="StatusFilter" class="w-full px-3 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-brand-200 focus:border-brand-400">
                    <option value="">All</option>
                    <option value="Scheduled">Scheduled</option>
                    <option value="InProgress">In Progress</option>
                    <option value="Completed">Completed</option>
                    <option value="Expired">Expired</option>
                </select>
            </div>
            <div class="w-40">
                <label class="block text-sm font-medium text-slate-700 mb-1">Type</label>
                <select name="TypeFilter" asp-for="TypeFilter" class="w-full px-3 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-brand-200 focus:border-brand-400">
                    <option value="">All</option>
                    <option value="Initial">Initial</option>
                    <option value="Refresher">Refresher</option>
                    <option value="Certification">Certification</option>
                    <option value="OnTheJob">On-the-Job</option>
                </select>
            </div>
            <div class="w-44">
                <label class="block text-sm font-medium text-slate-700 mb-1">From</label>
                <input type="date" name="DateFrom" value="@Model.DateFrom?.ToString("yyyy-MM-dd")"
                       class="w-full px-3 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-brand-200 focus:border-brand-400">
            </div>
            <div class="w-44">
                <label class="block text-sm font-medium text-slate-700 mb-1">To</label>
                <input type="date" name="DateTo" value="@Model.DateTo?.ToString("yyyy-MM-dd")"
                       class="w-full px-3 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-brand-200 focus:border-brand-400">
            </div>
            <button type="submit" class="px-4 py-2 bg-brand-600 text-white font-medium rounded-lg hover:bg-brand-700">
                Filter
            </button>
        </form>
    </div>

    <!-- Table -->
    <div class="card overflow-hidden">
        <table class="min-w-full divide-y divide-slate-200 text-sm">
            <thead class="bg-slate-50 text-slate-500 uppercase text-xs">
                <tr>
                    <th class="px-6 py-4 text-left font-semibold">Title</th>
                    <th class="px-6 py-4 text-left font-semibold">Employee</th>
                    <th class="px-6 py-4 text-left font-semibold">Type</th>
                    <th class="px-6 py-4 text-left font-semibold">Status</th>
                    <th class="px-6 py-4 text-left font-semibold">Scheduled</th>
                    <th class="px-6 py-4 text-left font-semibold">Completed</th>
                    <th class="px-6 py-4 text-left font-semibold">Score</th>
                    <th class="px-6 py-4 text-right font-semibold">Action</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 bg-white">
                @if (!Model.Records.Any())
                {
                    <tr>
                        <td colspan="8" class="px-6 py-8 text-center text-slate-500">No training records found.</td>
                    </tr>
                }
                else
                {
                    @foreach (var r in Model.Records)
                    {
                        <tr>
                            <td class="px-6 py-4 font-semibold text-slate-800">@r.Title</td>
                            <td class="px-6 py-4 text-slate-600">@r.Employee</td>
                            <td class="px-6 py-4">
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium @r.TypeClass">@r.Type</span>
                            </td>
                            <td class="px-6 py-4">
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium @r.StatusClass">@r.Status</span>
                            </td>
                            <td class="px-6 py-4 text-slate-600">@r.ScheduledDate</td>
                            <td class="px-6 py-4 text-slate-600">@r.CompletionDate</td>
                            <td class="px-6 py-4 text-slate-600">@(r.Score.HasValue ? $"{r.Score}%" : "—")</td>
                            <td class="px-6 py-4 text-right">
                                <a asp-page="/Training/Details" asp-route-id="@r.Id" class="text-brand-600 hover:text-brand-700 text-sm font-medium">View</a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
