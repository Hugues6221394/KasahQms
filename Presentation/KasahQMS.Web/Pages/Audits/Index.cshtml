@page
@model KasahQMS.Web.Pages.Audits.IndexModel
@{
    ViewData["Title"] = "Audits";
}

<div class="py-8">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 space-y-6">
        <section class="relative overflow-hidden rounded-2xl border border-slate-200 bg-slate-900 text-white animate-on-scroll" style="background-image:linear-gradient(120deg,rgba(2,6,23,.88),rgba(8,145,178,.55)),url('https://images.unsplash.com/photo-1554224155-6726b3ff858f?auto=format&fit=crop&w=1600&q=80');background-size:cover;background-position:center;">
            <div class="p-6 md:p-8 flex flex-col lg:flex-row lg:items-end lg:justify-between gap-5">
                <div><p class="text-xs uppercase tracking-[0.2em] text-cyan-100">Compliance</p><h1 class="mt-2 text-3xl font-bold">Audits</h1><p class="mt-2 text-cyan-100">@(Model.IsAuditor ? "View and execute assigned audits" : "Manage internal and external quality audits")</p></div>
                @if (Model.CanScheduleAudit)
                {
                    <div class="flex gap-3 flex-wrap"><a href="/Audits/Schedule" class="inline-flex items-center px-4 py-2.5 rounded-xl bg-white/90 text-slate-900 hover:bg-white">View Schedule</a><a href="/Audits/Create" class="inline-flex items-center px-4 py-2.5 rounded-xl bg-brand-600 text-white hover:bg-brand-700">New Audit</a></div>
                }
                else if (Model.IsAuditor)
                {
                    <span class="inline-flex items-center px-4 py-2 bg-blue-50/95 text-blue-700 text-sm font-medium rounded-xl border border-blue-200">Auditor View - Execute assigned audits</span>
                }
            </div>
        </section>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
            <a href="/Audits?status=Planned" class="card p-5 animate-on-scroll hover:-translate-y-0.5 transition-all"><p class="text-xs uppercase tracking-wider text-slate-500">Planned</p><p class="mt-2 text-3xl font-bold text-brand-600">@Model.PlannedCount</p></a>
            <a href="/Audits?status=InProgress" class="card p-5 animate-on-scroll hover:-translate-y-0.5 transition-all"><p class="text-xs uppercase tracking-wider text-slate-500">In Progress</p><p class="mt-2 text-3xl font-bold text-amber-600">@Model.InProgressCount</p></a>
            <a href="/Audits?status=Completed" class="card p-5 animate-on-scroll hover:-translate-y-0.5 transition-all"><p class="text-xs uppercase tracking-wider text-slate-500">Completed</p><p class="mt-2 text-3xl font-bold text-emerald-600">@Model.CompletedCount</p></a>
            <div class="card p-5 animate-on-scroll hover:-translate-y-0.5 transition-all"><p class="text-xs uppercase tracking-wider text-slate-500">Open Findings</p><p class="mt-2 text-3xl font-bold text-red-600">@Model.OpenFindingsCount</p></div>
        </div>

        <div class="card p-4 md:p-5 animate-on-scroll">
            <form method="get" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-12 gap-4 items-end">
                <div class="xl:col-span-5"><label class="block text-sm font-medium text-slate-700 mb-1">Search</label><input type="search" name="search" value="@Model.SearchTerm" placeholder="Search audits..." class="w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:ring-2 focus:ring-qms-500 focus:border-qms-500"></div>
                <div class="xl:col-span-2"><label class="block text-sm font-medium text-slate-700 mb-1">Status</label><select name="status" class="w-full px-3 py-2.5 border border-slate-300 rounded-lg focus:ring-2 focus:ring-qms-500 focus:border-qms-500"><option value="">All</option><option value="Planned" selected="@(Model.Status == "Planned")">Planned</option><option value="InProgress" selected="@(Model.Status == "InProgress")">In Progress</option><option value="Completed" selected="@(Model.Status == "Completed")">Completed</option><option value="Closed" selected="@(Model.Status == "Closed")">Closed</option></select></div>
                <div class="xl:col-span-2"><label class="block text-sm font-medium text-slate-700 mb-1">Type</label><select name="type" class="w-full px-3 py-2.5 border border-slate-300 rounded-lg focus:ring-2 focus:ring-qms-500 focus:border-qms-500"><option value="">All</option><option value="Internal" selected="@(Model.Type == "Internal")">Internal</option><option value="External" selected="@(Model.Type == "External")">External</option><option value="Supplier" selected="@(Model.Type == "Supplier")">Supplier</option></select></div>
                <div class="xl:col-span-3 flex gap-2"><button type="submit" class="w-full px-4 py-2.5 bg-qms-600 text-white font-medium rounded-lg hover:bg-qms-700 transition-colors">Filter</button><a href="/Audits" class="px-4 py-2.5 text-slate-600 hover:text-slate-900 font-medium">Clear</a></div>
            </form>
        </div>

        <div class="card overflow-hidden animate-on-scroll">
            @if (Model.Audits.Any())
            {
                <div class="overflow-x-auto"><table class="min-w-full divide-y divide-slate-200"><thead class="bg-slate-50"><tr><th class="px-6 py-4 text-left text-xs font-semibold text-slate-600 uppercase tracking-wider">Audit</th><th class="px-6 py-4 text-left text-xs font-semibold text-slate-600 uppercase tracking-wider">Type</th><th class="px-6 py-4 text-left text-xs font-semibold text-slate-600 uppercase tracking-wider">Status</th><th class="px-6 py-4 text-left text-xs font-semibold text-slate-600 uppercase tracking-wider">Lead Auditor</th><th class="px-6 py-4 text-left text-xs font-semibold text-slate-600 uppercase tracking-wider">Date</th><th class="px-6 py-4 text-left text-xs font-semibold text-slate-600 uppercase tracking-wider">Findings</th><th class="px-6 py-4 text-right text-xs font-semibold text-slate-600 uppercase tracking-wider">Actions</th></tr></thead><tbody class="bg-white divide-y divide-slate-100">@foreach (var audit in Model.Audits){<tr class="hover:bg-slate-50 transition-colors"><td class="px-6 py-4"><div><div class="text-sm font-semibold text-slate-900">@audit.Title</div><div class="text-sm text-slate-500">@audit.Number</div></div></td><td class="px-6 py-4"><span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium @(audit.Type == "Internal" ? "bg-brand-100 text-brand-800" : audit.Type == "Supplier" ? "bg-purple-100 text-purple-800" : "bg-blue-100 text-blue-800")">@audit.Type</span></td><td class="px-6 py-4"><span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium @audit.StatusClass">@audit.Status</span></td><td class="px-6 py-4 text-sm text-slate-600">@audit.LeadAuditor</td><td class="px-6 py-4 text-sm text-slate-500">@audit.DateRange</td><td class="px-6 py-4">@if (audit.Findings > 0){<span class="text-sm font-medium text-slate-900">@audit.Findings</span><span class="text-sm text-slate-500"> (@audit.MajorFindings major)</span>} else {<span class="text-sm text-slate-500">-</span>}</td><td class="px-6 py-4 text-right"><a href="/Audits/Details/@audit.Id" class="text-brand-600 hover:text-brand-700 text-sm font-medium">View</a></td></tr>}</tbody></table></div>
                <div class="px-6 py-4 border-t border-slate-200 text-sm text-slate-500">Showing <span class="font-medium">@Model.Audits.Count</span> audits</div>
            }
            else
            {
                <div class="text-center py-14"><div class="w-16 h-16 mx-auto mb-4 rounded-full bg-slate-100 flex items-center justify-center"><svg class="w-8 h-8 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2"/></svg></div><h3 class="text-lg font-medium text-slate-900 mb-1">No audits found</h3><p class="text-sm text-slate-500 mb-4">Get started by scheduling a new audit.</p>@if (Model.CanScheduleAudit){<a href="/Audits/Create" class="inline-flex items-center px-4 py-2 bg-brand-600 text-white font-medium rounded-lg hover:bg-brand-700 transition-colors">Schedule Audit</a>}</div>
            }
        </div>
    </div>
</div>
