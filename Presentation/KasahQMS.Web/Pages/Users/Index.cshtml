@page
@using System.Linq
@model KasahQMS.Web.Pages.Users.IndexModel
@{
    ViewData["Title"] = "Users";
    var totalUsers = Model.Users.Count();
    var activeUsers = Model.Users.Count(u => string.Equals(u.Status, "Active", System.StringComparison.OrdinalIgnoreCase));
    var privilegedUsers = Model.Users.Count(u => u.Role.Contains("Admin") || u.Role.Contains("Manager"));
}

<div class="space-y-6">
    <div class="relative overflow-hidden rounded-2xl border border-slate-200 bg-gradient-to-br from-slate-900 via-slate-800 to-brand-900 p-8 text-white">
        <div class="absolute -right-10 -top-10 h-40 w-40 rounded-full bg-white/10 blur-2xl"></div>
        <div class="relative flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
            <div>
                <p class="text-xs uppercase tracking-[0.2em] text-slate-200">Administration</p>
                <h1 class="mt-2 text-3xl font-semibold">User management</h1>
                <p class="mt-2 text-sm text-slate-200">Administer access, roles, and reporting lines across the enterprise.</p>
            </div>
            <div class="flex gap-3">
                @if (Model.CanEdit)
                {
                    <button class="rounded-lg border border-white/25 bg-white/10 px-4 py-2 text-sm font-semibold text-white hover:bg-white/20">Import users</button>
                    <a href="/Users/Create" class="rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-900 hover:bg-slate-100">Add user</a>
                }
                else
                {
                    <span class="rounded-lg bg-white/10 px-4 py-2 text-sm text-slate-200">Read-Only Access</span>
                }
            </div>
        </div>
    </div>

    <div class="grid gap-4 sm:grid-cols-3">
        <div class="card p-5"><p class="text-xs uppercase tracking-wide text-slate-500">Total users</p><p class="mt-2 text-2xl font-semibold text-slate-900">@totalUsers</p></div>
        <div class="card p-5"><p class="text-xs uppercase tracking-wide text-slate-500">Active users</p><p class="mt-2 text-2xl font-semibold text-emerald-600">@activeUsers</p></div>
        <div class="card p-5"><p class="text-xs uppercase tracking-wide text-slate-500">Privileged users</p><p class="mt-2 text-2xl font-semibold text-brand-600">@privilegedUsers</p></div>
    </div>

    <div class="card p-6">
        <div class="mb-4 flex items-center justify-between">
            <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-500">Directory</h2>
            <span class="text-xs text-slate-400">@totalUsers record(s)</span>
        </div>
        <div class="overflow-x-auto rounded-xl border border-slate-200">
            <table class="min-w-[820px] w-full divide-y divide-slate-200 text-sm">
                <thead class="bg-slate-50 text-xs uppercase text-slate-500">
                    <tr>
                        <th class="px-4 py-3 text-left font-semibold">Name</th>
                        <th class="px-4 py-3 text-left font-semibold">Role</th>
                        <th class="px-4 py-3 text-left font-semibold">Department</th>
                        <th class="px-4 py-3 text-left font-semibold">Status</th>
                        <th class="px-4 py-3 text-right font-semibold">Action</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 bg-white">
                    @foreach (var user in Model.Users)
                    {
                        <tr class="hover:bg-slate-50/70">
                            <td class="px-4 py-3">
                                <div class="font-semibold text-slate-800">@user.Name</div>
                                <div class="text-xs text-slate-500">@user.Email</div>
                            </td>
                            <td class="px-4 py-3 text-slate-600">@user.Role</td>
                            <td class="px-4 py-3 text-slate-600">@user.Department</td>
                            <td class="px-4 py-3">
                                <span class="rounded-full px-3 py-1 text-xs font-semibold @(string.Equals(user.Status, "Active", System.StringComparison.OrdinalIgnoreCase) ? "bg-emerald-50 text-emerald-700" : "bg-slate-100 text-slate-700")">@user.Status</span>
                            </td>
                            <td class="px-4 py-3 text-right">
                                <div class="flex flex-wrap items-center justify-end gap-2">
                                    @if (Model.CanEdit)
                                    {
                                        <a href="/Users/Edit?id=@user.Id" class="rounded-lg border border-slate-200 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 hover:border-brand-300 hover:text-brand-700">Edit</a>
                                        @if(Model.IsSystemAdmin || Model.CanEdit)
                                        {
                                            @if (user.IsActive)
                                            {
                                                <form method="post" asp-page-handler="Deactivate" asp-route-id="@user.Id" onsubmit="return confirm('Temporarily deactivate this user account?');" class="inline-block">
                                                    <button type="submit" class="rounded-lg border border-red-200 bg-red-50 px-3 py-1.5 text-xs font-semibold text-red-600 hover:border-red-300 hover:bg-red-100">Deactivate</button>
                                                </form>
                                            }
                                            else
                                            {
                                                <form method="post" asp-page-handler="Activate" asp-route-id="@user.Id" class="inline-block">
                                                    <button type="submit" class="rounded-lg border border-emerald-200 bg-emerald-50 px-3 py-1.5 text-xs font-semibold text-emerald-700 hover:border-emerald-300 hover:bg-emerald-100">Activate</button>
                                                </form>
                                            }
                                        }
                                        @if (Model.CanDelete)
                                        {
                                            <form method="post" asp-page-handler="Delete" asp-route-id="@user.Id" onsubmit="return confirm('Delete this user? This hides the account from active user management.');" class="inline-block">
                                                <button type="submit" class="rounded-lg border border-rose-200 bg-rose-50 px-3 py-1.5 text-xs font-semibold text-rose-700 hover:border-rose-300 hover:bg-rose-100">Delete</button>
                                            </form>
                                        }
                                    }
                                    else
                                    {
                                        <a href="/Chat?userId=@user.Id" class="rounded-lg border border-slate-200 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 hover:border-brand-300 hover:text-brand-700">Message</a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
