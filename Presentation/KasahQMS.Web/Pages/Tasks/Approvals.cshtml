@page
@model KasahQMS.Web.Pages.Tasks.ApprovalsModel
@{
    ViewData["Title"] = "Task Approvals";
}

<div class="space-y-6">
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-semibold text-slate-900">Task Approvals</h1>
            <p class="text-sm text-slate-500">Review and approve completed tasks from your team</p>
        </div>
        <a href="/Tasks" class="inline-flex items-center gap-2 text-sm text-brand-600 hover:text-brand-700 font-medium">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
            </svg>
            Back to Tasks
        </a>
    </div>

    @if (!Model.PendingTasks.Any())
    {
        <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-12 text-center">
            <svg class="w-16 h-16 mx-auto text-slate-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <h3 class="text-lg font-semibold text-slate-900 mb-2">No Pending Approvals</h3>
            <p class="text-slate-500 text-sm">There are no tasks awaiting your approval at this time.</p>
        </div>
    }
    else
    {
        <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-slate-200">
                    <thead class="bg-slate-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Task</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Assigned To</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Completed By</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Completed At</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Notes</th>
                            <th class="px-6 py-3 text-right text-xs font-medium text-slate-500 uppercase tracking-wider">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-slate-200">
                        @foreach (var task in Model.PendingTasks)
                        {
                            <tr class="hover:bg-slate-50">
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-3">
                                        <div class="flex-shrink-0">
                                            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium @(task.Priority == "Urgent" ? "bg-red-100 text-red-700" : task.Priority == "High" ? "bg-orange-100 text-orange-700" : task.Priority == "Medium" ? "bg-amber-100 text-amber-700" : "bg-slate-100 text-slate-700")">
                                                @task.Priority
                                            </span>
                                        </div>
                                        <div>
                                            <div class="text-sm font-medium text-slate-900">@task.Title</div>
                                            <div class="text-xs text-slate-500">@task.TaskNumber</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4">
                                    <div class="text-sm text-slate-900">@task.AssignedTo</div>
                                    <div class="text-xs text-slate-500">@task.Department</div>
                                </td>
                                <td class="px-6 py-4 text-sm text-slate-900">@task.CompletedBy</td>
                                <td class="px-6 py-4 text-sm text-slate-500">@task.CompletedAt</td>
                                <td class="px-6 py-4">
                                    <div class="text-sm text-slate-600 max-w-xs truncate" title="@task.CompletionNotes">
                                        @(string.IsNullOrWhiteSpace(task.CompletionNotes) ? "—" : task.CompletionNotes)
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-right whitespace-nowrap text-sm font-medium">
                                    <a href="/Tasks/Details?id=@task.Id" class="text-brand-600 hover:text-brand-900 mr-4">Review</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
