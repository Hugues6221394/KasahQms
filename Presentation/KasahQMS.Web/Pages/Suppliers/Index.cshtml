@page
@model KasahQMS.Web.Pages.Suppliers.IndexModel
@{
    ViewData["Title"] = "Suppliers";
}

<div class="space-y-6">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
        <div>
            <h1 class="text-2xl font-semibold text-slate-900">Supplier Quality Management</h1>
            <p class="text-sm text-slate-500">Manage supplier qualifications, audits and performance.</p>
        </div>
        <a href="/Suppliers/Create" class="inline-flex items-center rounded-lg bg-brand-600 px-4 py-2 text-sm font-semibold text-white hover:bg-brand-700">
            Add Supplier
        </a>
    </div>

    <!-- Stats Cards -->
    <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-5">
        <div class="card p-4 flex items-center justify-between">
            <div>
                <div class="text-xs text-slate-500 uppercase">Total</div>
                <div class="text-2xl font-semibold text-slate-900">@Model.TotalCount</div>
            </div>
            <div class="w-10 h-10 rounded-lg bg-slate-100 text-slate-600 flex items-center justify-center">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/></svg>
            </div>
        </div>
        <div class="card p-4 flex items-center justify-between">
            <div>
                <div class="text-xs text-slate-500 uppercase">Qualified</div>
                <div class="text-2xl font-semibold text-emerald-700">@Model.QualifiedCount</div>
            </div>
            <div class="w-10 h-10 rounded-lg bg-emerald-100 text-emerald-700 flex items-center justify-center">✓</div>
        </div>
        <div class="card p-4 flex items-center justify-between">
            <div>
                <div class="text-xs text-slate-500 uppercase">Conditional</div>
                <div class="text-2xl font-semibold text-amber-700">@Model.ConditionallyCount</div>
            </div>
            <div class="w-10 h-10 rounded-lg bg-amber-100 text-amber-700 flex items-center justify-center">●</div>
        </div>
        <div class="card p-4 flex items-center justify-between">
            <div>
                <div class="text-xs text-slate-500 uppercase">Pending</div>
                <div class="text-2xl font-semibold text-brand-700">@Model.PendingCount</div>
            </div>
            <div class="w-10 h-10 rounded-lg bg-brand-100 text-brand-700 flex items-center justify-center">▶</div>
        </div>
        <div class="card p-4 flex items-center justify-between">
            <div>
                <div class="text-xs text-slate-500 uppercase">Disqualified</div>
                <div class="text-2xl font-semibold text-rose-700">@Model.DisqualifiedCount</div>
            </div>
            <div class="w-10 h-10 rounded-lg bg-rose-100 text-rose-700 flex items-center justify-center">✗</div>
        </div>
    </div>

    <!-- Filters -->
    <div class="card p-4">
        <form method="get" class="flex flex-wrap gap-4 items-end">
            <div class="w-44">
                <label class="block text-sm font-medium text-slate-700 mb-1">Status</label>
                <select name="StatusFilter" asp-for="StatusFilter" class="w-full px-3 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-brand-200 focus:border-brand-400">
                    <option value="">All</option>
                    <option value="Pending">Pending</option>
                    <option value="Qualified">Qualified</option>
                    <option value="Conditionally">Conditionally</option>
                    <option value="Suspended">Suspended</option>
                    <option value="Disqualified">Disqualified</option>
                </select>
            </div>
            <div class="w-44">
                <label class="block text-sm font-medium text-slate-700 mb-1">Category</label>
                <select name="CategoryFilter" asp-for="CategoryFilter" class="w-full px-3 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-brand-200 focus:border-brand-400">
                    <option value="">All</option>
                    <option value="Raw Material">Raw Material</option>
                    <option value="Equipment">Equipment</option>
                    <option value="Service">Service</option>
                    <option value="IT">IT</option>
                    <option value="Logistics">Logistics</option>
                </select>
            </div>
            <button type="submit" class="px-4 py-2 bg-brand-600 text-white font-medium rounded-lg hover:bg-brand-700">
                Filter
            </button>
        </form>
    </div>

    <!-- Table -->
    <div class="card overflow-hidden">
        <table class="min-w-full divide-y divide-slate-200 text-sm">
            <thead class="bg-slate-50 text-slate-500 uppercase text-xs">
                <tr>
                    <th class="px-6 py-4 text-left font-semibold">Code</th>
                    <th class="px-6 py-4 text-left font-semibold">Name</th>
                    <th class="px-6 py-4 text-left font-semibold">Category</th>
                    <th class="px-6 py-4 text-left font-semibold">Contact</th>
                    <th class="px-6 py-4 text-left font-semibold">Status</th>
                    <th class="px-6 py-4 text-left font-semibold">Performance</th>
                    <th class="px-6 py-4 text-left font-semibold">Next Audit</th>
                    <th class="px-6 py-4 text-right font-semibold">Action</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 bg-white">
                @if (!Model.Suppliers.Any())
                {
                    <tr>
                        <td colspan="8" class="px-6 py-8 text-center text-slate-500">No suppliers found.</td>
                    </tr>
                }
                else
                {
                    @foreach (var s in Model.Suppliers)
                    {
                        <tr>
                            <td class="px-6 py-4 font-mono text-xs text-slate-600">@s.Code</td>
                            <td class="px-6 py-4 font-semibold text-slate-800">@s.Name</td>
                            <td class="px-6 py-4 text-slate-600">@s.Category</td>
                            <td class="px-6 py-4 text-slate-600">@s.Contact</td>
                            <td class="px-6 py-4">
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium @s.StatusClass">@s.Status</span>
                            </td>
                            <td class="px-6 py-4">
                                @if (s.PerformanceScore.HasValue)
                                {
                                    var pct = Math.Min(100, (int)s.PerformanceScore.Value);
                                    var barColor = pct >= 80 ? "bg-emerald-500" : pct >= 60 ? "bg-amber-500" : "bg-rose-500";
                                    <div class="flex items-center gap-2">
                                        <div class="w-20 h-2 bg-slate-200 rounded-full overflow-hidden">
                                            <div class="h-full rounded-full @barColor" style="width: @(pct)%"></div>
                                        </div>
                                        <span class="text-xs text-slate-600">@pct%</span>
                                    </div>
                                }
                                else
                                {
                                    <span class="text-slate-400">—</span>
                                }
                            </td>
                            <td class="px-6 py-4 text-slate-600">@s.NextAuditDate</td>
                            <td class="px-6 py-4 text-right">
                                <a asp-page="/Suppliers/Details" asp-route-id="@s.Id" class="text-brand-600 hover:text-brand-700 text-sm font-medium">View</a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
