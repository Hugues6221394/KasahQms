@page
@model KasahQMS.Web.Pages.Notifications.IndexModel
@{
    ViewData["Title"] = "Notifications";
}

<div class="space-y-6">
    <div class="rounded-2xl border border-slate-200 bg-white p-6">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
            <div>
                <p class="text-xs uppercase tracking-[0.2em] text-brand-600">Communication Center</p>
                <h1 class="mt-2 text-3xl font-semibold text-slate-900">Notifications</h1>
                <p class="mt-2 text-sm text-slate-500">Stay updated with latest activities and alerts across quality workflows.</p>
            </div>
            <div class="flex items-center gap-3">
                <div id="notif-total-badge" class="rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-xs font-semibold text-slate-600">0 total</div>
                <div id="notif-unread-badge" class="rounded-lg border border-amber-200 bg-amber-50 px-3 py-2 text-xs font-semibold text-amber-700">0 unread</div>
                @if (Model.Notifications.Any(n => !n.IsRead))
                {
                    <form method="post" asp-page-handler="MarkAllAsRead">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="rounded-lg bg-brand-600 px-4 py-2 text-sm font-semibold text-white hover:bg-brand-700">Mark all as read</button>
                    </form>
                }
            </div>
        </div>
    </div>

    <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white">
        <div id="notif-list-container" class="divide-y divide-slate-100"></div>
        <div id="notif-empty-state" class="hidden py-20 text-center">
            <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-2xl bg-slate-50">
                <svg class="h-8 w-8 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
            </div>
            <h3 class="text-lg font-medium text-slate-900">All caught up</h3>
            <p class="mt-1 text-slate-500">You have no new notifications at the moment.</p>
        </div>
    </div>

    <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white">
        <div class="border-b border-slate-100 p-5">
            <h2 class="text-lg font-semibold text-slate-900">Email Notification Preferences</h2>
            <p class="mt-1 text-sm text-slate-500">Choose which notifications you receive via email.</p>
        </div>
        @if (Model.PreferencesSaved)
        {
            <div class="mx-5 mt-4 rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700">Preferences saved successfully.</div>
        }
        <form method="post" asp-page-handler="SavePreferences" class="space-y-4 p-5">
            @Html.AntiForgeryToken()
            <label class="flex cursor-pointer items-center justify-between border-b border-slate-100 py-3">
                <div><div class="text-sm font-medium text-slate-800">Document Approvals</div><div class="text-xs text-slate-500">Notify when documents require your approval or are approved/rejected.</div></div>
                <div class="relative"><input type="hidden" name="PrefDocumentApprovals" value="false" /><input type="checkbox" name="PrefDocumentApprovals" value="true" @(Model.PrefDocumentApprovals ? "checked" : "") class="peer sr-only" id="pref-docs" /><label for="pref-docs" class="block h-6 w-11 cursor-pointer rounded-full bg-slate-200 after:absolute after:left-0.5 after:top-0.5 after:h-5 after:w-5 after:rounded-full after:bg-white after:transition-all after:content-[''] peer-checked:bg-brand-500 peer-checked:after:translate-x-5"></label></div>
            </label>
            <label class="flex cursor-pointer items-center justify-between border-b border-slate-100 py-3">
                <div><div class="text-sm font-medium text-slate-800">Task Assignments</div><div class="text-xs text-slate-500">Notify when tasks are assigned to you or updated.</div></div>
                <div class="relative"><input type="hidden" name="PrefTaskAssignments" value="false" /><input type="checkbox" name="PrefTaskAssignments" value="true" @(Model.PrefTaskAssignments ? "checked" : "") class="peer sr-only" id="pref-tasks" /><label for="pref-tasks" class="block h-6 w-11 cursor-pointer rounded-full bg-slate-200 after:absolute after:left-0.5 after:top-0.5 after:h-5 after:w-5 after:rounded-full after:bg-white after:transition-all after:content-[''] peer-checked:bg-brand-500 peer-checked:after:translate-x-5"></label></div>
            </label>
            <label class="flex cursor-pointer items-center justify-between border-b border-slate-100 py-3">
                <div><div class="text-sm font-medium text-slate-800">CAPA Updates</div><div class="text-xs text-slate-500">Notify on CAPA assignments, status changes, and verifications.</div></div>
                <div class="relative"><input type="hidden" name="PrefCapaUpdates" value="false" /><input type="checkbox" name="PrefCapaUpdates" value="true" @(Model.PrefCapaUpdates ? "checked" : "") class="peer sr-only" id="pref-capa" /><label for="pref-capa" class="block h-6 w-11 cursor-pointer rounded-full bg-slate-200 after:absolute after:left-0.5 after:top-0.5 after:h-5 after:w-5 after:rounded-full after:bg-white after:transition-all after:content-[''] peer-checked:bg-brand-500 peer-checked:after:translate-x-5"></label></div>
            </label>
            <label class="flex cursor-pointer items-center justify-between border-b border-slate-100 py-3">
                <div><div class="text-sm font-medium text-slate-800">Audit Schedules</div><div class="text-xs text-slate-500">Notify about upcoming audit schedules and findings.</div></div>
                <div class="relative"><input type="hidden" name="PrefAuditSchedules" value="false" /><input type="checkbox" name="PrefAuditSchedules" value="true" @(Model.PrefAuditSchedules ? "checked" : "") class="peer sr-only" id="pref-audits" /><label for="pref-audits" class="block h-6 w-11 cursor-pointer rounded-full bg-slate-200 after:absolute after:left-0.5 after:top-0.5 after:h-5 after:w-5 after:rounded-full after:bg-white after:transition-all after:content-[''] peer-checked:bg-brand-500 peer-checked:after:translate-x-5"></label></div>
            </label>
            <label class="flex cursor-pointer items-center justify-between py-3">
                <div><div class="text-sm font-medium text-slate-800">System Alerts</div><div class="text-xs text-slate-500">Important system-wide announcements and security alerts.</div></div>
                <div class="relative"><input type="hidden" name="PrefSystemAlerts" value="false" /><input type="checkbox" name="PrefSystemAlerts" value="true" @(Model.PrefSystemAlerts ? "checked" : "") class="peer sr-only" id="pref-system" /><label for="pref-system" class="block h-6 w-11 cursor-pointer rounded-full bg-slate-200 after:absolute after:left-0.5 after:top-0.5 after:h-5 after:w-5 after:rounded-full after:bg-white after:transition-all after:content-[''] peer-checked:bg-brand-500 peer-checked:after:translate-x-5"></label></div>
            </label>
            <div class="pt-4"><button type="submit" class="rounded-lg bg-brand-600 px-5 py-2 text-sm font-semibold text-white hover:bg-brand-700">Save Preferences</button></div>
        </form>
    </div>
</div>

@section Scripts {
<script>
(function() {
    var notifications = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Notifications));

    function esc(str) {
        return String(str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    function iconHtml(type) {
        if (type === 'Task') return '<svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>';
        if (type === 'Document') return '<svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>';
        return '<svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>';
    }

    function iconBg(type) {
        if (type === 'Task') return 'bg-indigo-100 text-indigo-600';
        if (type === 'Document') return 'bg-emerald-100 text-emerald-600';
        return 'bg-brand-100 text-brand-600';
    }

    function render() {
        var container = document.getElementById('notif-list-container');
        var empty = document.getElementById('notif-empty-state');
        var totalBadge = document.getElementById('notif-total-badge');
        var unreadBadge = document.getElementById('notif-unread-badge');
        if (!container) return;

        var unread = notifications.filter(function(n) { return !n.isRead; }).length;
        if (totalBadge) totalBadge.textContent = notifications.length + ' total';
        if (unreadBadge) unreadBadge.textContent = unread + ' unread';

        if (notifications.length === 0) {
            container.innerHTML = '';
            if (empty) empty.classList.remove('hidden');
            return;
        }
        if (empty) empty.classList.add('hidden');

        container.innerHTML = notifications.map(function(n) {
            var href = resolveUrl(n);
            var actionLabel = href === '/Notifications' ? 'Open notifications center' : 'Open related item';
            var rowBg = n.isRead ? 'opacity-75' : 'bg-slate-50/50';
            var dot = n.isRead ? '<span class="rounded-full bg-slate-100 px-2 py-0.5 text-[10px] font-medium text-slate-500">Read</span>' : '<span class="rounded-full bg-brand-100 px-2 py-0.5 text-[10px] font-semibold text-brand-700">New</span>';
            return '<a href="' + esc(href) + '" class="flex items-start gap-4 p-4 transition-colors hover:bg-slate-50 cursor-pointer ' + rowBg + '" onclick="qmsPageOpenNotification(event,\'' + (n.id||'') + '\',\'' + esc(href) + '\')">'
                + '<div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-xl ' + iconBg(n.type) + '">' + iconHtml(n.type) + '</div>'
                + '<div class="min-w-0 flex-1">'
                +   '<div class="flex items-center justify-between gap-2">'
                +     '<h3 class="truncate text-sm font-semibold text-slate-900">' + esc(n.title) + '</h3>'
                    +     '<span class="whitespace-nowrap text-xs text-slate-400">' + esc(n.time) + '</span>'
                +   '</div>'
                +   '<p class="mt-1 break-words text-sm leading-6 text-slate-700">' + esc(n.message) + '</p>'
                +   '<p class="mt-2 text-[11px] font-medium text-brand-600">' + actionLabel + '</p>'
                + '</div>'
                + dot
                + '</a>';
        }).join('');
    }

    function resolveUrl(notification) {
        if (!notification || !notification.relatedEntityId) return '/Notifications';
        var type = String(notification.relatedEntityType || '').toLowerCase();
        if (type === 'task' || type === 'taskassignment') return '/Tasks/Details/' + notification.relatedEntityId;
        if (type === 'training') return '/Training/Details/' + notification.relatedEntityId;
        if (type === 'chat') return '/Chat?thread=' + notification.relatedEntityId;
        if (type === 'newsarticle' || type === 'news') return '/News/Details/' + notification.relatedEntityId;
        return '/Documents/Details/' + notification.relatedEntityId;
    }

    window.qmsPageOpenNotification = function(e, id, href) {
        if (e) e.preventDefault();
        if (!id) {
            window.location.href = href || '/Notifications';
            return;
        }
        var n = notifications.find(function(x) { return x.id === id; });
        if (n && !n.isRead) {
            fetch('/api/NotificationsApi/' + id + '/read', { method: 'POST' }).finally(function() {
                notifications = notifications.map(function(x) { return x.id === id ? Object.assign({}, x, { isRead: true }) : x; });
                render();
                try { window.dispatchEvent(new CustomEvent('qms:refreshBadges')); } catch(e) {}
                window.location.href = href || '/Notifications';
            });
            return;
        }
        window.location.href = href || '/Notifications';
    };

    render();

    window.addEventListener('qms:notification', function() {
        fetch('/api/NotificationsApi?limit=100').then(function(r) { return r.json(); }).then(function(d) {
            notifications = d.items || [];
            render();
        });
    });
})();
</script>
}
