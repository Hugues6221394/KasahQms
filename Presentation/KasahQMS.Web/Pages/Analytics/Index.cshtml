@page
@model KasahQMS.Web.Pages.Analytics.IndexModel
@{
    ViewData["Title"] = "Analytics";
}

<div class="space-y-8">
    <div class="relative overflow-hidden rounded-2xl border border-slate-200 bg-gradient-to-r from-slate-900 via-slate-800 to-brand-900 p-7 text-white">
        <div class="absolute -right-14 -top-12 h-44 w-44 rounded-full bg-white/10 blur-3xl"></div>
        <div class="relative flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
            <div>
                <p class="text-xs uppercase tracking-[0.2em] text-slate-200">Performance Command Center</p>
                <h1 class="mt-2 text-3xl font-semibold">Analytics dashboard</h1>
                <p class="mt-2 text-sm text-slate-200">
                    @if (Model.IsScopedToDepartment)
                    {
                        <span>Department: <strong>@Model.ScopedDepartmentName</strong></span>
                    }
                    else
                    {
                        <span>Organization-wide performance indicators</span>
                    }
                </p>
            </div>
            <a href="/Reports" class="rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-900 hover:bg-slate-100">View reports</a>
        </div>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5">
        <div class="card p-5"><div class="text-xs uppercase tracking-wide text-slate-500">Documents</div><div class="mt-2 text-2xl font-bold text-slate-900">@Model.TotalDocuments</div><div class="mt-2 text-xs text-slate-500">Approved rate: <span class="font-semibold text-emerald-600">@Model.ApprovedRate%</span></div></div>
        <div class="card p-5"><div class="text-xs uppercase tracking-wide text-slate-500">Open CAPAs</div><div class="mt-2 text-2xl font-bold text-slate-900">@Model.OpenCapas</div><div class="mt-2 text-xs text-slate-500">Avg resolution: <span class="font-semibold text-amber-600">@Model.AvgCapaResolutionDays days</span></div></div>
        <div class="card p-5"><div class="text-xs uppercase tracking-wide text-slate-500">Task completion</div><div class="mt-2 text-2xl font-bold text-slate-900">@Model.TaskCompletionRate%</div><div class="mt-3 h-1.5 rounded-full bg-slate-100"><div class="h-full rounded-full bg-indigo-500" style="width:@(Model.TaskCompletionRate)%"></div></div></div>
        <div class="card p-5"><div class="text-xs uppercase tracking-wide text-slate-500">Audit coverage</div><div class="mt-2 text-2xl font-bold text-slate-900">@Model.AuditCoveragePercent%</div><div class="mt-2 text-xs text-slate-500">Findings: <span class="font-semibold text-sky-600">@Model.AuditFindingsCount</span></div></div>
        <div class="card p-5"><div class="text-xs uppercase tracking-wide text-slate-500">Avg risk score</div><div class="mt-2 text-2xl font-bold text-slate-900">@Model.AvgRiskScore</div><div class="mt-2 text-xs text-slate-500">Training compliance: <span class="font-semibold text-red-600">@Model.TrainingComplianceRate%</span></div></div>
    </div>

    <div class="grid gap-6 xl:grid-cols-3">
        <div class="card p-6"><h2 class="text-lg font-semibold text-slate-900">Document Status</h2><p class="mb-4 text-xs text-slate-500">Distribution by status</p><canvas id="docStatusChart" height="220"></canvas></div>
        <div class="card p-6 xl:col-span-2"><h2 class="text-lg font-semibold text-slate-900">Monthly Trends</h2><p class="mb-4 text-xs text-slate-500">Documents &amp;  last 12 months</p><canvas id="monthlyTrendChart" height="120"></canvas></div>tasks 
    </div>

    <div class="grid gap-6 xl:grid-cols-2">
        <div class="card p-6"><h2 class="text-lg font-semibold text-slate-900">CAPA Aging Analysis</h2><p class="mb-4 text-xs text-slate-500">Open CAPAs by age bracket</p><canvas id="capaAgingChart" height="180"></canvas></div>
        <div class="card p-6"><h2 class="text-lg font-semibold text-slate-900">Audit Finding Severity</h2><p class="mb-4 text-xs text-slate-500">Distribution across severity levels</p><canvas id="findingSeverityChart" height="180"></canvas></div>
    </div>

    <div class="grid gap-6 xl:grid-cols-2">
        <div class="card p-6"><h2 class="text-lg font-semibold text-slate-900">Supplier Performance</h2><p class="mb-4 text-xs text-slate-500">Top suppliers by score</p><canvas id="supplierChart" height="200"></canvas></div>
        <div class="card p-6"><h2 class="text-lg font-semibold text-slate-900">Risk Heat Map</h2><p class="mb-4 text-xs text-slate-500">Likelihood vs Impact (active risks)</p><div id="riskHeatMap" class="mt-2"></div></div>
    </div>

    <div class="card p-6">
        <div class="mb-4 flex items-center justify-between">
            <div>
                <h2 class="text-lg font-semibold text-slate-900">Training Compliance</h2>
                <p class="text-xs text-slate-500">Overall completion rate</p>
            </div>
            <span class="text-3xl font-bold text-brand-600">@Model.TrainingComplianceRate%</span>
        </div>
        <div class="h-4 w-full rounded-full bg-slate-100"><div class="h-full rounded-full transition-all duration-500" style="width:@(Model.TrainingComplianceRate)%; background: linear-gradient(90deg, #059669, #34d399);"></div></div>
    </div>

    <div class="card p-6">
        <h2 class="mb-4 text-lg font-semibold text-slate-900">Department Performance</h2>
        <div class="overflow-hidden rounded-xl border border-slate-200">
            <table class="min-w-full divide-y divide-slate-200 text-sm">
                <thead class="bg-slate-50 text-xs uppercase text-slate-500">
                    <tr>
                        <th class="px-4 py-3 text-left font-semibold">Department</th>
                        <th class="px-4 py-3 text-left font-semibold">Compliance</th>
                        <th class="px-4 py-3 text-left font-semibold">Open CAPAs</th>
                        <th class="px-4 py-3 text-left font-semibold">Audit Readiness</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 bg-white">
                    @foreach (var dept in Model.DepartmentMetrics)
                    {
                        <tr>
                            <td class="px-4 py-3 font-semibold text-slate-800">@dept.Department</td>
                            <td class="px-4 py-3 text-slate-600">@dept.Compliance</td>
                            <td class="px-4 py-3 text-slate-600">@dept.OpenCapa</td>
                            <td class="px-4 py-3"><span class="inline-flex rounded-full px-2 py-0.5 text-xs font-semibold @(dept.Readiness == "High" ? "bg-emerald-100 text-emerald-700" : dept.Readiness == "Medium" ? "bg-amber-100 text-amber-700" : "bg-red-100 text-red-700")">@dept.Readiness</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const chartColors = { green: '#059669', emerald: '#34d399', amber: '#f59e0b', red: '#ef4444', sky: '#0ea5e9', indigo: '#6366f1', slate: '#94a3b8' };
    const gridOpts = { color: '#e2e8f0' };
    const tickOpts = { color: '#64748b' };

    (function() {
        var d = @Html.Raw(Model.DocStatusChartJson);
        new Chart(document.getElementById('docStatusChart'), {
            type: 'doughnut',
            data: { labels: d.labels, datasets: [{ data: d.values, backgroundColor: ['#94a3b8','#6366f1','#0ea5e9','#059669','#ef4444','#64748b'] }] },
            options: { plugins: { legend: { position: 'bottom', labels: { boxWidth: 12 } } }, cutout: '60%' }
        });
    })();

    (function() {
        var d = @Html.Raw(Model.MonthlyTrendJson);
        new Chart(document.getElementById('monthlyTrendChart'), {
            type: 'line',
            data: {
                labels: d.labels,
                datasets: [
                    { label: 'Documents', data: d.documents, borderColor: '#059669', backgroundColor: 'rgba(5,150,105,0.1)', tension: 0.35, fill: true },
                    { label: 'Tasks', data: d.tasks, borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.1)', tension: 0.35, fill: true }
                ]
            },
            options: { plugins: { legend: { position: 'top', labels: { boxWidth: 12 } } }, scales: { y: { grid: gridOpts, ticks: tickOpts, beginAtZero: true }, x: { grid: { display: false }, ticks: tickOpts } } }
        });
    })();

    (function() {
        var d = @Html.Raw(Model.CapaAgingJson);
        new Chart(document.getElementById('capaAgingChart'), {
            type: 'bar',
            data: { labels: d.labels, datasets: [{ label: 'Open CAPAs', data: d.values, backgroundColor: ['#059669','#f59e0b','#f97316','#ef4444'], borderRadius: 6 }] },
            options: { plugins: { legend: { display: false } }, scales: { y: { grid: gridOpts, ticks: tickOpts, beginAtZero: true }, x: { grid: { display: false }, ticks: tickOpts } } }
        });
    })();

    (function() {
        var d = @Html.Raw(Model.FindingSeverityJson);
        new Chart(document.getElementById('findingSeverityChart'), {
            type: 'polarArea',
            data: { labels: d.labels, datasets: [{ data: d.values, backgroundColor: ['#34d399','#f59e0b','#ef4444','#94a3b8'] }] },
            options: { plugins: { legend: { position: 'bottom', labels: { boxWidth: 12 } } } }
        });
    })();

    (function() {
        var d = @Html.Raw(Model.SupplierPerformanceJson);
        new Chart(document.getElementById('supplierChart'), {
            type: 'bar',
            data: { labels: d.labels, datasets: [{ label: 'Score', data: d.values, backgroundColor: '#059669', borderRadius: 4 }] },
            options: { indexAxis: 'y', plugins: { legend: { display: false } }, scales: { x: { grid: gridOpts, ticks: tickOpts, beginAtZero: true, max: 100 }, y: { grid: { display: false }, ticks: tickOpts } } }
        });
    })();

    (function() {
        var cells = @Html.Raw(Model.RiskHeatMapJson);
        var el = document.getElementById('riskHeatMap');
        var labels = ['Very Low','Low','Medium','High','Very High'];
        var html = '<div style="display:grid;grid-template-columns:auto repeat(5,1fr);gap:2px;font-size:11px;text-align:center;">';
        html += '<div></div>';
        for (var i = 0; i < 5; i++) html += '<div class="text-xs font-medium text-slate-500 pb-1">' + labels[i] + '</div>';
        for (var l = 4; l >= 0; l--) {
            html += '<div class="text-xs font-medium text-slate-500 pr-2 flex items-center">' + labels[l] + '</div>';
            for (var im = 0; im < 5; im++) {
                var c = cells.find(function(x) { return x.likelihood === l+1 && x.impact === im+1; });
                var v = c ? c.count : 0;
                var score = (l+1) * (im+1);
                var bg = score <= 4 ? '#d1fae5' : score <= 9 ? '#fef3c7' : score <= 15 ? '#fed7aa' : '#fecaca';
                var tc = score <= 4 ? '#065f46' : score <= 9 ? '#92400e' : score <= 15 ? '#9a3412' : '#991b1b';
                html += '<div style="background:'+bg+';color:'+tc+';padding:8px 4px;border-radius:6px;font-weight:600;">'+v+'</div>';
            }
        }
</span></div><div class="text-[10px] text-slate-400 -mt-1"></div>';Likelihood 
        el.innerHTML = html;
    })();
</script>
}
