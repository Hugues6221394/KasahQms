@page
@model KasahQMS.Web.Pages.Security.SessionsModel
@{
    ViewData["Title"] = "Active Sessions";
}

<div class="space-y-8">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
        <div>
            <h1 class="text-2xl font-semibold text-slate-900">Active Sessions</h1>
            <p class="text-sm text-slate-500">Manage devices and sessions signed in to your account.</p>
        </div>
        <form method="post" asp-page-handler="RevokeAll">
            <button type="submit" onclick="return confirm('Revoke all other sessions? You will remain signed in on this device only.')"
                    class="rounded-lg border border-accent-300 bg-accent-50 px-4 py-2 text-sm font-semibold text-accent-700 hover:bg-accent-100 transition-colors">
                Revoke All Other Sessions
            </button>
        </form>
    </div>

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="p-4 bg-brand-50 border border-brand-200 rounded-xl flex items-start gap-3">
            <svg class="w-5 h-5 text-brand-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <p class="text-sm text-brand-800">@Model.StatusMessage</p>
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="p-4 bg-accent-50 border border-accent-100 rounded-xl flex items-start gap-3">
            <svg class="w-5 h-5 text-accent-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <p class="text-sm text-accent-600">@Model.ErrorMessage</p>
        </div>
    }

    <div class="card p-6">
        @if (Model.Sessions.Any())
        {
            <div class="overflow-hidden rounded-lg border border-slate-200">
                <table class="min-w-full divide-y divide-slate-200 text-sm">
                    <thead class="bg-slate-50 text-slate-500 uppercase text-xs">
                        <tr>
                            <th class="px-4 py-3 text-left font-semibold">Device</th>
                            <th class="px-4 py-3 text-left font-semibold">IP Address</th>
                            <th class="px-4 py-3 text-left font-semibold">Browser</th>
                            <th class="px-4 py-3 text-left font-semibold">Location</th>
                            <th class="px-4 py-3 text-left font-semibold">Last Activity</th>
                            <th class="px-4 py-3 text-left font-semibold">Created</th>
                            <th class="px-4 py-3 text-right font-semibold">Action</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100 bg-white">
                        @foreach (var session in Model.Sessions)
                        {
                            <tr class="@(session.IsCurrent ? "bg-brand-50/50" : "")">
                                <td class="px-4 py-3 text-slate-700 font-medium">
                                    <div class="flex items-center gap-2">
                                        <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                                        </svg>
                                        @session.Device
                                        @if (session.IsCurrent)
                                        {
                                            <span class="inline-flex items-center rounded-full bg-brand-100 px-2 py-0.5 text-xs font-medium text-brand-700">Current</span>
                                        }
                                    </div>
                                </td>
                                <td class="px-4 py-3 text-slate-600 font-mono text-xs">@session.IpAddress</td>
                                <td class="px-4 py-3 text-slate-600">@session.Browser</td>
                                <td class="px-4 py-3 text-slate-600">@session.Location</td>
                                <td class="px-4 py-3 text-slate-600">@session.LastActivity.ToString("MMM dd, yyyy HH:mm")</td>
                                <td class="px-4 py-3 text-slate-600">@session.CreatedAt.ToString("MMM dd, yyyy HH:mm")</td>
                                <td class="px-4 py-3 text-right">
                                    @if (!session.IsCurrent)
                                    {
                                        <form method="post" asp-page-handler="Revoke" class="inline">
                                            <input type="hidden" name="sessionId" value="@session.Id" />
                                            <button type="submit" onclick="return confirm('Revoke this session?')"
                                                    class="rounded-lg border border-slate-200 bg-white px-3 py-1.5 text-xs font-semibold text-accent-600 hover:bg-accent-50 hover:border-accent-200 transition-colors">
                                                Revoke
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="text-xs text-slate-400">This device</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-12">
                <svg class="w-12 h-12 text-slate-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
                <p class="text-sm text-slate-500">No active sessions found.</p>
            </div>
        }
    </div>
</div>
