@page
@model KasahQMS.Web.Pages.Security.PasswordPolicyModel
@{
    ViewData["Title"] = "Password Policy";
}

<div class="space-y-8">
    <div>
        <h1 class="text-2xl font-semibold text-slate-900">Password Policy</h1>
        <p class="text-sm text-slate-500">Configure password complexity and lifecycle rules for your organization.</p>
    </div>

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="p-4 bg-brand-50 border border-brand-200 rounded-xl flex items-start gap-3">
            <svg class="w-5 h-5 text-brand-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <p class="text-sm text-brand-800">@Model.StatusMessage</p>
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="p-4 bg-accent-50 border border-accent-100 rounded-xl flex items-start gap-3">
            <svg class="w-5 h-5 text-accent-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <p class="text-sm text-accent-600">@Model.ErrorMessage</p>
        </div>
    }

    <div class="grid gap-6 lg:grid-cols-3">
        <!-- Policy Configuration Form -->
        <div class="lg:col-span-2">
            <form method="post">
                <div class="card p-6 space-y-6">
                    <h2 class="text-lg font-semibold text-slate-900">Complexity Requirements</h2>

                    <div class="grid gap-4 md:grid-cols-2">
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-2">Minimum Length</label>
                            <input type="number" asp-for="MinLength" min="6" max="128"
                                   class="w-full rounded-lg border border-slate-300 px-4 py-2.5 text-sm focus:ring-2 focus:ring-brand-500/20 focus:border-brand-500 transition-all" />
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-2">Maximum Length</label>
                            <input type="number" asp-for="MaxLength" min="8" max="256"
                                   class="w-full rounded-lg border border-slate-300 px-4 py-2.5 text-sm focus:ring-2 focus:ring-brand-500/20 focus:border-brand-500 transition-all" />
                        </div>
                    </div>

                    <div class="space-y-3">
                        <label class="flex items-center justify-between">
                            <span class="text-sm text-slate-600">Require uppercase letter (A-Z)</span>
                            <input type="checkbox" asp-for="RequireUppercase" class="h-5 w-5 rounded border-slate-300 text-brand-600 focus:ring-brand-300" />
                        </label>
                        <label class="flex items-center justify-between">
                            <span class="text-sm text-slate-600">Require lowercase letter (a-z)</span>
                            <input type="checkbox" asp-for="RequireLowercase" class="h-5 w-5 rounded border-slate-300 text-brand-600 focus:ring-brand-300" />
                        </label>
                        <label class="flex items-center justify-between">
                            <span class="text-sm text-slate-600">Require digit (0-9)</span>
                            <input type="checkbox" asp-for="RequireDigit" class="h-5 w-5 rounded border-slate-300 text-brand-600 focus:ring-brand-300" />
                        </label>
                        <label class="flex items-center justify-between">
                            <span class="text-sm text-slate-600">Require special character</span>
                            <input type="checkbox" asp-for="RequireSpecialChar" class="h-5 w-5 rounded border-slate-300 text-brand-600 focus:ring-brand-300" />
                        </label>
                    </div>

                    <hr class="border-slate-200" />

                    <h2 class="text-lg font-semibold text-slate-900">Lifecycle &amp; Lockout</h2>

                    <div class="grid gap-4 md:grid-cols-2">
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-2">Prevent Reuse (last N passwords)</label>
                            <input type="number" asp-for="PreventReuse" min="0" max="24"
                                   class="w-full rounded-lg border border-slate-300 px-4 py-2.5 text-sm focus:ring-2 focus:ring-brand-500/20 focus:border-brand-500 transition-all" />
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-2">Max Age (days)</label>
                            <input type="number" asp-for="MaxAgeDays" min="0" max="365"
                                   class="w-full rounded-lg border border-slate-300 px-4 py-2.5 text-sm focus:ring-2 focus:ring-brand-500/20 focus:border-brand-500 transition-all" />
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-2">Lockout After (failed attempts)</label>
                            <input type="number" asp-for="LockoutThreshold" min="0" max="20"
                                   class="w-full rounded-lg border border-slate-300 px-4 py-2.5 text-sm focus:ring-2 focus:ring-brand-500/20 focus:border-brand-500 transition-all" />
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-2">Lockout Duration (minutes)</label>
                            <input type="number" asp-for="LockoutDurationMinutes" min="1" max="1440"
                                   class="w-full rounded-lg border border-slate-300 px-4 py-2.5 text-sm focus:ring-2 focus:ring-brand-500/20 focus:border-brand-500 transition-all" />
                        </div>
                    </div>

                    <div class="pt-4">
                        <button type="submit" class="rounded-lg bg-brand-600 px-6 py-2.5 text-sm font-semibold text-white hover:bg-brand-700 transition-colors shadow-sm">
                            Save Policy
                        </button>
                    </div>
                </div>
            </form>
        </div>

        <!-- Current Policy Preview -->
        <div>
            <div class="card p-6">
                <h2 class="text-lg font-semibold text-slate-900 mb-4">Current Policy Rules</h2>
                @if (Model.PolicyRules.Any())
                {
                    <ul class="space-y-3">
                        @foreach (var rule in Model.PolicyRules)
                        {
                            <li class="flex items-start gap-2 text-sm text-slate-600">
                                <svg class="w-4 h-4 text-brand-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                                </svg>
                                @rule
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-sm text-slate-500">No policy rules configured.</p>
                }
            </div>
        </div>
    </div>
</div>
