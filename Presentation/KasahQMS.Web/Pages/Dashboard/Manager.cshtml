@page
@model KasahQMS.Web.Pages.Dashboard.ManagerModel
@{
    ViewData["Title"] = "Manager Dashboard";
}

<div class="space-y-8 animate-fade-in">
    <section class="relative overflow-hidden rounded-2xl">
        <img src="https://images.unsplash.com/photo-1497215842964-222b430dc094?w=1600&q=80" alt="Modern meeting room" class="absolute inset-0 h-full w-full object-cover" loading="eager" />
        <div class="absolute inset-0 bg-gradient-to-r from-slate-950/85 via-slate-900/70 to-brand-900/50"></div>
        <div class="relative px-6 py-10 lg:px-10 lg:py-12">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-brand-200">Department Oversight</p>
            <h1 class="mt-3 text-3xl font-bold tracking-tight text-white lg:text-4xl">@Model.DepartmentName Dashboard</h1>
            <p class="mt-2 text-sm text-slate-200">Welcome back, @Model.DisplayName | @Model.CurrentDate</p>
            <div class="mt-6 flex flex-wrap gap-3">
                <a href="/Tasks/Create" class="inline-flex items-center rounded-xl border border-white/30 bg-white/10 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-white/20">Create Task</a>
                <a href="/Documents?status=PendingApproval" class="inline-flex items-center rounded-xl border border-brand-300/40 bg-brand-500/20 px-4 py-2.5 text-sm font-semibold text-brand-100 transition hover:bg-brand-500/30">Review Approvals</a>
            </div>
        </div>
    </section>

    <section class="grid gap-5 sm:grid-cols-2 xl:grid-cols-4">
        @foreach (var stat in Model.Stats)
        {
            <a href="@stat.Link" class="card p-6 card-hover block">
                <p class="text-xs font-semibold uppercase tracking-wider text-slate-400">@stat.Title</p>
                <p class="mt-3 text-3xl font-bold text-slate-900" data-count-to="@stat.CountTo">0</p>
                <p class="mt-1 text-sm text-slate-500">@stat.Subtitle</p>
            </a>
        }
    </section>

    <section>
        <h2 class="text-lg font-semibold text-slate-900">Quick Actions</h2>
        <div class="mt-4 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
            <a href="/Documents/Create" class="card card-hover p-5"><p class="font-semibold text-slate-800">Create Document</p><p class="mt-1 text-sm text-slate-500">Publish team guidance</p></a>
            <a href="/Tasks/Create" class="card card-hover p-5"><p class="font-semibold text-slate-800">Assign Task</p><p class="mt-1 text-sm text-slate-500">Delegate to team members</p></a>
            <a href="/Capa" class="card card-hover p-5"><p class="font-semibold text-slate-800">Manage CAPA</p><p class="mt-1 text-sm text-slate-500">Track remediation progress</p></a>
            <a href="/Risk" class="card card-hover p-5"><p class="font-semibold text-slate-800">Risk Register</p><p class="mt-1 text-sm text-slate-500">Monitor department risk</p></a>
        </div>
    </section>

    <section class="grid gap-6 xl:grid-cols-3">
        <div class="card p-6 xl:col-span-2">
            <div class="mb-5 flex items-center justify-between"><h3 class="text-lg font-semibold text-slate-900">Team Tasks</h3><a href="/Tasks" class="text-sm font-medium text-brand-600">View all</a></div>
            <div class="space-y-3">
                @if (Model.Tasks.Any())
                {
                    @foreach (var task in Model.Tasks)
                    {
                        <div class="rounded-xl border border-slate-200 px-4 py-3">
                            <p class="text-sm font-semibold text-slate-800">@task.Title</p>
                            <p class="text-xs text-slate-500">Due @task.DueDate | @task.Status</p>
                        </div>
                    }
                }
                else
                {
                    <p class="text-sm text-slate-500">No active tasks.</p>
                }
            </div>
        </div>
        <div class="card p-6">
            <h3 class="text-lg font-semibold text-slate-900">Role Widgets</h3>
            <div class="mt-4 space-y-3 text-sm">
                <div class="flex items-center justify-between"><span class="text-slate-500">Team members</span><span class="font-semibold text-slate-800" data-count-to="@Model.TeamMemberCount">0</span></div>
                <div class="flex items-center justify-between"><span class="text-slate-500">Open risks</span><span class="font-semibold text-rose-600" data-count-to="@Model.RiskCount">0</span></div>
                <div class="flex items-center justify-between"><span class="text-slate-500">Pending approvals</span><span class="font-semibold text-amber-600" data-count-to="@Model.PendingApprovalsCount">0</span></div>
            </div>
            <h4 class="mt-6 text-sm font-semibold text-slate-900">Approvals Queue</h4>
            <div class="mt-3 space-y-2">
                @if (Model.PendingApprovals.Any())
                {
                    @foreach (var approval in Model.PendingApprovals)
                    {
                        <div class="rounded-lg border border-slate-200 px-3 py-2">
                            <p class="text-xs font-medium text-slate-700">@approval.Title</p>
                            <p class="text-xs text-slate-500">@approval.Owner | @approval.Stage</p>
                        </div>
                    }
                }
                else
                {
                    <p class="text-xs text-slate-500">No pending approvals.</p>
                }
            </div>
        </div>
    </section>

    <section class="grid gap-6 xl:grid-cols-2">
        <div class="card p-6">
            <h3 class="text-lg font-semibold text-slate-900">Recent Activity Timeline</h3>
            <div class="mt-4 space-y-3">
                @if (Model.Activity.Any())
                {
                    @foreach (var item in Model.Activity)
                    {
                        <div class="border-l-2 border-brand-200 pl-3">
                            <p class="text-sm font-semibold text-slate-800">@item.Title</p>
                            <p class="text-xs text-slate-500">@item.Description</p>
                            <p class="text-xs text-slate-400">@item.When</p>
                        </div>
                    }
                }
                else
                {
                    <p class="text-sm text-slate-500">No recent activity.</p>
                }
            </div>
        </div>
        <div class="card p-6">
            <h3 class="text-lg font-semibold text-slate-900">Department Throughput</h3>
            <p class="text-sm text-slate-500">Document trend across the last 6 months</p>
            <div class="mt-4 h-[280px]"><canvas id="documentsTrendChart"></canvas></div>
        </div>
    </section>

    <section class="card p-6">
        <div class="mb-5 flex items-center justify-between">
            <div>
                <h3 class="text-lg font-semibold text-slate-900">Latest News</h3>
                <p class="text-sm text-slate-500">Team-relevant updates and announcements</p>
            </div>
            <a href="/News" class="text-sm font-medium text-brand-600 hover:underline">View all</a>
        </div>
        <div class="grid gap-3 md:grid-cols-2 xl:grid-cols-3">
            @if (Model.LatestNews.Any())
            {
                @foreach (var item in Model.LatestNews)
                {
                    <a href="/News/Details?id=@item.Id" class="group rounded-xl border border-slate-200 bg-gradient-to-br from-white to-brand-50/40 p-4 transition-all duration-300 hover:-translate-y-0.5 hover:border-brand-200 hover:shadow-md">
                        <p class="text-xs font-semibold uppercase tracking-wider text-brand-600">Latest News</p>
                        <p class="mt-2 line-clamp-2 text-sm font-semibold text-slate-900">@item.Title</p>
                        <p class="mt-2 line-clamp-3 text-xs text-slate-600">@item.Summary</p>
                        <p class="mt-3 text-[11px] text-slate-400">@item.PublishedAt</p>
                    </a>
                }
            }
            else
            {
                <p class="text-sm text-slate-500">No published news yet.</p>
            }
        </div>
    </section>
</div>

@if (Model.ShowTrainingWelcome)
{
    <div id="training-welcome-modal" class="fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
        <div class="bg-white rounded-2xl shadow-2xl max-w-lg w-full p-8">
            <div class="flex items-center gap-4 mb-4">
                <div class="w-12 h-12 bg-brand-100 rounded-xl flex items-center justify-center">
                    <svg class="w-6 h-6 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                    </svg>
                </div>
                <div>
                    <h2 class="text-xl font-bold text-slate-900">Welcome to KASAH QMS!</h2>
                    <p class="text-sm text-slate-500">Mandatory manager onboarding training awaits</p>
                </div>
            </div>
            <p class="text-slate-600 text-sm mb-6">
                As a first-time manager, you are required to complete the <strong>system onboarding trainings</strong>
                to guide approvals, delegation, and quality oversight workflows.
            </p>
            <div class="flex gap-3">
                <a href="/Training" class="btn btn-primary flex-1 text-center">Go to Training</a>
                <button onclick="document.getElementById('training-welcome-modal').remove()" class="btn btn-secondary flex-1">Remind Me Later</button>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const countUp = () => document.querySelectorAll('[data-count-to]').forEach(el => {
            const target = Number(el.dataset.countTo || 0); let cur = 0; const step = Math.max(1, Math.ceil(target / 40));
            const timer = setInterval(() => { cur = Math.min(target, cur + step); el.textContent = cur.toLocaleString(); if (cur >= target) clearInterval(timer); }, 20);
        });
        countUp();

        const docsTrend = @Html.Raw(Model.DocumentsTrendJson);
        const docsCtx = document.getElementById('documentsTrendChart');
        if (docsCtx) {
            new Chart(docsCtx, {
                type: 'line',
                data: { labels: docsTrend.labels, datasets: [{ data: docsTrend.values, borderColor: '#0f766e', backgroundColor: 'rgba(15,118,110,.12)', fill: true, tension: .35 }] },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } } }
            });
        }
    </script>
}
