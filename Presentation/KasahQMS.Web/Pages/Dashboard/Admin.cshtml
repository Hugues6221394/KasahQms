@page
@model KasahQMS.Web.Pages.Dashboard.AdminModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="space-y-8 animate-fade-in">
    <section class="relative overflow-hidden rounded-2xl">
        <img src="https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?w=1600&q=80" alt="Enterprise office" class="absolute inset-0 h-full w-full object-cover" loading="eager" />
        <div class="absolute inset-0 bg-gradient-to-r from-slate-950/85 via-slate-900/70 to-brand-900/50"></div>
        <div class="relative px-6 py-10 lg:px-10 lg:py-12">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-brand-200">System Administration</p>
            <h1 class="mt-3 text-3xl font-bold tracking-tight text-white lg:text-4xl">Welcome back, @Model.DisplayName</h1>
            <p class="mt-2 text-sm text-slate-200">@Model.CurrentDate</p>
            <div class="mt-6 flex flex-wrap gap-3">
                <a href="/Users" class="inline-flex items-center rounded-xl border border-white/30 bg-white/10 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-white/20">Manage Users</a>
                <a href="/AuditLogs" class="inline-flex items-center rounded-xl border border-brand-300/40 bg-brand-500/20 px-4 py-2.5 text-sm font-semibold text-brand-100 transition hover:bg-brand-500/30">Audit Logs</a>
            </div>
        </div>
    </section>

    <section class="grid gap-5 sm:grid-cols-2 xl:grid-cols-4">
        <article class="card p-6">
            <p class="text-xs font-semibold uppercase tracking-wider text-slate-400">Total Users</p>
            <p class="mt-3 text-3xl font-bold text-slate-900" data-count-to="@Model.TotalUsersCount">0</p>
            <p class="mt-1 text-sm text-slate-500">@(Model.UserGrowthPercent >= 0 ? "+" : "")@Model.UserGrowthPercent% this month</p>
        </article>
        <article class="card p-6">
            <p class="text-xs font-semibold uppercase tracking-wider text-slate-400">Active Documents</p>
            <p class="mt-3 text-3xl font-bold text-slate-900" data-count-to="@Model.ActiveDocumentsCount">0</p>
            <p class="mt-1 text-sm text-slate-500">System-wide compliance content</p>
        </article>
        <article class="card p-6">
            <p class="text-xs font-semibold uppercase tracking-wider text-slate-400">Open Tasks</p>
            <p class="mt-3 text-3xl font-bold text-slate-900" data-count-to="@Model.OpenTasksCount">0</p>
            <p class="mt-1 text-sm text-slate-500">Operational workload</p>
        </article>
        <article class="card p-6">
            <p class="text-xs font-semibold uppercase tracking-wider text-slate-400">Active Users</p>
            <p class="mt-3 text-3xl font-bold text-slate-900" data-count-to="@Model.ActiveUsersCount">0</p>
            <p class="mt-1 text-sm text-slate-500">Platform engagement</p>
        </article>
    </section>

    <section>
        <h2 class="text-lg font-semibold text-slate-900">Quick Actions</h2>
        <div class="mt-4 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
            <a href="/Documents/Create" class="card card-hover p-5"><p class="font-semibold text-slate-800">Create Document</p><p class="mt-1 text-sm text-slate-500">Start new policy artifact</p></a>
            <a href="/Tasks?action=create" class="card card-hover p-5"><p class="font-semibold text-slate-800">Assign Task</p><p class="mt-1 text-sm text-slate-500">Delegate corrective work</p></a>
            <a href="/Audits/Create" class="card card-hover p-5"><p class="font-semibold text-slate-800">Schedule Audit</p><p class="mt-1 text-sm text-slate-500">Plan internal or external audit</p></a>
            <a href="/Capa/Create" class="card card-hover p-5"><p class="font-semibold text-slate-800">Raise CAPA</p><p class="mt-1 text-sm text-slate-500">Track systemic remediation</p></a>
        </div>
    </section>

    <section class="grid gap-6 xl:grid-cols-5">
        <div class="card p-6 xl:col-span-3">
            <div class="mb-5 flex items-center justify-between">
                <h3 class="text-lg font-semibold text-slate-900">Recent Activity Timeline</h3>
                <a href="/AuditLogs" class="text-sm font-medium text-brand-600">View all</a>
            </div>
            <div class="space-y-4">
                @if (Model.Activity.Any())
                {
                    @foreach (var item in Model.Activity)
                    {
                        <div class="border-l-2 border-brand-200 pl-4">
                            <p class="text-sm font-semibold text-slate-800">@item.Title</p>
                            <p class="text-xs text-slate-500">@item.Description</p>
                            <p class="mt-1 text-xs text-slate-400">@item.When</p>
                        </div>
                    }
                }
                else
                {
                    <p class="text-sm text-slate-500">No recent activity.</p>
                }
            </div>
        </div>
        <div class="space-y-6 xl:col-span-2">
            <div class="card p-6">
                <h3 class="text-lg font-semibold text-slate-900">Role Widgets</h3>
                <div class="mt-4 space-y-3 text-sm">
                    <div class="flex items-center justify-between"><span class="text-slate-500">System health</span><span class="font-semibold text-emerald-600">98%</span></div>
                    <div class="flex items-center justify-between"><span class="text-slate-500">Users active now</span><span class="font-semibold text-slate-800" data-count-to="@Model.ActiveUsersCount">0</span></div>
                    <div class="flex items-center justify-between"><span class="text-slate-500">Open operational tasks</span><span class="font-semibold text-slate-800" data-count-to="@Model.OpenTasksCount">0</span></div>
                </div>
            </div>
            <div class="card p-6">
                <div class="mb-4 flex items-center justify-between"><h3 class="text-lg font-semibold text-slate-900">Recent Users</h3><a href="/Users" class="text-sm font-medium text-brand-600">View</a></div>
                <div class="space-y-3">
                    @if (Model.RecentUsers.Any())
                    {
                        @foreach (var user in Model.RecentUsers)
                        {
                            <div class="rounded-xl border border-slate-200 px-3 py-2.5">
                                <p class="text-sm font-medium text-slate-800">@user.Name</p>
                                <p class="text-xs text-slate-500">@user.Email | @user.Status</p>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-sm text-slate-500">No recent users.</p>
                    }
                </div>
            </div>
        </div>
    </section>

    <section class="grid gap-6 xl:grid-cols-2">
        <div class="card p-6">
            <h3 class="text-lg font-semibold text-slate-900">User Growth</h3>
            <p class="text-sm text-slate-500">Registrations over the last 6 months</p>
            <div class="mt-4 h-[280px]"><canvas id="usersTrendChart"></canvas></div>
        </div>
        <div class="card p-6">
            <h3 class="text-lg font-semibold text-slate-900">Compliance Health Mix</h3>
            <p class="text-sm text-slate-500">Users and document status distribution</p>
            <div class="mt-4 h-[280px]"><canvas id="systemHealthChart"></canvas></div>
        </div>
    </section>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const countUp = () => document.querySelectorAll('[data-count-to]').forEach(el => {
            const target = Number(el.dataset.countTo || 0); let cur = 0; const step = Math.max(1, Math.ceil(target / 40));
            const timer = setInterval(() => { cur = Math.min(target, cur + step); el.textContent = cur.toLocaleString(); if (cur >= target) clearInterval(timer); }, 20);
        });
        countUp();

        const usersTrend = @Html.Raw(Model.UsersTrendJson);
        const systemHealth = @Html.Raw(Model.SystemHealthJson);
        Chart.defaults.color = '#64748b';

        const usersCtx = document.getElementById('usersTrendChart');
        if (usersCtx) {
            new Chart(usersCtx, {
                type: 'line',
                data: { labels: usersTrend.labels, datasets: [{ data: usersTrend.values, borderColor: '#0f766e', backgroundColor: 'rgba(15,118,110,.12)', fill: true, tension: .35 }] },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } } }
            });
        }

        const healthCtx = document.getElementById('systemHealthChart');
        if (healthCtx) {
            new Chart(healthCtx, {
                type: 'doughnut',
                data: { labels: systemHealth.labels, datasets: [{ data: systemHealth.values, backgroundColor: ['#0ea5e9', '#f59e0b', '#10b981', '#ef4444'] }] },
                options: { responsive: true, maintainAspectRatio: false, cutout: '65%' }
            });
        }
    </script>
}
