@page
@model KasahQMS.Web.Pages.Dashboard.StaffModel
@{
    ViewData["Title"] = "My Dashboard";
}

<div class="space-y-8 animate-fade-in">
    <section class="relative overflow-hidden rounded-2xl">
        <img src="https://images.unsplash.com/photo-1497366216548-37526070297c?w=1600&q=80" alt="Workstation" class="absolute inset-0 h-full w-full object-cover" loading="eager" />
        <div class="absolute inset-0 bg-gradient-to-r from-slate-950/85 via-slate-900/70 to-brand-900/50"></div>
        <div class="relative px-6 py-10 lg:px-10 lg:py-12">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-brand-200">Personal Workspace</p>
            <h1 class="mt-3 text-3xl font-bold tracking-tight text-white lg:text-4xl">Welcome, @Model.DisplayName</h1>
            <p class="mt-2 text-sm text-slate-200">@Model.CurrentDate</p>
            <div class="mt-6 flex flex-wrap gap-3">
                <a href="/Documents/Create" class="inline-flex items-center rounded-xl border border-white/30 bg-white/10 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-white/20">New Document</a>
                <a href="/Tasks" class="inline-flex items-center rounded-xl border border-brand-300/40 bg-brand-500/20 px-4 py-2.5 text-sm font-semibold text-brand-100 transition hover:bg-brand-500/30">My Tasks</a>
            </div>
        </div>
    </section>

    <section class="grid gap-5 sm:grid-cols-2 xl:grid-cols-4">
        @foreach (var stat in Model.Stats)
        {
            <article class="card p-6">
                <p class="text-xs font-semibold uppercase tracking-wider text-slate-400">@stat.Title</p>
                <p class="mt-3 text-3xl font-bold text-slate-900" data-count-to="@stat.CountTo">0</p>
                <p class="mt-1 text-sm text-slate-500">@stat.Subtitle</p>
            </article>
        }
    </section>

    <section>
        <h2 class="text-lg font-semibold text-slate-900">Quick Actions</h2>
        <div class="mt-4 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
            <a href="/Documents/Create" class="card card-hover p-5"><p class="font-semibold text-slate-800">Create Document</p><p class="mt-1 text-sm text-slate-500">Draft a new document</p></a>
            <a href="/Documents" class="card card-hover p-5"><p class="font-semibold text-slate-800">My Documents</p><p class="mt-1 text-sm text-slate-500">Track your submissions</p></a>
            <a href="/Tasks" class="card card-hover p-5"><p class="font-semibold text-slate-800">Task Board</p><p class="mt-1 text-sm text-slate-500">Focus on pending work</p></a>
            <a href="/Training" class="card card-hover p-5"><p class="font-semibold text-slate-800">Training</p><p class="mt-1 text-sm text-slate-500">Review assigned learning</p></a>
        </div>
    </section>

    <section class="grid gap-6 xl:grid-cols-3">
        <div class="card p-6 xl:col-span-2">
            <div class="mb-5 flex items-center justify-between"><h3 class="text-lg font-semibold text-slate-900">My Tasks</h3><a href="/Tasks" class="text-sm font-medium text-brand-600">View all</a></div>
            <div class="space-y-3">
                @if (Model.Tasks.Any())
                {
                    @foreach (var task in Model.Tasks)
                    {
                        <div class="rounded-xl border border-slate-200 px-4 py-3">
                            <p class="text-sm font-semibold text-slate-800">@task.Title</p>
                            <p class="text-xs text-slate-500">Due @task.DueDate | @task.Status</p>
                        </div>
                    }
                }
                else
                {
                    <p class="text-sm text-slate-500">No pending tasks.</p>
                }
            </div>
        </div>
        <div class="card p-6">
            <h3 class="text-lg font-semibold text-slate-900">Role Widgets</h3>
            <div class="mt-4 space-y-3 text-sm">
                <div class="flex items-center justify-between"><span class="text-slate-500">Pending approvals</span><span class="font-semibold text-slate-800" data-count-to="@Model.AwaitingApprovalCount">0</span></div>
                <div class="flex items-center justify-between"><span class="text-slate-500">Overdue tasks</span><span class="font-semibold text-rose-600" data-count-to="@Model.OverdueTasksCount">0</span></div>
                <div class="flex items-center justify-between"><span class="text-slate-500">Documents created</span><span class="font-semibold text-slate-800" data-count-to="@Model.MyDocumentsCount">0</span></div>
            </div>
            <h4 class="mt-6 text-sm font-semibold text-slate-900">Training & Compliance</h4>
            <div class="mt-3 space-y-2">
                @if (Model.TrainingItems.Any())
                {
                    @foreach (var item in Model.TrainingItems)
                    {
                        <div class="rounded-lg border border-slate-200 px-3 py-2">
                            <p class="text-xs font-medium text-slate-700">@item.Title</p>
                            <p class="text-xs text-slate-500">@item.Status | @item.DueDate</p>
                        </div>
                    }
                }
                else
                {
                    <p class="text-xs text-slate-500">No training records.</p>
                }
            </div>
        </div>
    </section>

    <section class="grid gap-6 xl:grid-cols-2">
        <div class="card p-6">
            <h3 class="text-lg font-semibold text-slate-900">Recent Activity</h3>
            <div class="mt-4 space-y-3">
                @if (Model.Notifications.Any())
                {
                    @foreach (var note in Model.Notifications)
                    {
                        <div class="border-l-2 border-brand-200 pl-3">
                            <p class="text-sm font-semibold text-slate-800">@note.Title</p>
                            <p class="text-xs text-slate-500">@note.Message</p>
                            <p class="text-xs text-slate-400">@note.When</p>
                        </div>
                    }
                }
                else
                {
                    <p class="text-sm text-slate-500">No recent updates.</p>
                }
            </div>
        </div>
        <div class="card p-6">
            <h3 class="text-lg font-semibold text-slate-900">Workload Snapshot</h3>
            <p class="text-sm text-slate-500">Tasks, approvals and document volume</p>
            <div class="mt-4 h-[280px]"><canvas id="staffWorkChart"></canvas></div>
        </div>
    </section>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const countUp = () => document.querySelectorAll('[data-count-to]').forEach(el => {
            const target = Number(el.dataset.countTo || 0); let cur = 0; const step = Math.max(1, Math.ceil(target / 40));
            const timer = setInterval(() => { cur = Math.min(target, cur + step); el.textContent = cur.toLocaleString(); if (cur >= target) clearInterval(timer); }, 20);
        });
        countUp();

        const ctx = document.getElementById('staffWorkChart');
        if (ctx) {
            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: ['Pending Tasks', 'Overdue Tasks', 'Awaiting Approval', 'My Documents'],
                    datasets: [{ data: [@Model.PendingTasksCount, @Model.OverdueTasksCount, @Model.AwaitingApprovalCount, @Model.MyDocumentsCount], backgroundColor: ['#0ea5e9', '#ef4444', '#f59e0b', '#10b981'], borderRadius: 8 }]
                },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } } }
            });
        }
    </script>
}
