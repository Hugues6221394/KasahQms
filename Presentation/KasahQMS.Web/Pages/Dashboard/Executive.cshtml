@page
@model KasahQMS.Web.Pages.Dashboard.ExecutiveModel
@{
    ViewData["Title"] = "Executive Dashboard";
}

<div class="space-y-8 animate-fade-in">
    <section class="relative overflow-hidden rounded-2xl">
        <img src="https://images.unsplash.com/photo-1504384308090-c894fdcc538d?w=1600&q=80" alt="Executive workspace" class="absolute inset-0 h-full w-full object-cover" loading="eager" />
        <div class="absolute inset-0 bg-gradient-to-r from-slate-950/85 via-slate-900/70 to-brand-900/50"></div>
        <div class="relative px-6 py-10 lg:px-10 lg:py-12">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-brand-200">Strategic Overview</p>
            <h1 class="mt-3 text-3xl font-bold tracking-tight text-white lg:text-4xl">Welcome, @Model.DisplayName</h1>
            <p class="mt-2 text-sm text-slate-200">@Model.CurrentDate</p>
            <div class="mt-6 flex flex-wrap gap-3">
                <a href="/AuditLogs" class="inline-flex items-center rounded-xl border border-white/30 bg-white/10 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-white/20">Audit Logs</a>
                <a href="/Documents?status=pending" class="inline-flex items-center rounded-xl border border-brand-300/40 bg-brand-500/20 px-4 py-2.5 text-sm font-semibold text-brand-100 transition hover:bg-brand-500/30">Approval Queue</a>
            </div>
        </div>
    </section>

    <section class="grid gap-5 sm:grid-cols-2 xl:grid-cols-4">
        @foreach (var stat in Model.Stats)
        {
            <article class="card p-6">
                <p class="text-xs font-semibold uppercase tracking-wider text-slate-400">@stat.Title</p>
                <p class="mt-3 text-3xl font-bold text-slate-900" data-count-to="@stat.CountTo">0</p>
                <p class="mt-1 text-sm text-slate-500">@stat.Subtitle</p>
            </article>
        }
    </section>

    <section>
        <h2 class="text-lg font-semibold text-slate-900">Quick Actions</h2>
        <div class="mt-4 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
            <a href="/Documents/Create" class="card card-hover p-5"><p class="font-semibold text-slate-800">New Document</p><p class="mt-1 text-sm text-slate-500">Issue strategic directives</p></a>
            <a href="/Tasks" class="card card-hover p-5"><p class="font-semibold text-slate-800">Task Oversight</p><p class="mt-1 text-sm text-slate-500">Review enterprise workload</p></a>
            <a href="/Capa" class="card card-hover p-5"><p class="font-semibold text-slate-800">CAPA Portfolio</p><p class="mt-1 text-sm text-slate-500">Mitigate critical findings</p></a>
            <a href="/Audits" class="card card-hover p-5"><p class="font-semibold text-slate-800">Audit Calendar</p><p class="mt-1 text-sm text-slate-500">Monitor upcoming audits</p></a>
        </div>
    </section>

    <section class="grid gap-6 xl:grid-cols-3">
        <div class="card p-6 xl:col-span-2">
            <h3 class="text-lg font-semibold text-slate-900">Performance Trend</h3>
            <p class="text-sm text-slate-500">Documents processed over the last 6 months</p>
            <div class="mt-4 h-[280px]"><canvas id="documentsTrendChart"></canvas></div>
        </div>
        <div class="card p-6">
            <h3 class="text-lg font-semibold text-slate-900">Role Widgets</h3>
            <div class="mt-4 space-y-3 text-sm">
                <div class="flex items-center justify-between"><span class="text-slate-500">Compliance score</span><span class="font-semibold text-emerald-600" data-count-to="@Model.ComplianceScorePercent">0</span></div>
                <div class="flex items-center justify-between"><span class="text-slate-500">SLA adherence</span><span class="font-semibold text-brand-700" data-count-to="@Model.SlaPercent">0</span></div>
                <div class="flex items-center justify-between"><span class="text-slate-500">Risk hotspots</span><span class="font-semibold text-rose-600" data-count-to="@Model.OverdueItemsCount">0</span></div>
            </div>
            <h4 class="mt-6 text-sm font-semibold text-slate-900">Critical Items</h4>
            <div class="mt-3 space-y-2">
                @if (Model.CriticalItems.Any())
                {
                    @foreach (var item in Model.CriticalItems)
                    {
                        <div class="rounded-lg border border-slate-200 px-3 py-2">
                            <p class="text-xs font-medium text-slate-700">@item.Title</p>
                            <p class="text-xs text-slate-500">@item.Type | @item.Severity | @item.DueDate</p>
                        </div>
                    }
                }
                else
                {
                    <p class="text-xs text-slate-500">No critical items.</p>
                }
            </div>
        </div>
    </section>

    <section class="grid gap-6 xl:grid-cols-2">
        <div class="card p-6">
            <div class="mb-5 flex items-center justify-between"><h3 class="text-lg font-semibold text-slate-900">Approvals Queue</h3><a href="/Documents?status=pending" class="text-sm font-medium text-brand-600">View all</a></div>
            <div class="space-y-3">
                @if (Model.PendingApprovals.Any())
                {
                    @foreach (var approval in Model.PendingApprovals)
                    {
                        <div class="rounded-xl border border-slate-200 px-4 py-3">
                            <p class="text-sm font-semibold text-slate-800">@approval.Title</p>
                            <p class="text-xs text-slate-500">@approval.Owner | @approval.Stage</p>
                        </div>
                    }
                }
                else
                {
                    <p class="text-sm text-slate-500">No pending approvals.</p>
                }
            </div>
        </div>
        <div class="card p-6">
            <h3 class="text-lg font-semibold text-slate-900">Recent Activity Timeline</h3>
            <div class="mt-4 space-y-3">
                @if (Model.Activity.Any())
                {
                    @foreach (var item in Model.Activity)
                    {
                        <div class="border-l-2 border-brand-200 pl-3">
                            <p class="text-sm font-semibold text-slate-800">@item.Title</p>
                            <p class="text-xs text-slate-500">@item.Description</p>
                            <p class="text-xs text-slate-400">@item.When</p>
                        </div>
                    }
                }
                else
                {
                    <p class="text-sm text-slate-500">No recent activity.</p>
                }
            </div>
        </div>
    </section>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const countUp = () => document.querySelectorAll('[data-count-to]').forEach(el => {
            const target = Number(el.dataset.countTo || 0); let cur = 0; const step = Math.max(1, Math.ceil(target / 40));
            const timer = setInterval(() => { cur = Math.min(target, cur + step); el.textContent = cur.toLocaleString(); if (cur >= target) clearInterval(timer); }, 20);
        });
        countUp();

        const docsTrend = @Html.Raw(Model.DocumentsTrendJson);
        const docsCtx = document.getElementById('documentsTrendChart');
        if (docsCtx) {
            new Chart(docsCtx, {
                type: 'line',
                data: { labels: docsTrend.labels, datasets: [{ data: docsTrend.values, borderColor: '#0f766e', backgroundColor: 'rgba(15,118,110,.12)', fill: true, tension: .35 }] },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } } }
            });
        }
    </script>
}
