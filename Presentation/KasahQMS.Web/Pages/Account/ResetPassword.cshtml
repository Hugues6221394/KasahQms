@page
@model KasahQMS.Web.Pages.Account.ResetPasswordModel
@{
    ViewData["Title"] = "Reset Password";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - KASAH QMS</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="h-full font-sans antialiased bg-slate-50 flex items-center justify-center p-4">
    <div class="w-full max-w-md">
        <div class="bg-white rounded-2xl shadow-lg border border-slate-200 p-8">
            <div class="flex items-center gap-3 mb-6">
                <div class="w-10 h-10 bg-emerald-600 rounded-xl flex items-center justify-center">
                    <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                    </svg>
                </div>
                <div>
                    <h1 class="text-xl font-bold text-slate-900">Reset Password</h1>
                    <p class="text-sm text-slate-500">KASAH QMS</p>
                </div>
            </div>

            @if (Model.Success)
            {
                <div class="p-4 bg-emerald-50 border border-emerald-200 rounded-xl text-emerald-800 text-sm mb-6">
                    <strong>Password updated!</strong> You can now sign in with your new password.
                </div>
                <a href="/Account/Login" class="block w-full text-center rounded-xl bg-emerald-600 py-3 text-sm font-semibold text-white hover:bg-emerald-700 transition-colors">
                    Sign In
                </a>
            }
            else if (!string.IsNullOrWhiteSpace(Model.ErrorMessage) && !Model.TokenValid)
            {
                <div class="p-4 bg-red-50 border border-red-200 rounded-xl text-red-700 text-sm mb-6">
                    @Model.ErrorMessage
                </div>
                <a href="/Account/ForgotPassword" class="block w-full text-center rounded-xl border border-slate-200 py-3 text-sm font-medium text-slate-700 hover:bg-slate-50 transition-colors">
                    Request New Reset Link
                </a>
            }
            else
            {
                <p class="text-sm text-slate-600 mb-6">Enter your new password below.</p>

                @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                {
                    <div class="p-3 bg-red-50 border border-red-200 rounded-lg text-red-700 text-sm mb-4">@Model.ErrorMessage</div>
                }

                <form method="post" class="space-y-4">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Token" />

                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1.5">New Password</label>
                        <input type="password" asp-for="NewPassword" required minlength="6"
                               class="w-full rounded-xl border border-slate-300 px-4 py-3 text-sm focus:border-emerald-500 focus:ring-2 focus:ring-emerald-100 outline-none transition-all"
                               placeholder="At least 6 characters" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1.5">Confirm Password</label>
                        <input type="password" asp-for="ConfirmPassword" required
                               class="w-full rounded-xl border border-slate-300 px-4 py-3 text-sm focus:border-emerald-500 focus:ring-2 focus:ring-emerald-100 outline-none transition-all"
                               placeholder="Repeat your new password" />
                    </div>

                    <button type="submit" class="w-full rounded-xl bg-emerald-600 py-3 text-sm font-semibold text-white hover:bg-emerald-700 transition-colors">
                        Set New Password
                    </button>
                </form>
            }
        </div>
    </div>
</body>
</html>
