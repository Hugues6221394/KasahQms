@page
@model KasahQMS.Web.Pages.Employees.IndexModel
@{
    ViewData["Title"] = "Employee Activity";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="py-8">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 space-y-6">
        <section class="relative overflow-hidden rounded-2xl border border-slate-200 bg-slate-900 text-white" style="background-image:linear-gradient(120deg,rgba(2,6,23,.88),rgba(16,185,129,.45)),url('https://images.unsplash.com/photo-1522071820081-009f0129c71c?auto=format&fit=crop&w=1600&q=80');background-size:cover;background-position:center;">
            <div class="p-6 md:p-8">
                <p class="text-xs uppercase tracking-[0.2em] text-emerald-100">Performance</p>
                <h1 class="mt-2 text-3xl font-bold">Employee Activity</h1>
                <p class="mt-2 text-emerald-100">Track team performance and engagement over the past 7 days</p>
            </div>
        </section>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="rounded-lg bg-red-50 border border-red-200 p-4">
                <div class="flex items-center">
                    <svg class="w-5 h-5 text-red-600 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    <p class="text-sm font-medium text-red-800">@Model.ErrorMessage</p>
                </div>
            </div>
        }

        @if (Model.CanView && Model.TopPerformers.Any())
        {
            <div class="card p-6">
                <h2 class="text-xl font-bold text-slate-900 mb-4">🏆 Top Performers This Week</h2>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                    @for (int i = 0; i < Model.TopPerformers.Count && i < 3; i++)
                    {
                        var performer = Model.TopPerformers[i];
                        var medal = i == 0 ? "🥇" : i == 1 ? "🥈" : "🥉";
                        var bgColor = i == 0 ? "bg-amber-50 border-amber-200" : i == 1 ? "bg-slate-50 border-slate-200" : "bg-orange-50 border-orange-200";
                        
                        <div class="rounded-xl border-2 @bgColor p-5">
                            <div class="flex items-center justify-between mb-3">
                                <span class="text-3xl">@medal</span>
                                <span class="text-2xl font-bold text-brand-600">@performer.ActivityScore</span>
                            </div>
                            <h3 class="font-bold text-slate-900">@performer.Name</h3>
                            <p class="text-sm text-slate-600">@performer.JobTitle</p>
                            <div class="mt-3 pt-3 border-t border-slate-200 space-y-1 text-xs text-slate-600">
                                <div class="flex justify-between">
                                    <span>Tasks:</span>
                                    <span class="font-medium">@performer.TasksCompleted</span>
                                </div>
                                <div class="flex justify-between">
                                    <span>Documents:</span>
                                    <span class="font-medium">@performer.DocumentsCreated</span>
                                </div>
                                <div class="flex justify-between">
                                    <span>Activity:</span>
                                    <span class="font-medium">@performer.AuditEntries</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        @if (Model.CanView && Model.Employees.Any())
        {
            var maxScore = Model.Employees.Max(e => e.ActivityScore);
            if (maxScore == 0) maxScore = 1; // Prevent division by zero

            <div class="card p-6">
                <h2 class="text-xl font-bold text-slate-900 mb-4">Activity Chart</h2>
                <canvas id="activityChart" style="max-height: 400px;"></canvas>
            </div>

            <div class="card overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-slate-200">
                        <thead class="bg-slate-50">
                            <tr>
                                <th class="px-6 py-4 text-left text-xs font-semibold text-slate-600 uppercase tracking-wider">Employee</th>
                                <th class="px-6 py-4 text-left text-xs font-semibold text-slate-600 uppercase tracking-wider">Department</th>
                                <th class="px-6 py-4 text-left text-xs font-semibold text-slate-600 uppercase tracking-wider">Tasks</th>
                                <th class="px-6 py-4 text-left text-xs font-semibold text-slate-600 uppercase tracking-wider">Documents</th>
                                <th class="px-6 py-4 text-left text-xs font-semibold text-slate-600 uppercase tracking-wider">Activity</th>
                                <th class="px-6 py-4 text-left text-xs font-semibold text-slate-600 uppercase tracking-wider">Score</th>
                                <th class="px-6 py-4 text-left text-xs font-semibold text-slate-600 uppercase tracking-wider">Last Login</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-slate-100">
                            @foreach (var emp in Model.Employees)
                            {
                                var percentage = maxScore > 0 ? (int)((double)emp.ActivityScore / maxScore * 100) : 0;
                                
                                <tr class="hover:bg-slate-50 transition-colors">
                                    <td class="px-6 py-4">
                                        <div>
                                            <div class="text-sm font-semibold text-slate-900">@emp.Name</div>
                                            <div class="text-sm text-slate-500">@emp.JobTitle</div>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 text-sm text-slate-600">@emp.Department</td>
                                    <td class="px-6 py-4 text-sm font-medium text-slate-900">@emp.TasksCompleted</td>
                                    <td class="px-6 py-4 text-sm font-medium text-slate-900">@emp.DocumentsCreated</td>
                                    <td class="px-6 py-4 text-sm font-medium text-slate-900">@emp.AuditEntries</td>
                                    <td class="px-6 py-4">
                                        <div class="flex items-center gap-3">
                                            <span class="text-sm font-bold text-brand-600">@emp.ActivityScore</span>
                                            <div class="flex-1 max-w-[100px]">
                                                <div class="w-full bg-slate-200 rounded-full h-2">
                                                    <div class="bg-brand-600 h-2 rounded-full" style="width: @percentage%"></div>
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 text-sm text-slate-500">
                                        @if (emp.LastLogin.HasValue)
                                        {
                                            @emp.LastLogin.Value.ToString("MMM dd, yyyy")
                                        }
                                        else
                                        {
                                            <span class="text-slate-400">Never</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="px-6 py-4 border-t border-slate-200 text-sm text-slate-500">
                    Showing <span class="font-medium">@Model.Employees.Count</span> employees
                </div>
            </div>
        }
        else if (Model.CanView && !Model.Employees.Any())
        {
            <div class="card p-12 text-center">
                <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-slate-100 flex items-center justify-center">
                    <svg class="w-8 h-8 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
                    </svg>
                </div>
                <h3 class="text-lg font-medium text-slate-900 mb-1">No employee data</h3>
                <p class="text-sm text-slate-500">No employees found for the current period.</p>
            </div>
        }
    </div>
</div>

@if (Model.CanView && Model.Employees.Any())
{
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>
    <script>
        (function() {
            var topEmployees = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Employees.Take(10).Select(e => new { name = e.Name, score = e.ActivityScore })));
            
            var ctx = document.getElementById('activityChart');
            if (ctx) {
                new Chart(ctx, {
                    type: 'bar',
                    data: {
                        labels: topEmployees.map(e => e.name),
                        datasets: [{
                            label: 'Activity Score',
                            data: topEmployees.map(e => e.score),
                            backgroundColor: 'rgba(16, 185, 129, 0.8)',
                            borderColor: 'rgba(16, 185, 129, 1)',
                            borderWidth: 1
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: true,
                        plugins: {
                            legend: {
                                display: false
                            },
                            title: {
                                display: true,
                                text: 'Top 10 Employees by Activity Score (Last 7 Days)',
                                font: {
                                    size: 16,
                                    weight: 'bold'
                                }
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                ticks: {
                                    stepSize: 1
                                }
                            }
                        }
                    }
                });
            }
        })();
    </script>
}
