@page
@model KasahQMS.Web.Pages.Capa.IndexModel
@removeTagHelper "Microsoft.AspNetCore.Mvc.Razor.TagHelpers.OptionTagHelper", "Microsoft.AspNetCore.Mvc.Razor"
@{
    ViewData["Title"] = "CAPA";
}

<div class="space-y-6">
    <section class="relative overflow-hidden rounded-2xl border border-slate-200 bg-slate-900 text-white animate-on-scroll" style="background-image:linear-gradient(120deg,rgba(2,6,23,.9),rgba(22,163,74,.45)),url('https://images.unsplash.com/photo-1450101499163-c8848c66ca85?auto=format&fit=crop&w=1600&q=80');background-size:cover;background-position:center;">
        <div class="p-6 md:p-8 flex flex-col lg:flex-row lg:items-end lg:justify-between gap-5">
            <div><p class="text-xs uppercase tracking-[0.2em] text-emerald-100">Continuous Improvement</p><h1 class="mt-2 text-3xl font-bold">Corrective &amp; Preventive Actions</h1><p class="mt-2 text-emerald-100">Track and manage CAPA records for continuous improvement.</p></div>
            <a href="/Capa/Create" class="inline-flex items-center rounded-xl bg-white px-4 py-2.5 text-sm font-semibold text-slate-900 hover:bg-slate-100">Initiate CAPA</a>
        </div>
    </section>

    <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-6">
        <div class="card p-4 animate-on-scroll"><div class="text-xs text-slate-500 uppercase">Draft</div><div class="mt-2 text-2xl font-bold text-slate-900">@Model.DraftCount</div></div>
        <div class="card p-4 animate-on-scroll"><div class="text-xs text-slate-500 uppercase">Investigation</div><div class="mt-2 text-2xl font-bold text-amber-600">@Model.UnderInvestigationCount</div></div>
        <div class="card p-4 animate-on-scroll"><div class="text-xs text-slate-500 uppercase">Defined</div><div class="mt-2 text-2xl font-bold text-blue-600">@Model.ActionsDefinedCount</div></div>
        <div class="card p-4 animate-on-scroll"><div class="text-xs text-slate-500 uppercase">Implemented</div><div class="mt-2 text-2xl font-bold text-indigo-600">@Model.ActionsImplementedCount</div></div>
        <div class="card p-4 animate-on-scroll"><div class="text-xs text-slate-500 uppercase">Verified</div><div class="mt-2 text-2xl font-bold text-emerald-600">@Model.VerifiedCount</div></div>
        <div class="card p-4 animate-on-scroll"><div class="text-xs text-slate-500 uppercase">Closed</div><div class="mt-2 text-2xl font-bold text-green-600">@Model.ClosedCount</div></div>
    </div>

    <div class="card p-4 md:p-5 animate-on-scroll">
        <form method="get" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-12 gap-4 items-end">
            <div class="xl:col-span-5"><label class="block text-sm font-medium text-slate-700 mb-1">Search</label><input type="search" name="search" value="@Model.SearchTerm" placeholder="Search CAPAs..." class="w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:ring-2 focus:ring-brand-200 focus:border-brand-400"></div>
            <div class="xl:col-span-3"><label class="block text-sm font-medium text-slate-700 mb-1">Status</label><select name="status" class="w-full px-3 py-2.5 border border-slate-300 rounded-lg focus:ring-2 focus:ring-brand-200 focus:border-brand-400"><option value="">All</option><option value="Draft" selected="@(Model.Status == "Draft")">Draft</option><option value="UnderInvestigation" selected="@(Model.Status == "UnderInvestigation")">Under Investigation</option><option value="ActionsDefined" selected="@(Model.Status == "ActionsDefined")">Actions Defined</option><option value="ActionsImplemented" selected="@(Model.Status == "ActionsImplemented")">Actions Implemented</option><option value="EffectivenessVerified" selected="@(Model.Status == "EffectivenessVerified")">Effectiveness Verified</option><option value="Closed" selected="@(Model.Status == "Closed")">Closed</option></select></div>
            <div class="xl:col-span-2"><label class="block text-sm font-medium text-slate-700 mb-1">Priority</label><select name="priority" class="w-full px-3 py-2.5 border border-slate-300 rounded-lg focus:ring-2 focus:ring-brand-200 focus:border-brand-400"><option value="">All</option><option value="Critical" selected="@(Model.Priority == "Critical")">Critical</option><option value="High" selected="@(Model.Priority == "High")">High</option><option value="Medium" selected="@(Model.Priority == "Medium")">Medium</option><option value="Low" selected="@(Model.Priority == "Low")">Low</option></select></div>
            <div class="xl:col-span-2 flex gap-2"><button type="submit" class="w-full px-4 py-2.5 bg-brand-600 text-white font-medium rounded-lg hover:bg-brand-700">Filter</button><a href="/Capa" class="px-4 py-2.5 text-slate-600 hover:text-slate-900 font-medium">Clear</a></div>
        </form>
    </div>

    <div class="card overflow-hidden animate-on-scroll">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-200 text-sm">
                <thead class="bg-slate-50 text-slate-500 uppercase text-xs"><tr><th class="px-6 py-4 text-left font-semibold">CAPA</th><th class="px-6 py-4 text-left font-semibold">Type</th><th class="px-6 py-4 text-left font-semibold">Priority</th><th class="px-6 py-4 text-left font-semibold">Status</th><th class="px-6 py-4 text-left font-semibold">Owner</th><th class="px-6 py-4 text-left font-semibold">Visibility</th><th class="px-6 py-4 text-left font-semibold">Due</th><th class="px-6 py-4 text-right font-semibold">Action</th></tr></thead>
                <tbody class="divide-y divide-slate-100 bg-white">
                    @if (!Model.Capas.Any())
                    {
                        <tr><td colspan="8" class="px-6 py-14 text-center"><div class="mx-auto w-14 h-14 rounded-full bg-slate-100 flex items-center justify-center mb-3"><svg class="w-7 h-7 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8V7m0 1v8m0 0v1"/></svg></div><p class="text-sm font-medium text-slate-700">No CAPA records found</p></td></tr>
                    }
                    else
                    {
                        @foreach (var item in Model.Capas)
                        {
                            <tr class="hover:bg-slate-50 transition-colors"><td class="px-6 py-4"><div class="font-semibold text-slate-800">@item.Title</div><div class="text-xs text-slate-500">@item.Number</div></td><td class="px-6 py-4 text-slate-600">@item.Type</td><td class="px-6 py-4"><span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium @item.PriorityClass">@item.Priority</span></td><td class="px-6 py-4"><span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium @item.StatusClass">@item.Status</span></td><td class="px-6 py-4 text-slate-600">@item.Owner</td><td class="px-6 py-4 text-slate-600">@item.Visibility</td><td class="px-6 py-4 text-slate-600">@item.DueDate</td><td class="px-6 py-4 text-right"><a asp-page="/Capa/Details" asp-route-id="@item.Id" class="text-brand-600 hover:text-brand-700 text-sm font-medium">View</a></td></tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
