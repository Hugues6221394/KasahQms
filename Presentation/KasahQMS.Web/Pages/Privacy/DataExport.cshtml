@page
@model KasahQMS.Web.Pages.Privacy.DataExportModel
@{
    ViewData["Title"] = "Data Exports";
}

<div class="space-y-8">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
        <div>
            <h1 class="text-2xl font-semibold text-slate-900">Data Exports</h1>
            <p class="text-sm text-slate-500">Track your personal data export requests. Downloads are delivered as Excel-compatible CSV files in a ZIP package.</p>
        </div>
        <a href="/Privacy" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50 transition-colors inline-flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
            </svg>
            Back to Privacy Center
        </a>
    </div>

    <div class="card p-6">
        <div class="mb-5 grid gap-3 sm:grid-cols-2 xl:grid-cols-5">
            <div class="rounded-lg border border-slate-200 bg-slate-50 p-3">
                <p class="text-[11px] uppercase tracking-wider text-slate-500">Documents</p>
                <p class="mt-1 text-xl font-semibold text-slate-900">@Model.Preview.Documents</p>
            </div>
            <div class="rounded-lg border border-slate-200 bg-slate-50 p-3">
                <p class="text-[11px] uppercase tracking-wider text-slate-500">Tasks + CAPAs</p>
                <p class="mt-1 text-xl font-semibold text-slate-900">@(Model.Preview.Tasks + Model.Preview.Capas)</p>
            </div>
            <div class="rounded-lg border border-slate-200 bg-slate-50 p-3">
                <p class="text-[11px] uppercase tracking-wider text-slate-500">Audits + Trainings</p>
                <p class="mt-1 text-xl font-semibold text-slate-900">@(Model.Preview.Audits + Model.Preview.Trainings)</p>
            </div>
            <div class="rounded-lg border border-slate-200 bg-slate-50 p-3">
                <p class="text-[11px] uppercase tracking-wider text-slate-500">Messages + Notifications</p>
                <p class="mt-1 text-xl font-semibold text-slate-900">@(Model.Preview.ChatMessages + Model.Preview.Notifications)</p>
            </div>
            <div class="rounded-lg border border-brand-200 bg-brand-50 p-3">
                <p class="text-[11px] uppercase tracking-wider text-brand-600">Total Preview Records</p>
                <p class="mt-1 text-xl font-semibold text-brand-800">@Model.Preview.TotalRecords</p>
            </div>
        </div>

        @if (Model.Exports.Any())
        {
            <div class="overflow-hidden rounded-lg border border-slate-200">
                <table class="min-w-full divide-y divide-slate-200 text-sm">
                    <thead class="bg-slate-50 text-slate-500 uppercase text-xs">
                        <tr>
                            <th class="px-4 py-3 text-left font-semibold">Requested</th>
                            <th class="px-4 py-3 text-left font-semibold">Status</th>
                            <th class="px-4 py-3 text-left font-semibold">Completed</th>
                            <th class="px-4 py-3 text-left font-semibold">Expires</th>
                            <th class="px-4 py-3 text-left font-semibold">Preview Records</th>
                            <th class="px-4 py-3 text-right font-semibold">Download</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100 bg-white">
                        @foreach (var export in Model.Exports)
                        {
                            <tr>
                                <td class="px-4 py-3 text-slate-600">@export.RequestedAt.ToString("MMM dd, yyyy HH:mm")</td>
                                <td class="px-4 py-3">
                                    @{
                                        var badgeClass = export.Status switch
                                        {
                                            "Completed" => "bg-brand-100 text-brand-700",
                                            "Processing" => "bg-blue-100 text-blue-700",
                                            "Failed" => "bg-accent-100 text-accent-700",
                                            _ => "bg-slate-100 text-slate-600"
                                        };
                                    }
                                    <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium @badgeClass">@export.Status</span>
                                </td>
                                <td class="px-4 py-3 text-slate-600">@(export.CompletedAt?.ToString("MMM dd, yyyy HH:mm") ?? "-")</td>
                                <td class="px-4 py-3 text-slate-600">@(export.ExpiresAt?.ToString("MMM dd, yyyy") ?? "-")</td>
                                <td class="px-4 py-3 text-slate-700 font-medium">@export.TotalRecords</td>
                                <td class="px-4 py-3 text-right">
                                    @if (!string.IsNullOrEmpty(export.DownloadUrl) && export.Status == "Completed" && (export.ExpiresAt == null || export.ExpiresAt > DateTime.UtcNow))
                                    {
                                        <a href="@export.DownloadUrl" class="rounded-lg bg-brand-600 px-3 py-1.5 text-xs font-semibold text-white hover:bg-brand-700 transition-colors inline-flex items-center gap-1.5">
                                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                                            </svg>
                                            Download
                                        </a>
                                    }
                                    else if (export.Status == "Completed" && export.ExpiresAt != null && export.ExpiresAt <= DateTime.UtcNow)
                                    {
                                        <span class="text-xs text-slate-400">Expired</span>
                                    }
                                    else
                                    {
                                        <span class="text-xs text-slate-400">-</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-12">
                <svg class="w-12 h-12 text-slate-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
                <p class="text-sm text-slate-500 mb-4">No data export requests yet.</p>
                <a href="/Privacy" class="text-sm font-medium text-brand-600 hover:text-brand-700 transition-colors">
                    Request an export from the Privacy Center →
                </a>
            </div>
        }
    </div>
</div>
