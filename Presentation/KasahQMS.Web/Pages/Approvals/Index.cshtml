@page
@model KasahQMS.Web.Pages.Approvals.IndexModel
@{
    ViewData["Title"] = "Pending Approvals";
}

<div class="space-y-6">
    <div class="rounded-2xl border border-slate-200 bg-white p-6">
        <h1 class="text-3xl font-semibold text-slate-900">Pending Approvals</h1>
        <p class="mt-1 text-sm text-slate-500">Review and action submissions for tasks, documents, and trainings.</p>
    </div>

    <div class="rounded-2xl border border-slate-200 bg-white p-6 space-y-4">
        <div class="flex items-center justify-between gap-3 flex-wrap">
            <h2 class="text-lg font-semibold text-slate-900">Document Approval History</h2>
            <span class="text-sm text-slate-500">@Model.DocumentApprovalHistory.Count records</span>
        </div>
        <form method="get" class="grid grid-cols-1 md:grid-cols-5 gap-3 items-end">
            <div>
                <label class="block text-xs font-medium text-slate-600 mb-1">Action</label>
                <select name="HistoryFilterAction" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm">
                    <option value="">All</option>
                    <option value="DOCUMENT_SUBMITTED" selected="@(Model.HistoryFilterAction == "DOCUMENT_SUBMITTED")">Pending approval entered</option>
                    <option value="DOCUMENT_APPROVED_PARTIAL" selected="@(Model.HistoryFilterAction == "DOCUMENT_APPROVED_PARTIAL")">Partial approval</option>
                    <option value="DOCUMENT_APPROVED_FINAL" selected="@(Model.HistoryFilterAction == "DOCUMENT_APPROVED_FINAL")">Final approval</option>
                    <option value="DOCUMENT_REJECTED" selected="@(Model.HistoryFilterAction == "DOCUMENT_REJECTED")">Rejected</option>
                    <option value="DOCUMENT_RETURNED_WITH_REVISION" selected="@(Model.HistoryFilterAction == "DOCUMENT_RETURNED_WITH_REVISION")">Returned with revision</option>
                </select>
            </div>
            <div>
                <label class="block text-xs font-medium text-slate-600 mb-1">Text</label>
                <input type="text" name="HistoryFilterText" value="@Model.HistoryFilterText" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm" placeholder="Search description..." />
            </div>
            <div>
                <label class="block text-xs font-medium text-slate-600 mb-1">From</label>
                <input type="date" name="HistoryFrom" value="@(Model.HistoryFrom?.ToString("yyyy-MM-dd"))" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm" />
            </div>
            <div>
                <label class="block text-xs font-medium text-slate-600 mb-1">To</label>
                <input type="date" name="HistoryTo" value="@(Model.HistoryTo?.ToString("yyyy-MM-dd"))" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm" />
            </div>
            <div class="flex gap-2">
                <button type="submit" class="px-4 py-2 bg-slate-900 text-white rounded-lg text-sm">Filter</button>
                <a href="/Approvals" class="px-4 py-2 border border-slate-300 rounded-lg text-sm text-slate-700">Clear</a>
            </div>
        </form>
        @if (Model.DocumentApprovalHistory.Any())
        {
            <div class="space-y-2">
                @foreach (var h in Model.DocumentApprovalHistory)
                {
                    <div class="rounded-lg border border-slate-200 p-3 bg-slate-50">
                        <div class="flex items-start justify-between gap-3">
                            <div>
                                <p class="text-sm font-semibold text-slate-900">@h.Action</p>
                                <p class="text-xs text-slate-500">@h.Timestamp.ToString("MMM dd, yyyy HH:mm")</p>
                                <p class="text-sm text-slate-700 mt-1">@h.Description</p>
                                @if (h.DocumentId.HasValue)
                                {
                                    <a href="/Documents/Details/@h.DocumentId" class="text-xs text-brand-600 hover:text-brand-700">Open document</a>
                                }
                            </div>
                            @{
                                var canManageHistory = Model.IsExecutiveUser || (Model.CurrentUserId.HasValue && h.UserId == Model.CurrentUserId.Value);
                            }
                            @if (canManageHistory)
                            {
                                <div class="flex gap-2">
                                    <form method="post" asp-page-handler="ArchiveHistory" class="inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="HistoryEntryId" value="@h.Id" />
                                        <button type="submit" class="px-3 py-1.5 text-xs rounded-lg border border-slate-300 text-slate-700 hover:bg-slate-100">Archive</button>
                                    </form>
                                    <form method="post" asp-page-handler="DeleteHistory" class="inline" onsubmit="return confirm('Delete this history entry?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="HistoryEntryId" value="@h.Id" />
                                        <button type="submit" class="px-3 py-1.5 text-xs rounded-lg border border-rose-300 text-rose-700 hover:bg-rose-50">Delete</button>
                                    </form>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="text-sm text-slate-500">No document approval history entries found.</p>
        }
    </div>

    @if (!Model.PendingTasks.Any() && !Model.PendingDocuments.Any() && !Model.PendingTrainings.Any())
    {
        <div class="rounded-2xl border border-slate-200 bg-white p-12 text-center">
            <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-brand-50">
                <svg class="h-8 w-8 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
            </div>
            <h3 class="text-lg font-semibold text-slate-900">All caught up!</h3>
            <p class="mx-auto mt-1 max-w-sm text-slate-500">There are no pending tasks, documents, or trainings awaiting your approval at this time.</p>
        </div>
    }
    else
    {
        @if (Model.PendingTasks.Any())
        {
            <div class="space-y-4">
                <h2 class="flex items-center gap-2 text-lg font-semibold text-slate-800">
                    <svg class="h-5 w-5 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                    </svg>
                    Pending Tasks (@Model.PendingTasks.Count)
                </h2>
                <div class="grid gap-4">
                    @foreach (var item in Model.PendingTasks)
                    {
                        <div class="flex items-center justify-between rounded-xl border border-slate-200 bg-white p-4 transition-all hover:shadow-soft">
                            <div class="flex items-center gap-4">
                                <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-indigo-50 text-indigo-600">
                                    <span class="text-xs font-bold">TASK</span>
                                </div>
                                <div>
                                    <div class="font-semibold text-slate-900">@item.Title</div>
                                    <div class="text-xs text-slate-500">Submitted by <span class="font-medium text-slate-700">@item.SubmmitedBy</span> - @item.SubmittedAt.ToString("MMM dd, yyyy HH:mm")</div>
                                    <div class="text-xs text-slate-500">Submitted to: <span class="font-medium text-slate-700">@item.SubmittedTo</span></div>
                                </div>
                            </div>
                            <a href="/Tasks/Details/@item.Id" class="rounded-lg border border-slate-200 px-3 py-1.5 text-sm font-medium text-slate-600 transition-colors hover:bg-slate-50">Review</a>
                        </div>
                    }
                </div>
            </div>
        }

        @if (Model.PendingDocuments.Any())
        {
            <div class="space-y-4">
                <h2 class="flex items-center gap-2 text-lg font-semibold text-slate-800">
                    <svg class="h-5 w-5 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                    Pending Documents (@Model.PendingDocuments.Count)
                </h2>
                <div class="grid gap-4">
                    @foreach (var item in Model.PendingDocuments)
                    {
                        <div class="flex items-center justify-between rounded-xl border border-slate-200 bg-white p-4 transition-all hover:shadow-soft">
                            <div class="flex items-center gap-4">
                                <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-amber-50 text-amber-600">
                                    <span class="text-xs font-bold">DOC</span>
                                </div>
                                <div>
                                    <div class="font-semibold text-slate-900">@item.Title</div>
                                    <div class="text-xs text-slate-500">Submitted by <span class="font-medium text-slate-700">@item.SubmmitedBy</span> - @item.SubmittedAt.ToString("MMM dd, yyyy HH:mm")</div>
                                    <div class="text-xs text-slate-500">Submitted to: <span class="font-medium text-slate-700">@item.SubmittedTo</span></div>
                                </div>
                            </div>
                            <a href="/Documents/Details/@item.Id" class="rounded-lg border border-slate-200 px-3 py-1.5 text-sm font-medium text-slate-600 transition-colors hover:bg-slate-50">Review</a>
                        </div>
                    }
                </div>
            </div>
        }

        @if (Model.PendingTrainings.Any())
        {
            <div class="space-y-4">
                <h2 class="flex items-center gap-2 text-lg font-semibold text-slate-800">
                    <svg class="h-5 w-5 text-violet-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" />
                    </svg>
                    Pending Trainings (@Model.PendingTrainings.Count)
                </h2>
                <div class="grid gap-4">
                    @foreach (var item in Model.PendingTrainings)
                    {
                        <div class="flex items-center justify-between rounded-xl border border-slate-200 bg-white p-4 transition-all hover:shadow-soft">
                            <div class="flex items-center gap-4">
                                <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-violet-50 text-violet-600">
                                    <span class="text-xs font-bold">TRN</span>
                                </div>
                                <div>
                                    <div class="font-semibold text-slate-900">@item.Title</div>
                                    <div class="text-xs text-slate-500">Submitted by <span class="font-medium text-slate-700">@item.SubmmitedBy</span> - @item.SubmittedAt.ToString("MMM dd, yyyy HH:mm")</div>
                                </div>
                            </div>
                            <a href="/Training/Details/@item.Id" class="rounded-lg border border-slate-200 px-3 py-1.5 text-sm font-medium text-slate-600 transition-colors hover:bg-slate-50">Review</a>
                        </div>
                    }
                </div>
            </div>
        }
    }
</div>
