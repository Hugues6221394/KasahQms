@page
@model KasahQMS.Web.Pages.Documents.IndexModel
@{
    ViewData["Title"] = "Documents";
}

<div class="py-8 space-y-6">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 space-y-6">
        @if (TempData["SuccessMessage"] is string successMessage)
        {
            <div class="rounded-xl border border-emerald-200 bg-emerald-50 p-4 text-emerald-800">@successMessage</div>
        }
        @if (TempData["ErrorMessage"] is string errorMessage)
        {
            <div class="rounded-xl border border-rose-200 bg-rose-50 p-4 text-rose-800">@errorMessage</div>
        }

        @if (Model.UserRoleContext == "Auditor")
        {
            <div class="bg-amber-50 border border-amber-200 rounded-2xl p-4 animate-on-scroll">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-amber-100 flex items-center justify-center flex-shrink-0">
                        <svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                    </div>
                    <div>
                        <h3 class="font-semibold text-amber-900">Auditor Read-Only Mode</h3>
                        <p class="text-sm text-amber-700">You have view-only access to all documents. You cannot create, modify, or delete any records.</p>
                    </div>
                </div>
            </div>
        }

        <section class="relative overflow-hidden rounded-2xl border border-slate-200 bg-slate-900 text-white animate-on-scroll" style="background-image:linear-gradient(120deg,rgba(15,23,42,.88),rgba(37,99,235,.55)),url('https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?auto=format&fit=crop&w=1600&q=80');background-size:cover;background-position:center;">
            <div class="p-6 md:p-8 flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6">
                <div>
                    <p class="text-xs uppercase tracking-[0.2em] text-blue-100">Quality Management</p>
                    <h1 class="mt-2 text-3xl font-bold">Documents</h1>
                    <p class="mt-2 text-blue-100 max-w-2xl">
                        @if (Model.UserRoleContext == "Staff")
                        {
                            <text>Your documents and department documents</text>
                        }
                        else if (Model.UserRoleContext == "Manager")
                        {
                            <text>Documents from you and your team</text>
                        }
                        else if (Model.UserRoleContext == "Auditor")
                        {
                            <text>Document overview for audit purposes (read-only)</text>
                        }
                        else
                        {
                            <text>Manage your quality documents, policies, and procedures</text>
                        }
                    </p>
                </div>
                @if (Model.CanCreateDocument)
                {
                    <a href="/Documents/Create" class="inline-flex items-center px-4 py-2.5 bg-white/95 text-slate-900 font-semibold rounded-xl hover:bg-white transition-all hover:-translate-y-0.5 shadow-lg">
                        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
                        New Document
                    </a>
                }
            </div>
        </section>

        @{ 
            var visibleDraft = Model.Documents.Count(d => d.IsDraft && !d.IsLatestRejected);
            var visibleRejected = Model.Documents.Count(d => d.IsLatestRejected);
            var visibleApproved = Model.Documents.Count(d => d.Status == "Approved");
            var visibleReview = Model.Documents.Count(d => d.Status == "InReview" || d.Status == "Submitted");
        }
        <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-5">
            <a href="/Documents" class="card p-5 animate-on-scroll hover:-translate-y-0.5 transition-all block"><p class="text-xs uppercase tracking-wider text-slate-500">Total Results</p><p class="mt-2 text-3xl font-bold text-slate-900">@Model.TotalItems</p></a>
            <a href="/Documents?status=Draft" class="card p-5 animate-on-scroll hover:-translate-y-0.5 transition-all block"><p class="text-xs uppercase tracking-wider text-slate-500">Visible Drafts</p><p class="mt-2 text-3xl font-bold text-amber-600">@visibleDraft</p></a>
            <a href="/Documents?status=Submitted" class="card p-5 animate-on-scroll hover:-translate-y-0.5 transition-all block"><p class="text-xs uppercase tracking-wider text-slate-500">In Review</p><p class="mt-2 text-3xl font-bold text-blue-600">@visibleReview</p></a>
            <a href="/Documents?status=Approved" class="card p-5 animate-on-scroll hover:-translate-y-0.5 transition-all block"><p class="text-xs uppercase tracking-wider text-slate-500">Approved</p><p class="mt-2 text-3xl font-bold text-emerald-600">@visibleApproved</p></a>
            <a href="/Documents?status=Rejected" class="card p-5 animate-on-scroll hover:-translate-y-0.5 transition-all block"><p class="text-xs uppercase tracking-wider text-slate-500">Rejected</p><p class="mt-2 text-3xl font-bold text-rose-600">@visibleRejected</p></a>
        </div>

        @if (Model.IsExecutiveUser)
        {
            <div class="card p-5">
                <div class="flex items-center justify-between gap-3">
                    <h2 class="text-lg font-semibold text-slate-900">Executive Pending Approvals (All Departments)</h2>
                    <a href="/Documents?status=Submitted" class="text-sm font-medium text-brand-600">View all pending</a>
                </div>
                <div class="mt-4 space-y-3">
                    @if (Model.PendingApprovals.Any())
                    {
                        @foreach (var item in Model.PendingApprovals)
                        {
                            <div class="rounded-lg border border-slate-200 p-3">
                                <div class="flex flex-wrap items-center justify-between gap-3">
                                    <div>
                                        <a asp-page="/Documents/Details" asp-route-id="@item.Id" class="font-semibold text-slate-900 hover:text-brand-600">@item.Title</a>
                                        <p class="text-xs text-slate-500">@item.Number • @item.Status • Submitted @item.SubmittedAt</p>
                                    </div>
                                    <div class="flex items-center gap-2">
                                        <form method="post" asp-page-handler="Approve" class="inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="ActionDocumentId" value="@item.Id" />
                                            <button type="submit" class="rounded-lg bg-emerald-600 px-3 py-2 text-xs font-semibold text-white hover:bg-emerald-700">Approve</button>
                                        </form>
                                        <form method="post" asp-page-handler="Reject" class="inline-flex items-center gap-2">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="ActionDocumentId" value="@item.Id" />
                                            <input type="text" name="ActionRejectReason" required placeholder="Reason" class="rounded-lg border border-slate-300 px-2 py-2 text-xs" />
                                            <button type="submit" class="rounded-lg bg-rose-600 px-3 py-2 text-xs font-semibold text-white hover:bg-rose-700">Reject</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-sm text-slate-500">No pending documents right now.</p>
                    }
                </div>
            </div>
        }

        <div class="card p-4 md:p-5 animate-on-scroll">
            <form method="get" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-12 gap-4 items-end">
                <div class="xl:col-span-4">
                    <label class="block text-sm font-medium text-slate-700 mb-1">Search</label>
                    <div class="relative">
                        <input type="search" name="search" value="@Model.SearchTerm" placeholder="Search documents..." class="w-full pl-10 pr-4 py-2.5 border border-slate-300 rounded-lg focus:ring-2 focus:ring-qms-500 focus:border-qms-500">
                        <svg class="absolute left-3 top-3 h-5 w-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                    </div>
                </div>
                <div class="xl:col-span-3">
                    <label class="block text-sm font-medium text-slate-700 mb-1">Status</label>
                    <select name="status" class="w-full px-3 py-2.5 border border-slate-300 rounded-lg focus:ring-2 focus:ring-qms-500 focus:border-qms-500">
                        <option value="" selected="@string.IsNullOrEmpty(Model.Status)">All Statuses</option>
                        <option value="Draft" selected="@(Model.Status == "Draft")">Draft</option>
                        <option value="Submitted" selected="@(Model.Status == "Submitted")">Submitted</option>
                        <option value="InReview" selected="@(Model.Status == "InReview")">In Review</option>
                        <option value="Approved" selected="@(Model.Status == "Approved")">Approved</option>
                        <option value="Rejected" selected="@(Model.Status == "Rejected")">Rejected</option>
                        <option value="Archived" selected="@(Model.Status == "Archived")">Archived</option>
                    </select>
                </div>
                <div class="xl:col-span-3">
                    <label class="block text-sm font-medium text-slate-700 mb-1">Type</label>
                    <select name="type" class="w-full px-3 py-2.5 border border-slate-300 rounded-lg focus:ring-2 focus:ring-qms-500 focus:border-qms-500">
                        <option value="" selected="@string.IsNullOrEmpty(Model.Type)">All Types</option>
                        @foreach (var type in Model.DocumentTypes)
                        {
                            <option value="@type.Name" selected="@(Model.Type == type.Name)">@type.Name</option>
                        }
                    </select>
                </div>
                <div class="xl:col-span-2 flex gap-2">
                    <button type="submit" class="w-full px-4 py-2.5 bg-qms-600 text-white font-medium rounded-lg hover:bg-qms-700 transition-colors">Filter</button>
                    <a href="/Documents" class="px-4 py-2.5 text-slate-600 hover:text-slate-900 font-medium">Clear</a>
                </div>
            </form>
        </div>

        <div class="card overflow-hidden animate-on-scroll">
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-slate-200">
                    <thead class="bg-slate-50"><tr><th class="px-6 py-4 text-left text-xs font-semibold text-slate-600 uppercase tracking-wider">Document</th><th class="px-6 py-4 text-left text-xs font-semibold text-slate-600 uppercase tracking-wider">Type</th><th class="px-6 py-4 text-left text-xs font-semibold text-slate-600 uppercase tracking-wider">Status</th><th class="px-6 py-4 text-left text-xs font-semibold text-slate-600 uppercase tracking-wider">Latest Decision (When/Why)</th><th class="px-6 py-4 text-left text-xs font-semibold text-slate-600 uppercase tracking-wider">Version</th><th class="px-6 py-4 text-left text-xs font-semibold text-slate-600 uppercase tracking-wider">Modified</th><th class="px-6 py-4 text-right text-xs font-semibold text-slate-600 uppercase tracking-wider">Actions</th></tr></thead>
                    <tbody class="bg-white divide-y divide-slate-100">
                        @if (!Model.Documents.Any())
                        {
                            <tr><td colspan="7" class="px-6 py-14 text-center"><div class="mx-auto w-14 h-14 rounded-full bg-slate-100 flex items-center justify-center mb-3"><svg class="w-7 h-7 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg></div><p class="text-sm font-medium text-slate-700">No documents found</p><p class="text-sm text-slate-500 mt-1">Try adjusting your filters.</p></td></tr>
                        }
                        else
                        {
                            @foreach (var doc in Model.Documents)
                            {
                                <tr class="hover:bg-slate-50 transition-colors">
                                    <td class="px-6 py-4"><div class="flex items-center"><div class="flex-shrink-0 h-10 w-10 bg-qms-100 rounded-lg flex items-center justify-center"><svg class="w-5 h-5 text-qms-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg></div><div class="ml-4"><div class="text-sm font-semibold text-slate-900">@doc.Title</div><div class="text-sm text-slate-500">@doc.Number</div></div></div></td>
                                    <td class="px-6 py-4"><span class="inline-flex px-2.5 py-1 rounded-full text-xs font-medium bg-slate-100 text-slate-700">@doc.Type</span></td>
                                    <td class="px-6 py-4"><span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium @doc.StatusClass">@doc.Status</span></td>
                                    <td class="px-6 py-4">
                                        <div class="space-y-1">
                                            <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium @doc.LastDecisionClass">@doc.LastDecision</span>
                                            <div class="text-xs text-slate-500">@doc.LastDecisionAt</div>
                                            @if (!string.IsNullOrWhiteSpace(doc.LastDecisionReason))
                                            {
                                                <div class="text-xs text-slate-600 max-w-sm truncate" title="@doc.LastDecisionReason">@doc.LastDecisionReason</div>
                                            }
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 text-sm text-slate-600">@doc.Version</td>
                                    <td class="px-6 py-4 text-sm text-slate-500">@doc.ModifiedAt</td>
                                    <td class="px-6 py-4 text-right"><div class="flex items-center justify-end space-x-2"><a asp-page="/Documents/Details" asp-route-id="@doc.Id" class="p-2 text-slate-400 hover:text-qms-600 transition-colors" title="View"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg></a>@if (Model.UserRoleContext != "Auditor" && doc.IsDraft) { <a asp-page="/Documents/Edit" asp-route-id="@doc.Id" class="p-2 text-slate-400 hover:text-qms-600 transition-colors" title="Edit"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg></a> }</div></td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
            <div class="px-6 py-4 border-t border-slate-200 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                @{ var start = Model.TotalItems == 0 ? 0 : (Model.CurrentPage - 1) * Model.PageSize + 1; var end = Math.Min(Model.TotalItems, Model.CurrentPage * Model.PageSize); }
                <div class="text-sm text-slate-500">Showing <span class="font-medium">@start</span> to <span class="font-medium">@end</span> of <span class="font-medium">@Model.TotalItems</span> results</div>
                <nav class="flex items-center space-x-2">
                    <a class="px-3 py-2 text-sm text-slate-500 bg-slate-100 rounded-lg hover:bg-slate-200 transition-colors @(Model.CurrentPage <= 1 ? "pointer-events-none opacity-50" : "")" href="?page=@(Model.CurrentPage - 1)&search=@Model.SearchTerm&status=@Model.Status&type=@Model.Type">Previous</a>
                    @for (var i = 1; i <= Model.TotalPages; i++)
                    {
                        <a class="px-3 py-2 text-sm rounded-lg @(i == Model.CurrentPage ? "text-white bg-qms-600" : "text-slate-600 bg-slate-100 hover:bg-slate-200")" href="?page=@i&search=@Model.SearchTerm&status=@Model.Status&type=@Model.Type">@i</a>
                    }
                    <a class="px-3 py-2 text-sm text-slate-600 bg-slate-100 rounded-lg hover:bg-slate-200 transition-colors @(Model.CurrentPage >= Model.TotalPages ? "pointer-events-none opacity-50" : "")" href="?page=@(Model.CurrentPage + 1)&search=@Model.SearchTerm&status=@Model.Status&type=@Model.Type">Next</a>
                </nav>
            </div>
        </div>
    </div>
</div>
