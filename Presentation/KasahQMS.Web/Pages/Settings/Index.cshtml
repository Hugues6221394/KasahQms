@page
@model KasahQMS.Web.Pages.Settings.IndexModel
@{
    ViewData["Title"] = "System Settings";
}

<div class="space-y-6">
    <div class="relative overflow-hidden rounded-2xl border border-slate-200 bg-gradient-to-r from-slate-900 to-slate-800 p-7 text-white">
        <div class="absolute -right-10 top-0 h-32 w-32 rounded-full bg-brand-400/20 blur-2xl"></div>
        <div class="relative">
            <p class="text-xs uppercase tracking-[0.2em] text-slate-300">Platform Governance</p>
            <h1 class="mt-2 text-3xl font-semibold">System settings</h1>
            <p class="mt-2 text-sm text-slate-200">Configure global policies, retention controls, and operational defaults.</p>
        </div>
    </div>

    <div class="grid gap-4 md:grid-cols-4">
        <div class="card p-4 md:col-span-2"><p class="text-xs uppercase tracking-wide text-slate-500">Lockout threshold</p><p class="mt-2 text-2xl font-semibold text-slate-900">@Model.LockoutThreshold attempts</p></div>
        <div class="card p-4"><p class="text-xs uppercase tracking-wide text-slate-500">Audit retention</p><p class="mt-2 text-2xl font-semibold text-indigo-600">@Model.AuditLogRetentionYears yrs</p></div>
        <div class="card p-4"><p class="text-xs uppercase tracking-wide text-slate-500">Archive window</p><p class="mt-2 text-2xl font-semibold text-brand-600">@Model.DocumentArchiveMonths mos</p></div>
    </div>

    <div class="grid gap-6 lg:grid-cols-2">
        <div class="card p-6 lg:col-span-2">
            <h2 class="text-lg font-semibold text-slate-900">Maintenance mode</h2>
            <p class="mt-1 text-sm text-slate-500">When enabled, only system administrators can access the platform.</p>
            @if (Model.CanManageSystemSettings)
            {
                <form method="post" asp-page-handler="Maintenance" class="mt-4 space-y-4">
                    @Html.AntiForgeryToken()
                    <label class="flex items-center justify-between rounded-lg border border-slate-200 bg-slate-50 px-4 py-3">
                        <span class="text-sm text-slate-700 font-medium">Enable maintenance mode</span>
                        <input asp-for="MaintenanceModeEnabled" type="checkbox" class="h-5 w-5 rounded border-slate-300 text-brand-600 focus:ring-brand-300" />
                    </label>
                    <label class="block text-sm text-slate-700">
                        Message shown on login page
                        <textarea asp-for="MaintenanceModeMessage" rows="3" class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm"></textarea>
                    </label>
                    <button type="submit" class="px-4 py-2 bg-brand-600 text-white rounded-lg hover:bg-brand-700 text-sm font-medium">Save maintenance settings</button>
                </form>
            }
            else
            {
                <p class="mt-3 text-sm text-amber-700">Only system administrators can change maintenance mode.</p>
            }
        </div>

        <div class="card p-6">
            <h2 class="text-lg font-semibold text-slate-900">Security policies</h2>
            <div class="mt-4 space-y-4 text-sm text-slate-600">
                <label class="flex items-center justify-between rounded-lg border border-slate-200 bg-slate-50 px-4 py-3">
                    <span>Require MFA for privileged users</span>
                    <input type="checkbox" @(Model.RequireMfa ? "checked" : "") class="h-5 w-5 rounded border-slate-300 text-brand-600 focus:ring-brand-300" />
                </label>
                <label class="flex items-center justify-between rounded-lg border border-slate-200 bg-slate-50 px-4 py-3">
                    <span>Enforce strong password policies</span>
                    <input type="checkbox" @(Model.StrongPasswords ? "checked" : "") class="h-5 w-5 rounded border-slate-300 text-brand-600 focus:ring-brand-300" />
                </label>
                <label class="flex items-center justify-between rounded-lg border border-slate-200 bg-slate-50 px-4 py-3">
                    <span>Lock account after @Model.LockoutThreshold failed logins</span>
                    <input type="checkbox" @(Model.LockoutThreshold > 0 ? "checked" : "") class="h-5 w-5 rounded border-slate-300 text-brand-600 focus:ring-brand-300" />
                </label>
            </div>
        </div>

        <div class="card p-6">
            <h2 class="text-lg font-semibold text-slate-900">Notification routing</h2>
            <div class="mt-4 space-y-4 text-sm text-slate-600">
                <label class="block">
                    CAPA escalation threshold (days)
                    <input class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm" value="@Model.CapaEscalationDays" />
                </label>
                <label class="block">
                    Audit reminder cadence
                    <select class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm">
                        <option value="Weekly">Weekly</option>
                        <option value="Bi-weekly">Bi-weekly</option>
                        <option value="Monthly">Monthly</option>
                    </select>
                </label>
            </div>
        </div>

        <div class="card p-6 lg:col-span-2">
            <h2 class="text-lg font-semibold text-slate-900">Retention &amp; archival</h2>
            <div class="mt-4 grid gap-4 md:grid-cols-3 text-sm text-slate-600">
                <label class="block">
                    Audit log retention (years)
                    <input class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm" value="@Model.AuditLogRetentionYears" />
                </label>
                <label class="block">
                    Document archive threshold (months)
                    <input class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm" value="@Model.DocumentArchiveMonths" />
                </label>
                <label class="block">
                    Backup frequency
                    <select class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm">
                        <option value="Daily">Daily</option>
                        <option value="Weekly">Weekly</option>
                        <option value="Monthly">Monthly</option>
                    </select>
                </label>
            </div>
        </div>
    </div>
</div>
